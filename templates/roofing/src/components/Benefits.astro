---
import brand from '../../brand.json';

const iconPaths: Record<string, string> = {
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  zap: 'M13 10V3L4 14h7v7l9-11h-7z',
  check: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
};
---
<section class="section-padding" style={`background-color: ${brand.colors.light}`}>
  <div class="mx-auto max-w-7xl">
    <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-20">
      <!-- Left: Text -->
      <div class="animate-on-scroll from-left">
        <p class="text-sm font-semibold" style={`color: ${brand.colors.accent}`}>Why Choose {brand.businessName}</p>
        <h2 class="mt-2 text-3xl font-extrabold tracking-tight sm:text-4xl">Unmatched Benefits for Your Peace of Mind</h2>
      </div>
      <!-- Right: Description -->
      <div class="animate-on-scroll from-right">
        <p class="text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
          When you choose {brand.businessName}, you're not just getting a roof — you're investing in decades of protection, backed by our family's commitment to excellence.
        </p>
      </div>
    </div>

    <!-- Benefit Cards -->
    <div class="stagger-children mt-12 grid gap-6 sm:grid-cols-3">
      {brand.benefits.map((benefit) => (
        <div class="card-hover rounded-2xl p-7" style={`background-color: ${brand.colors.accentLight}`}>
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-white shadow-sm">
            <svg class="h-6 w-6" style={`color: ${brand.colors.accent}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[benefit.icon] || iconPaths.check} />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold" style={`color: ${brand.colors.text}`}>{benefit.title}</h3>
          <p class="mt-2 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
