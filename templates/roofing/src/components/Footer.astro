---
import brand from '../../brand.json';
---
<footer style={`background-color: ${brand.colors.primary}`} class="text-white">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Main footer -->
    <div class="grid gap-12 py-16 md:grid-cols-3">
      <div>
        <h3 class="text-xl font-extrabold">{brand.businessName}</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/60">{brand.description}</p>
      </div>
      <div>
        <h4 class="font-semibold" style={`color: ${brand.colors.accent}`}>Quick Links</h4>
        <ul class="mt-4 space-y-3">
          {brand.nav.map(link => (
            <li>
              <a href={link.href} class="text-sm text-white/60 transition-colors hover:text-white">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-semibold" style={`color: ${brand.colors.accent}`}>Contact</h4>
        <div class="mt-4 space-y-3 text-sm text-white/60">
          {brand.contact.email && (
            <a href={`mailto:${brand.contact.email}`} class="flex items-center gap-3 transition-colors hover:text-white">
              <svg class="h-4 w-4 flex-shrink-0" style={`color: ${brand.colors.accent}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {brand.contact.email}
            </a>
          )}
          {brand.contact.phone && (
            <a href={`tel:${brand.contact.phone}`} class="flex items-center gap-3 transition-colors hover:text-white">
              <svg class="h-4 w-4 flex-shrink-0" style={`color: ${brand.colors.accent}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {brand.contact.phone}
            </a>
          )}
          {brand.contact.address && (
            <p class="flex items-start gap-3">
              <svg class="mt-0.5 h-4 w-4 flex-shrink-0" style={`color: ${brand.colors.accent}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              {brand.contact.address}
            </p>
          )}
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 py-6 text-center text-sm text-white/40">
      &copy; {new Date().getFullYear()} {brand.businessName}. All rights reserved.
    </div>
  </div>
</footer>
