---
import brand from '../../brand.json';
---
<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-20">
      <div class="animate-on-scroll from-left">
        <p class="text-sm font-semibold" style={`color: ${brand.colors.accent}`}>Our Latest Projects</p>
        <h2 class="mt-2 text-3xl font-extrabold tracking-tight sm:text-4xl">Craftsmanship That Speaks for Itself</h2>
      </div>
      <div class="animate-on-scroll from-right">
        <p class="text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
          Every project tells a story of quality, dedication, and attention to detail. Explore our recent work and see why homeowners trust {brand.businessName}.
        </p>
      </div>
    </div>

    <div class="stagger-children mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {brand.projectImages.map((img, i) => (
        <div class="group relative overflow-hidden rounded-2xl shadow-lg" style="aspect-ratio: 4/3">
          <img
            src={img}
            alt={`Project ${i + 1}`}
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <div class="absolute bottom-5 left-5 right-5">
              <p class="text-sm font-bold text-white">Residential Project</p>
              <p class="text-xs text-white/70">Complete roof replacement</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
