---
import brand from '../../brand.json';
---
<header class="fixed top-0 left-0 right-0 z-50 border-b border-gray-100 bg-white/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="/" class="flex items-center gap-2">
      {brand.logoUrl ? (
        <img src={brand.logoUrl} alt={brand.businessName} class="h-8 max-w-[140px] object-contain" />
      ) : (
        <div class="flex items-center gap-2">
          <svg class="h-7 w-7" style={`color: ${brand.colors.accent}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          <span class="text-lg font-extrabold tracking-tight" style={`color: ${brand.colors.text}`}>
            {brand.businessName}
          </span>
        </div>
      )}
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {brand.nav.map(link => (
        <a href={link.href} class="text-sm font-medium transition-colors hover:opacity-70" style={`color: ${brand.colors.text}`}>
          {link.label}
        </a>
      ))}
      <a href="/contact" class="btn-accent !py-2.5 !px-5 !text-sm">
        Get a Free Estimate
      </a>
    </nav>

    <button class="md:hidden" id="mobile-menu-btn" aria-label="Menu" style={`color: ${brand.colors.text}`}>
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div class="hidden border-t border-gray-100 bg-white md:hidden" id="mobile-menu">
    <div class="flex flex-col gap-1 px-6 py-4">
      {brand.nav.map(link => (
        <a href={link.href} class="rounded-lg px-4 py-3 text-sm font-medium transition-colors hover:bg-gray-50" style={`color: ${brand.colors.text}`}>
          {link.label}
        </a>
      ))}
      <a href="/contact" class="btn-accent mt-2 text-center !text-sm">
        Get a Free Estimate
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  btn.addEventListener('click', () => menu.classList.toggle('hidden'));
</script>
