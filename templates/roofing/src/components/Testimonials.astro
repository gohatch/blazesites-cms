---
import brand from '../../brand.json';
---
<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <p class="text-sm font-bold uppercase tracking-widest" style={`color: ${brand.colors.accent}`}>Testimonials</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">What Our Clients Say</h2>
    </div>

    <div class="stagger-children mt-16 grid gap-8 md:grid-cols-3">
      {brand.testimonials.map((t) => (
        <div class="card-hover relative rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
          <!-- Quote mark -->
          <svg class="mb-4 h-8 w-8" style={`color: ${brand.colors.accent}; opacity: 0.3`} fill="currentColor" viewBox="0 0 32 32">
            <path d="M10 8c-3.3 0-6 2.7-6 6v10h10V14H8c0-1.1.9-2 2-2V8zm14 0c-3.3 0-6 2.7-6 6v10h10V14h-6c0-1.1.9-2 2-2V8z" />
          </svg>

          <p class="text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
            "{t.quote}"
          </p>

          <div class="mt-6 border-t border-gray-100 pt-4">
            <p class="font-bold">{t.author}</p>
            <p class="text-sm" style={`color: ${brand.colors.textLight}`}>{t.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
