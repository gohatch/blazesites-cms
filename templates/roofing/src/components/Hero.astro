---
import brand from '../../brand.json';
---
<section class="relative overflow-hidden bg-white pt-24 pb-0 lg:pt-32 lg:pb-0">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Left: Text Content -->
      <div class="hero-animate hero-animate-1">
        <h1 class="text-4xl font-extrabold leading-[1.08] tracking-tight sm:text-5xl lg:text-6xl" style={`color: ${brand.colors.text}`}>
          {brand.tagline}
        </h1>
        <p class="mt-6 max-w-lg text-lg leading-relaxed" style={`color: ${brand.colors.textLight}`}>
          {brand.description}
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a href="/contact" class="btn-accent text-center">
            Get a Free Estimate
          </a>
        </div>

        <!-- Trust badges row -->
        <div class="hero-animate hero-animate-3 mt-10 flex flex-wrap gap-8">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full" style={`background-color: ${brand.colors.accentLight}`}>
              <svg class="h-5 w-5" style={`color: ${brand.colors.accent}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-bold">Lifetime Warranty</p>
              <p class="text-xs" style={`color: ${brand.colors.textLight}`}>Protection</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <div class="flex -space-x-2">
              <div class="h-8 w-8 rounded-full border-2 border-white bg-gray-300"></div>
              <div class="h-8 w-8 rounded-full border-2 border-white bg-gray-400"></div>
              <div class="flex h-8 w-8 items-center justify-center rounded-full border-2 border-white text-xs font-bold text-white" style={`background-color: ${brand.colors.accent}`}>+</div>
            </div>
            <div>
              <div class="flex text-amber-400">
                {'★★★★★'.split('').map((s) => <span class="text-sm">{s}</span>)}
              </div>
              <p class="text-xs" style={`color: ${brand.colors.textLight}`}>Happy clients love our services!</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Hero Image with stats overlay -->
      <div class="hero-animate hero-animate-2 relative">
        <div class="relative overflow-hidden rounded-2xl shadow-2xl">
          <img
            src={brand.heroImage}
            alt={brand.tagline}
            class="h-[500px] w-full object-cover lg:h-[600px]"
          />
          <!-- Stats overlay at bottom -->
          <div class="absolute bottom-6 right-6 flex gap-4">
            <div class="rounded-xl bg-white/95 px-5 py-3 shadow-lg backdrop-blur-sm">
              <p class="text-2xl font-extrabold" style={`color: ${brand.colors.text}`}>{brand.stats[0].value}</p>
              <p class="text-xs" style={`color: ${brand.colors.textLight}`}>{brand.stats[0].label}</p>
            </div>
            <div class="rounded-xl bg-white/95 px-5 py-3 shadow-lg backdrop-blur-sm">
              <p class="text-2xl font-extrabold" style={`color: ${brand.colors.text}`}>{brand.stats[1].value}</p>
              <p class="text-xs" style={`color: ${brand.colors.textLight}`}>{brand.stats[1].label}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
