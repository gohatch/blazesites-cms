---
import brand from '../../brand.json';
---
<section id="contact" class="section-padding" style={`background-color: ${brand.colors.bg}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-start">

      <!-- Left: Info -->
      <div class="animate-on-scroll from-left">
        <div class="section-label">{brand.contact.heading}</div>
        <h2 class="font-serif text-4xl sm:text-5xl font-medium leading-tight mb-6" style={`color: ${brand.colors.primaryDark}`}>
          Come find us
        </h2>
        <p class="text-base font-light leading-relaxed mb-10" style={`color: ${brand.colors.textLight}`}>
          {brand.contact.subheading}
        </p>

        <!-- Studio image -->
        <div class="relative overflow-hidden rounded-2xl mb-10 h-64">
          <img
            src={brand.contact.image}
            alt="PureYoga Studio"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0" style={`background: linear-gradient(to top, ${brand.colors.primaryDark}66, transparent)`}></div>
        </div>

        <!-- Contact details -->
        <div class="space-y-5">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style={`background-color: ${brand.colors.bgDark}`}>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${brand.colors.primary}`}><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <span class="text-sm font-light" style={`color: ${brand.colors.textLight}`}>{brand.address}</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style={`background-color: ${brand.colors.bgDark}`}>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${brand.colors.primary}`}><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <span class="text-sm font-light" style={`color: ${brand.colors.textLight}`}>{brand.email}</span>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0" style={`background-color: ${brand.colors.bgDark}`}>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${brand.colors.primary}`}><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <span class="text-sm font-light" style={`color: ${brand.colors.textLight}`}>{brand.phone}</span>
          </div>
        </div>

        <!-- Hours -->
        <div class="mt-8 p-6 rounded-2xl" style={`background-color: ${brand.colors.white}`}>
          <h4 class="font-medium text-sm mb-4" style={`color: ${brand.colors.primaryDark}`}>Studio Hours</h4>
          <div class="space-y-2">
            {brand.contact.hours.map((h: any) => (
              <div class="flex justify-between text-sm font-light" style={`color: ${brand.colors.textLight}`}>
                <span>{h.days}</span>
                <span class="font-medium" style={`color: ${brand.colors.primaryDark}`}>{h.time}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="animate-on-scroll from-right">
        <div class="bg-white rounded-3xl p-8 sm:p-10" style={`border: 1px solid ${brand.colors.border}`}>
          <h3 class="font-serif text-2xl font-medium mb-2" style={`color: ${brand.colors.primaryDark}`}>Send us a message</h3>
          <p class="text-sm font-light mb-8" style={`color: ${brand.colors.textLight}`}>We'll get back to you within 24 hours.</p>

          <form class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label class="block text-xs font-medium mb-2 tracking-wide uppercase" style={`color: ${brand.colors.primaryDark}`}>First Name</label>
                <input
                  type="text"
                  placeholder="Maya"
                  class="w-full px-4 py-3 rounded-xl text-sm font-light outline-none transition-all duration-200"
                  style={`border: 1px solid ${brand.colors.border}; color: ${brand.colors.text}; background: ${brand.colors.bg}`}
                />
              </div>
              <div>
                <label class="block text-xs font-medium mb-2 tracking-wide uppercase" style={`color: ${brand.colors.primaryDark}`}>Last Name</label>
                <input
                  type="text"
                  placeholder="Sinclair"
                  class="w-full px-4 py-3 rounded-xl text-sm font-light outline-none transition-all duration-200"
                  style={`border: 1px solid ${brand.colors.border}; color: ${brand.colors.text}; background: ${brand.colors.bg}`}
                />
              </div>
            </div>

            <div>
              <label class="block text-xs font-medium mb-2 tracking-wide uppercase" style={`color: ${brand.colors.primaryDark}`}>Email</label>
              <input
                type="email"
                placeholder="maya@example.com"
                class="w-full px-4 py-3 rounded-xl text-sm font-light outline-none transition-all duration-200"
                style={`border: 1px solid ${brand.colors.border}; color: ${brand.colors.text}; background: ${brand.colors.bg}`}
              />
            </div>

            <div>
              <label class="block text-xs font-medium mb-2 tracking-wide uppercase" style={`color: ${brand.colors.primaryDark}`}>Interest</label>
              <select
                class="w-full px-4 py-3 rounded-xl text-sm font-light outline-none transition-all duration-200 appearance-none"
                style={`border: 1px solid ${brand.colors.border}; color: ${brand.colors.text}; background: ${brand.colors.bg}`}
              >
                <option value="">Select a class...</option>
                {brand.classes.map((cls: any) => (
                  <option value={cls.name}>{cls.name}</option>
                ))}
                <option value="general">General Inquiry</option>
                <option value="membership">Membership Information</option>
              </select>
            </div>

            <div>
              <label class="block text-xs font-medium mb-2 tracking-wide uppercase" style={`color: ${brand.colors.primaryDark}`}>Message</label>
              <textarea
                rows="4"
                placeholder="Tell us about your yoga experience and goals..."
                class="w-full px-4 py-3 rounded-xl text-sm font-light outline-none transition-all duration-200 resize-none"
                style={`border: 1px solid ${brand.colors.border}; color: ${brand.colors.text}; background: ${brand.colors.bg}`}
              ></textarea>
            </div>

            <button type="submit" class="btn-primary w-full justify-center">
              Send Message
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
