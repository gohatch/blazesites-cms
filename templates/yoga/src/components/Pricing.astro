---
import brand from '../../brand.json';
---
<section id="pricing" class="section-padding" style={`background-color: ${brand.colors.bg}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 animate-on-scroll">
      <div class="section-label justify-center">Membership</div>
      <h2 class="font-serif text-4xl sm:text-5xl font-medium leading-tight" style={`color: ${brand.colors.primaryDark}`}>
        Choose your path
      </h2>
      <p class="mt-4 text-base font-light" style={`color: ${brand.colors.textLight}`}>
        Flexible plans designed to support your practice at every stage of the journey.
      </p>
    </div>

    <!-- Pricing cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
      {brand.pricing.map((plan: any) => (
        <div class={`relative rounded-3xl overflow-hidden card-hover ${plan.highlight ? 'ring-2' : 'bg-white'}`} style={plan.highlight ? `ring-color: ${brand.colors.primary}; background-color: ${brand.colors.primaryDark}` : ''}>
          <!-- Plan image -->
          <div class="h-48 overflow-hidden relative">
            <img
              src={plan.image}
              alt={plan.name}
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0" style={plan.highlight ? `background: linear-gradient(to bottom, transparent 30%, ${brand.colors.primaryDark})` : `background: linear-gradient(to bottom, transparent 30%, white)`}></div>
          </div>

          <!-- Content -->
          <div class="p-7 -mt-6 relative">
            <!-- Plan name -->
            <div class="inline-block px-3 py-1 rounded-full text-xs font-medium mb-4" style={plan.highlight ? `background-color: ${brand.colors.primary}; color: white` : `background-color: ${brand.colors.bgDark}; color: ${brand.colors.primary}`}>
              {plan.name}
            </div>

            <!-- Price -->
            <div class="flex items-baseline gap-1 mb-2">
              <span class="font-serif text-5xl font-medium" style={plan.highlight ? 'color: white' : `color: ${brand.colors.primaryDark}`}>
                ${plan.price}
              </span>
              <span class="text-sm font-light" style={plan.highlight ? 'color: rgba(255,255,255,0.6)' : `color: ${brand.colors.textLight}`}>
                {plan.period}
              </span>
            </div>

            <p class="text-sm font-light mb-6" style={plan.highlight ? 'color: rgba(255,255,255,0.7)' : `color: ${brand.colors.textLight}`}>
              {plan.desc}
            </p>

            <!-- Divider -->
            <div class="h-px mb-6 opacity-20" style={plan.highlight ? 'background: white' : `background: ${brand.colors.border}`}></div>

            <!-- Features -->
            <ul class="space-y-3 mb-8">
              {plan.features.map((feature: string) => (
                <li class="flex items-center gap-2.5 text-sm font-light" style={plan.highlight ? 'color: rgba(255,255,255,0.85)' : `color: ${brand.colors.textLight}`}>
                  <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style={`color: ${brand.colors.primary}`}>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a
              href="#contact"
              class={plan.highlight ? 'btn-primary w-full justify-center' : 'btn-outline w-full justify-center'}
            >
              {plan.cta}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
