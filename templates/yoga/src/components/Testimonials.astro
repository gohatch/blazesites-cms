---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.white}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 animate-on-scroll">
      <div class="section-label justify-center">Testimonials</div>
      <h2 class="font-serif text-4xl sm:text-5xl font-medium leading-tight" style={`color: ${brand.colors.primaryDark}`}>
        Stories from our community
      </h2>
    </div>

    <!-- Testimonials grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
      {brand.testimonials.map((t: any) => (
        <div class="relative bg-white rounded-2xl p-8 card-hover" style={`border: 1px solid ${brand.colors.border}`}>
          <!-- Quote mark -->
          <div class="absolute top-6 right-8 font-serif text-8xl leading-none pointer-events-none select-none" style={`color: ${brand.colors.bgDark}; line-height: 1`}>
            "
          </div>

          <!-- Stars -->
          <div class="flex gap-1 mb-5">
            {Array(5).fill(0).map(() => (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" style={`color: ${brand.colors.accent}`}>
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <blockquote class="relative text-base font-light leading-relaxed mb-6" style={`color: ${brand.colors.textLight}`}>
            "{t.quote}"
          </blockquote>

          <!-- Author -->
          <div class="flex items-center gap-3">
            <div class="w-11 h-11 rounded-full flex items-center justify-center text-white text-sm font-medium flex-shrink-0" style={`background: linear-gradient(135deg, ${brand.colors.primary}, ${brand.colors.primaryLight})`}>
              {t.avatar}
            </div>
            <div>
              <p class="text-sm font-medium" style={`color: ${brand.colors.primaryDark}`}>{t.name}</p>
              <p class="text-xs font-light" style={`color: ${brand.colors.textLight}`}>{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
