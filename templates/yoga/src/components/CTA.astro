---
import brand from '../../brand.json';
---
<section class="relative py-24 overflow-hidden" style={`background-color: ${brand.colors.primaryDark}`}>
  <!-- Background texture -->
  <div class="absolute inset-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(#ffffff 1px, transparent 1px); background-size: 30px 30px;"></div>

  <!-- Decorative arcs -->
  <div class="absolute -top-32 -right-32 w-80 h-80 rounded-full opacity-10" style={`background-color: ${brand.colors.primary}`}></div>
  <div class="absolute -bottom-20 -left-20 w-56 h-56 rounded-full opacity-10" style={`background-color: ${brand.colors.primaryLight}`}></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center animate-on-scroll">
    <!-- Ornament -->
    <div class="flex items-center justify-center gap-4 mb-6">
      <div class="h-px w-16 bg-white/30"></div>
      <span class="text-white/60 text-xl">🧘</span>
      <div class="h-px w-16 bg-white/30"></div>
    </div>

    <h2 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-medium text-white leading-tight mb-6">
      {brand.cta.heading}
    </h2>
    <p class="text-lg font-light text-white/70 max-w-2xl mx-auto mb-10">
      {brand.cta.subheading}
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#contact" class="btn-primary" style={`background-color: ${brand.colors.primary}; color: white`}>
        {brand.cta.primary}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
      <a href="#classes" class="btn-outline" style="border-color: rgba(255,255,255,0.3); color: white;">
        {brand.cta.secondary}
      </a>
    </div>

    <!-- Feature pills -->
    <div class="flex flex-wrap justify-center gap-3 mt-12">
      {['No experience needed', 'All levels welcome', 'Cancel anytime', 'Free first class'].map((pill) => (
        <span class="px-4 py-1.5 rounded-full text-xs font-light text-white/70 border border-white/20">
          {pill}
        </span>
      ))}
    </div>
  </div>
</section>
