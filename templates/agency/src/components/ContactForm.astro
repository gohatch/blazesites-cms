---
import brand from '../../brand.json';
---
<section id="contact" class="section-padding" style={`background-color: ${brand.colors.background}`}>
  <div class="mx-auto max-w-7xl">
    <div class="grid gap-16 lg:grid-cols-2">
      <!-- Left Column — Info -->
      <div class="animate-on-scroll from-left">
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest" style={`color: ${brand.colors.accent}`}>Contact</p>
        <h2 class="heading-font text-3xl font-bold tracking-tight md:text-5xl" style={`color: ${brand.colors.text}`}>
          {brand.contact.heading}
        </h2>
        <p class="mt-4 text-lg leading-relaxed" style={`color: ${brand.colors.textLight}`}>
          {brand.contact.subheading}
        </p>

        <div class="mt-10 space-y-6">
          <!-- Email -->
          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-lg" style={`background-color: ${brand.colors.accent}18; color: ${brand.colors.accent}`}>
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold" style={`color: ${brand.colors.text}`}>Email</p>
              <p class="text-sm" style={`color: ${brand.colors.textLight}`}>{brand.contact.email}</p>
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-lg" style={`background-color: ${brand.colors.accent}18; color: ${brand.colors.accent}`}>
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold" style={`color: ${brand.colors.text}`}>Phone</p>
              <p class="text-sm" style={`color: ${brand.colors.textLight}`}>{brand.contact.phone}</p>
            </div>
          </div>

          <!-- Address -->
          <div class="flex items-start gap-4">
            <div class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-lg" style={`background-color: ${brand.colors.accent}18; color: ${brand.colors.accent}`}>
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold" style={`color: ${brand.colors.text}`}>Office</p>
              <p class="text-sm" style={`color: ${brand.colors.textLight}`}>{brand.contact.address}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column — Form -->
      <div class="animate-on-scroll from-right">
        <form class="space-y-6 rounded-2xl p-8" style={`background-color: ${brand.colors.card}; border: 1px solid ${brand.colors.border}`}>
          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <label class="mb-2 block text-sm font-medium" style={`color: ${brand.colors.text}`}>Name</label>
              <input
                type="text"
                placeholder="John Doe"
                class="w-full rounded-lg px-4 py-3 text-sm outline-none transition-colors focus:ring-2"
                style={`background-color: ${brand.colors.background}; color: ${brand.colors.text}; border: 1px solid ${brand.colors.border}; --tw-ring-color: ${brand.colors.accent}`}
              />
            </div>
            <div>
              <label class="mb-2 block text-sm font-medium" style={`color: ${brand.colors.text}`}>Email</label>
              <input
                type="email"
                placeholder="john@example.com"
                class="w-full rounded-lg px-4 py-3 text-sm outline-none transition-colors focus:ring-2"
                style={`background-color: ${brand.colors.background}; color: ${brand.colors.text}; border: 1px solid ${brand.colors.border}; --tw-ring-color: ${brand.colors.accent}`}
              />
            </div>
          </div>

          <div>
            <label class="mb-2 block text-sm font-medium" style={`color: ${brand.colors.text}`}>Company</label>
            <input
              type="text"
              placeholder="Your company name"
              class="w-full rounded-lg px-4 py-3 text-sm outline-none transition-colors focus:ring-2"
              style={`background-color: ${brand.colors.background}; color: ${brand.colors.text}; border: 1px solid ${brand.colors.border}; --tw-ring-color: ${brand.colors.accent}`}
            />
          </div>

          <div>
            <label class="mb-2 block text-sm font-medium" style={`color: ${brand.colors.text}`}>Service Interested In</label>
            <select
              class="w-full rounded-lg px-4 py-3 text-sm outline-none transition-colors focus:ring-2"
              style={`background-color: ${brand.colors.background}; color: ${brand.colors.textLight}; border: 1px solid ${brand.colors.border}; --tw-ring-color: ${brand.colors.accent}`}
            >
              <option value="">Select a service</option>
              {brand.services.items.map((service: { title: string }) => (
                <option value={service.title}>{service.title}</option>
              ))}
            </select>
          </div>

          <div>
            <label class="mb-2 block text-sm font-medium" style={`color: ${brand.colors.text}`}>Project Details</label>
            <textarea
              rows={4}
              placeholder="Tell us about your project..."
              class="w-full resize-none rounded-lg px-4 py-3 text-sm outline-none transition-colors focus:ring-2"
              style={`background-color: ${brand.colors.background}; color: ${brand.colors.text}; border: 1px solid ${brand.colors.border}; --tw-ring-color: ${brand.colors.accent}`}
            ></textarea>
          </div>

          <button
            type="submit"
            class="btn-primary w-full justify-center"
            style={`background-color: ${brand.colors.accent}; box-shadow: 0 4px 14px ${brand.colors.accent}44`}
          >
            Send Message
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
