---
import brand from '../../brand.json';
---
<section id="testimonials" class="section-padding" style={`background-color: ${brand.colors.card}`}>
  <div class="mx-auto max-w-7xl">
    <!-- Section Header -->
    <div class="animate-on-scroll mx-auto mb-16 max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest" style={`color: ${brand.colors.accent}`}>Testimonials</p>
      <h2 class="heading-font text-3xl font-bold tracking-tight md:text-5xl" style={`color: ${brand.colors.text}`}>
        What Our Clients Say
      </h2>
    </div>

    <!-- Testimonials Grid -->
    <div class="stagger-children grid gap-8 md:grid-cols-3">
      {brand.testimonials.map((testimonial: { quote: string; name: string; role: string; image: string }) => (
        <div class="rounded-2xl p-8" style={`background-color: ${brand.colors.background}; border: 1px solid ${brand.colors.border}`}>
          <!-- Stars -->
          <div class="mb-5 flex gap-1" style={`color: ${brand.colors.accent}`}>
            {[1,2,3,4,5].map(() => (
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
            "{testimonial.quote}"
          </p>

          <!-- Author -->
          <div class="mt-6 flex items-center gap-4">
            <img
              src={testimonial.image}
              alt={testimonial.name}
              class="h-12 w-12 rounded-full object-cover"
              loading="lazy"
              style={`border: 2px solid ${brand.colors.accent}44`}
            />
            <div>
              <p class="text-sm font-semibold" style={`color: ${brand.colors.text}`}>{testimonial.name}</p>
              <p class="text-xs" style={`color: ${brand.colors.textLight}`}>{testimonial.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
