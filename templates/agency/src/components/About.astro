---
import brand from '../../brand.json';
---
<section id="about" class="section-padding" style={`background-color: ${brand.colors.background}`}>
  <div class="mx-auto max-w-7xl">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <!-- Image -->
      <div class="animate-on-scroll from-left relative">
        <div class="overflow-hidden rounded-2xl" style={`border: 1px solid ${brand.colors.border}`}>
          <img
            src={brand.about.image}
            alt="Our team at work"
            class="h-full w-full object-cover"
            loading="lazy"
            style="aspect-ratio: 4/3;"
          />
        </div>
        <!-- Floating badge -->
        <div class="absolute -bottom-6 -right-4 rounded-xl px-6 py-4 shadow-2xl md:-right-8" style={`background-color: ${brand.colors.accent}`}>
          <p class="heading-font text-2xl font-bold text-white">6+ Years</p>
          <p class="text-sm text-white opacity-80">of Excellence</p>
        </div>
      </div>

      <!-- Content -->
      <div class="animate-on-scroll from-right">
        <p class="mb-3 text-sm font-semibold uppercase tracking-widest" style={`color: ${brand.colors.accent}`}>About Us</p>
        <h2 class="heading-font text-3xl font-bold tracking-tight md:text-5xl" style={`color: ${brand.colors.text}`}>
          {brand.about.heading}
        </h2>
        <p class="mt-6 text-lg leading-relaxed" style={`color: ${brand.colors.textLight}`}>
          {brand.about.description}
        </p>

        <!-- Highlights -->
        <ul class="mt-8 space-y-4">
          {brand.about.highlights.map((item: string) => (
            <li class="flex items-start gap-3">
              <div class="mt-1 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full" style={`background-color: ${brand.colors.accent}`}>
                <svg class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
              </div>
              <span class="text-base" style={`color: ${brand.colors.textLight}`}>{item}</span>
            </li>
          ))}
        </ul>

        <a href="#contact" class="btn-primary mt-10 inline-flex" style={`background-color: ${brand.colors.accent}; box-shadow: 0 4px 14px ${brand.colors.accent}44`}>
          Work With Us
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
