---
import brand from '../../brand.json';
---
<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md" style={`background-color: ${brand.colors.background}ee; border-bottom: 1px solid ${brand.colors.border}`}>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-3">
      <div class="flex h-9 w-9 items-center justify-center rounded-lg" style={`background-color: ${brand.colors.accent}`}>
        <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
        </svg>
      </div>
      <span class="heading-font text-xl font-bold tracking-tight" style={`color: ${brand.colors.text}`}>
        {brand.name}
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-8 lg:flex">
      {brand.nav.map(link => (
        <a href={link.href} class="text-sm font-medium transition-colors duration-200 hover:opacity-100" style={`color: ${brand.colors.textLight}`}>
          {link.label}
        </a>
      ))}
      <a href="#contact" class="btn-primary" style={`background-color: ${brand.colors.accent}; box-shadow: 0 4px 14px ${brand.colors.accent}44`}>
        Start a Project
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button class="lg:hidden" id="mobile-menu-btn" aria-label="Menu" style={`color: ${brand.colors.text}`}>
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="hidden lg:hidden" id="mobile-menu" style={`background-color: ${brand.colors.background}; border-top: 1px solid ${brand.colors.border}`}>
    <div class="flex flex-col gap-1 px-6 py-4">
      {brand.nav.map(link => (
        <a href={link.href} class="rounded-lg px-4 py-3 text-sm font-medium transition-colors" style={`color: ${brand.colors.textLight}`}>
          {link.label}
        </a>
      ))}
      <a href="#contact" class="btn-primary mt-2 justify-center" style={`background-color: ${brand.colors.accent}`}>
        Start a Project
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  btn.addEventListener('click', () => menu.classList.toggle('hidden'));
</script>
