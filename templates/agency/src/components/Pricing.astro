---
import brand from '../../brand.json';
---
<section id="pricing" class="section-padding" style={`background-color: ${brand.colors.background}`}>
  <div class="mx-auto max-w-7xl">
    <!-- Section Header -->
    <div class="animate-on-scroll mx-auto mb-16 max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest" style={`color: ${brand.colors.accent}`}>Pricing</p>
      <h2 class="heading-font text-3xl font-bold tracking-tight md:text-5xl" style={`color: ${brand.colors.text}`}>
        Investment Tiers
      </h2>
      <p class="mt-4 text-lg leading-relaxed" style={`color: ${brand.colors.textLight}`}>
        Transparent pricing for every stage of growth. No hidden fees, no surprises.
      </p>
    </div>

    <!-- Pricing Grid -->
    <div class="stagger-children grid gap-8 lg:grid-cols-3">
      {brand.pricing.map((tier: { name: string; price: string; period: string; description: string; features: string[]; popular?: boolean }) => (
        <div
          class={`relative rounded-2xl p-8 ${tier.popular ? 'glow-violet' : ''}`}
          style={`background-color: ${brand.colors.card}; border: 1px solid ${tier.popular ? brand.colors.accent : brand.colors.border}`}
        >
          {tier.popular && (
            <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full px-4 py-1 text-xs font-bold uppercase tracking-wider text-white" style={`background-color: ${brand.colors.accent}`}>
              Most Popular
            </div>
          )}

          <p class="heading-font text-lg font-bold" style={`color: ${brand.colors.accent}`}>{tier.name}</p>

          <div class="mt-4 flex items-baseline gap-1">
            <span class="heading-font text-4xl font-bold" style={`color: ${brand.colors.text}`}>{tier.price}</span>
            {tier.period && (
              <span class="text-sm" style={`color: ${brand.colors.textLight}`}> {tier.period}</span>
            )}
          </div>

          <p class="mt-3 text-sm" style={`color: ${brand.colors.textLight}`}>{tier.description}</p>

          <div class="my-8 h-px" style={`background-color: ${brand.colors.border}`}></div>

          <ul class="space-y-4">
            {tier.features.map((feature: string) => (
              <li class="flex items-start gap-3">
                <svg class="mt-0.5 h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style={`color: ${brand.colors.accent}`}>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                <span class="text-sm" style={`color: ${brand.colors.textLight}`}>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href="#contact"
            class={`mt-8 block w-full rounded-lg py-3 text-center text-sm font-semibold transition-all duration-200 hover:-translate-y-0.5`}
            style={tier.popular
              ? `background-color: ${brand.colors.accent}; color: white; box-shadow: 0 4px 14px ${brand.colors.accent}44`
              : `background-color: transparent; color: ${brand.colors.text}; border: 1.5px solid ${brand.colors.border}`
            }
          >
            {tier.price === 'Custom' ? 'Contact Us' : 'Get Started'}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
