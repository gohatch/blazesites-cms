---
import brand from '../../brand.json';
---
<footer style={`background-color: ${brand.colors.card}; border-top: 1px solid ${brand.colors.border}`}>
  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-12 lg:grid-cols-4">
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="#" class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg" style={`background-color: ${brand.colors.accent}`}>
            <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
            </svg>
          </div>
          <span class="heading-font text-xl font-bold" style={`color: ${brand.colors.text}`}>
            {brand.name}
          </span>
        </a>
        <p class="mt-4 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>
          {brand.footer.description}
        </p>

        <!-- Social Links -->
        <div class="mt-6 flex gap-3">
          {Object.entries(brand.footer.social).map(([platform, url]) => (
            <a
              href={url as string}
              class="flex h-9 w-9 items-center justify-center rounded-lg transition-colors duration-200"
              style={`background-color: ${brand.colors.background}; color: ${brand.colors.textLight}; border: 1px solid ${brand.colors.border}`}
              aria-label={platform}
            >
              {platform === 'twitter' && (
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              )}
              {platform === 'instagram' && (
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              )}
              {platform === 'linkedin' && (
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              )}
              {platform === 'dribbble' && (
                <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 24C5.385 24 0 18.615 0 12S5.385 0 12 0s12 5.385 12 12-5.385 12-12 12zm10.12-10.358c-.35-.11-3.17-.953-6.384-.438 1.34 3.684 1.887 6.684 1.992 7.308 2.3-1.555 3.936-4.02 4.395-6.87zm-6.115 7.808c-.153-.9-.75-4.032-2.19-7.77l-.066.02c-5.79 2.015-7.86 6.025-8.04 6.4 1.73 1.358 3.92 2.166 6.29 2.166 1.42 0 2.77-.29 4-.815zm-11.62-2.58c.232-.4 3.045-5.055 8.332-6.765.135-.045.27-.084.405-.12-.26-.585-.54-1.167-.832-1.74C7.17 11.775 2.206 11.71 1.756 11.7l-.004.312c0 2.633.998 5.037 2.634 6.855zm-2.42-8.955c.46.008 4.683.026 9.477-1.248-1.698-3.018-3.53-5.558-3.8-5.928-2.868 1.35-5.01 3.99-5.676 7.17zM9.6 2.052c.282.38 2.145 2.914 3.822 6 3.645-1.365 5.19-3.44 5.373-3.702A10.58 10.58 0 0012 1.48c-.825 0-1.63.1-2.4.285zm10.335 3.483c-.218.29-1.91 2.47-5.724 4.02.24.49.47.985.68 1.485.08.18.15.36.22.53 3.41-.43 6.8.26 7.14.33-.02-2.42-.88-4.64-2.31-6.38z"/></svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Link Columns -->
      {brand.footer.links.map((group: { heading: string; items: { label: string; href: string }[] }) => (
        <div>
          <p class="heading-font text-sm font-bold uppercase tracking-wider" style={`color: ${brand.colors.text}`}>
            {group.heading}
          </p>
          <ul class="mt-4 space-y-3">
            {group.items.map((link: { label: string; href: string }) => (
              <li>
                <a href={link.href} class="text-sm transition-colors duration-200 hover:opacity-100" style={`color: ${brand.colors.textLight}`}>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Newsletter Column -->
      <div>
        <p class="heading-font text-sm font-bold uppercase tracking-wider" style={`color: ${brand.colors.text}`}>
          Stay Updated
        </p>
        <p class="mt-4 text-sm" style={`color: ${brand.colors.textLight}`}>
          Get the latest insights on branding and design delivered to your inbox.
        </p>
        <form class="mt-4 flex gap-2">
          <input
            type="email"
            placeholder="your@email.com"
            class="min-w-0 flex-1 rounded-lg px-4 py-2.5 text-sm outline-none"
            style={`background-color: ${brand.colors.background}; color: ${brand.colors.text}; border: 1px solid ${brand.colors.border}`}
          />
          <button
            type="submit"
            class="flex-shrink-0 rounded-lg px-4 py-2.5 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5"
            style={`background-color: ${brand.colors.accent}`}
          >
            Join
          </button>
        </form>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 flex flex-col items-center justify-between gap-4 pt-8 sm:flex-row" style={`border-top: 1px solid ${brand.colors.border}`}>
      <p class="text-xs" style={`color: ${brand.colors.textLight}`}>
        &copy; 2024 {brand.name}. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="#" class="text-xs transition-colors hover:opacity-100" style={`color: ${brand.colors.textLight}`}>Privacy Policy</a>
        <a href="#" class="text-xs transition-colors hover:opacity-100" style={`color: ${brand.colors.textLight}`}>Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
