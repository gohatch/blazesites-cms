---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.warm}`}>
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll grid items-end gap-8 lg:grid-cols-3">
      <div>
        <h2 class="heading-serif text-3xl sm:text-4xl">
          Your next favorite<br />meal awaits
        </h2>
      </div>
      <div></div>
      <div class="flex justify-start lg:justify-end">
        <a href="/menu" class="btn-outline">
          Discover our Menu
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>

    <div class="stagger-children mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {brand.menuCategories.map((cat, i) => (
        <div
          class={`rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1 ${i === 2 ? 'text-white' : ''}`}
          style={i === 2 ? { backgroundColor: brand.colors.accent } : { backgroundColor: '#ffffff' }}
        >
          <div class="mb-4 text-2xl">
            {cat.icon === 'utensils' ? '🍽️' : cat.icon === 'leaf' ? '🥗' : cat.icon === 'plant' ? '🥬' : '🍷'}
          </div>
          <h3 class="text-base font-bold">{cat.title}</h3>
          <p class={`mt-1 text-xs leading-relaxed ${i === 2 ? 'text-white/80' : ''}`} style={i !== 2 ? { color: brand.colors.textLight } : undefined}>
            {cat.subtitle}
          </p>
        </div>
      ))}
    </div>

    <!-- Menu highlights -->
    <div class="animate-on-scroll mt-10 grid grid-cols-2 gap-3 sm:grid-cols-4">
      {brand.menuHighlights.map((item, i) => (
        <p class="text-sm" style={`color: ${brand.colors.textLight}`}>
          <span class="mr-2 font-semibold" style={`color: ${brand.colors.text}`}>{i + 1}.</span>
          {item}
        </p>
      ))}
    </div>
  </div>
</section>
