---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.primary}`}>
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll text-center">
      <span class="badge-pill border-white/20 text-white/80">A Feast <em>for the</em> <strong>Eyes</strong></span>
      <h2 class="heading-italic mt-6 text-3xl text-white sm:text-4xl">
        Taste the vibes through our gallery
      </h2>
    </div>

    <!-- Scrolling gallery -->
    <div class="stagger-children mt-12 flex gap-4 overflow-x-auto pb-4 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
      {brand.galleryImages.map((img, i) => (
        <div class="flex-shrink-0">
          <div class="group relative h-56 w-48 overflow-hidden rounded-xl sm:h-64 sm:w-56">
            <img src={img} alt={`Gallery ${i + 1}`} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
            <div class="absolute inset-0 flex items-end justify-center bg-gradient-to-t from-black/40 to-transparent p-4">
              <p class="heading-italic text-sm text-white">
                {['Fried Rice', 'Burger', 'Rice & Meat', 'Salad & Soup', 'Special Burger', 'Pasta'][i] || 'Dish'}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
