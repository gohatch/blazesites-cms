---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.cream}`}>
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll grid items-start gap-12 lg:grid-cols-3">
      <!-- Left: heading -->
      <div>
        <span class="badge-pill">Customer <strong>Reviews</strong></span>
        <h2 class="heading-serif mt-6 text-3xl leading-tight sm:text-4xl">
          Where every visit becomes a great Memory
        </h2>
      </div>

      <!-- Right: testimonial cards -->
      <div class="stagger-children col-span-2 grid gap-4 sm:grid-cols-3">
        {brand.testimonials.map((t, i) => (
          <div
            class="rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1"
            style={i === 1 ? { backgroundColor: brand.colors.accent, color: '#ffffff' } : { backgroundColor: '#ffffff' }}
          >
            <p class={`text-sm leading-relaxed ${i === 1 ? 'text-white/90' : ''}`} style={i !== 1 ? { color: brand.colors.textLight } : undefined}>
              "{t.quote}"
            </p>
            <div class="mt-5 border-t pt-4" style={`border-color: ${i === 1 ? 'rgba(255,255,255,0.2)' : 'rgba(0,0,0,0.08)'}`}>
              <p class="text-sm font-bold">— {t.author}</p>
              <div class="mt-1 flex items-center justify-between">
                <p class={`text-xs ${i === 1 ? 'text-white/70' : ''}`} style={i !== 1 ? { color: brand.colors.textLight } : undefined}>{t.location}</p>
                <p class="text-xs font-semibold">★ {t.rating}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
