---
import brand from '../../brand.json';
---
<section class="pt-20">
  <div class="mx-auto max-w-7xl px-6">
    <div class="hero-animate hero-animate-1 pt-8 text-center">
      <span class="badge-pill">Made with <strong>Love</strong>, Served with <strong>Joy</strong></span>
      <h1 class="heading-italic mt-8 text-5xl leading-[1.05] sm:text-6xl lg:text-7xl">
        Experience the<br />Language of Taste
      </h1>
    </div>

    <div class="hero-animate hero-animate-2 relative mt-10">
      <a href="/contact" class="circle-btn absolute -top-6 right-8 z-10 sm:right-16">
        <svg class="mb-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
        RESERVE A<br />TABLE
      </a>
      <div class="overflow-hidden rounded-2xl">
        <img src={brand.heroImage} alt={brand.tagline} class="h-[400px] w-full object-cover sm:h-[500px] lg:h-[550px]" />
      </div>
    </div>
  </div>
</section>
