---
const programs = [
  { title: "Barbell Basics", description: "Master the fundamentals of barbell training for a solid strength foundation.", image: "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=600&q=80" },
  { title: "Kettlebell Masterclass", description: "Dynamic kettlebell flows for explosive power and total-body conditioning.", image: "https://images.unsplash.com/photo-1517963879433-6ad2b056d712?w=600&q=80" },
  { title: "Cardio Power Boost", description: "Heart-pumping cardio sessions to elevate your endurance and stamina.", image: "https://images.unsplash.com/photo-1538805060514-97d9cc17730c?w=600&q=80" },
  { title: "Hypertrophy", description: "Volume-based training protocols designed to maximize muscle growth.", image: "https://images.unsplash.com/photo-1581009146145-b5ef050c2e1e?w=600&q=80" },
  { title: "Rope Climbing", description: "Build grip strength, upper body power, and mental toughness.", image: "https://images.unsplash.com/photo-1599058945522-28d584b6f0ff?w=600&q=80" },
  { title: "TRX Suspension", description: "Suspension training for core stability, balance, and lean muscle.", image: "https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=600&q=80" }
];
---

<section id="programs" class="section-padding" style="background-color: #0A0A0A;">
  <div style="max-width: 1280px; margin: 0 auto;">

    <!-- Section Header -->
    <div class="fade-up" style="display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; margin-bottom: 3.5rem; gap: 1.5rem;">
      <div>
        <span style="color: #B5FF00; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em;" class="font-heading">Our Programs</span>
        <h2 class="font-heading" style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #FFFFFF; margin-top: 0.75rem; line-height: 1.15;">
          Train Smarter, Unleash <br /><span style="color: #B5FF00;">Your Potential</span>
        </h2>
      </div>
      <a href="#cta" class="btn-outline" style="padding: 0.75rem 1.75rem; font-size: 0.875rem;">View All Programs</a>
    </div>

    <!-- Programs Grid -->
    <div class="stagger-children programs-grid" style="display: grid; grid-template-columns: repeat(1, 1fr); gap: 1.5rem;">
      {programs.map((program) => (
        <div class="card-hover img-zoom" style="background-color: #141414; border-radius: 16px; overflow: hidden; cursor: pointer; position: relative;">
          <div style="position: relative; aspect-ratio: 4/3; overflow: hidden;">
            <img src={program.image} alt={program.title} style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease;" loading="lazy" />
            <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(10, 10, 10, 0.9) 0%, rgba(10, 10, 10, 0.1) 60%);"></div>
            <!-- Title overlay -->
            <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 1.5rem;">
              <h3 class="font-heading" style="font-size: 1.25rem; font-weight: 600; color: #FFFFFF; margin-bottom: 0.375rem;">{program.title}</h3>
              <p style="font-size: 0.8125rem; color: #9CA3AF; line-height: 1.5;">{program.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @media (min-width: 640px) {
    .programs-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (min-width: 1024px) {
    .programs-grid {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }
</style>
