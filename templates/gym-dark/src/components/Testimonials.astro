---
const testimonials = [
  {
    quote: "FiTusion completely transformed my approach to fitness. The trainers are incredibly knowledgeable and the atmosphere pushes you to give your absolute best every single session.",
    name: "David Harmon",
    role: "Lost 30kg in 8 months",
    image: "https://images.unsplash.com/photo-1568602471122-7832951cc4c5?w=200&q=80"
  },
  {
    quote: "I've tried dozens of gyms over the years, but nothing comes close to the experience at FiTusion. The combination of expert coaching and premium facilities is unmatched.",
    name: "Sarah Mitchell",
    role: "Competitive Athlete",
    image: "https://images.unsplash.com/photo-1594381898411-846e7d193883?w=200&q=80"
  }
];
---

<section id="testimonials" class="section-padding" style="background-color: #0E0E0E; position: relative; overflow: hidden;">
  <!-- Background decoration -->
  <div style="position: absolute; top: -100px; right: -100px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(181, 255, 0, 0.05) 0%, transparent 70%); border-radius: 50%;"></div>
  <div style="position: absolute; bottom: -100px; left: -100px; width: 300px; height: 300px; background: radial-gradient(circle, rgba(181, 255, 0, 0.03) 0%, transparent 70%); border-radius: 50%;"></div>

  <div style="max-width: 1280px; margin: 0 auto; position: relative;">

    <!-- Section Header -->
    <div class="fade-up" style="text-align: center; margin-bottom: 4rem;">
      <span style="color: #B5FF00; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em;" class="font-heading">Testimonials</span>
      <h2 class="font-heading" style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #FFFFFF; margin-top: 0.75rem; line-height: 1.15;">
        Your Success Stories, <span style="color: #B5FF00;">Our Inspiration</span>
      </h2>
    </div>

    <!-- Testimonials Grid -->
    <div class="stagger-children testimonials-grid" style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
      {testimonials.map((testimonial) => (
        <div class="card-hover" style="background-color: #141414; border-radius: 20px; padding: 2.5rem; position: relative;">
          <!-- Green quote mark -->
          <div style="position: absolute; top: 1.5rem; right: 2rem;">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="rgba(181, 255, 0, 0.15)"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          </div>

          <!-- Quote -->
          <p style="font-size: 1.0625rem; color: #D1D5DB; line-height: 1.8; margin-bottom: 2rem; position: relative; z-index: 1;">"{testimonial.quote}"</p>

          <!-- Author -->
          <div style="display: flex; align-items: center; gap: 1rem;">
            <img src={testimonial.image} alt={testimonial.name} style="width: 52px; height: 52px; border-radius: 50%; object-fit: cover; border: 2px solid #B5FF00;" loading="lazy" />
            <div>
              <h4 class="font-heading" style="font-size: 1rem; font-weight: 600; color: #FFFFFF;">{testimonial.name}</h4>
              <p style="font-size: 0.8125rem; color: #B5FF00; font-weight: 500;">{testimonial.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>
