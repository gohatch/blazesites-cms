---
const featuredPrograms = [
  {
    title: "Endurance Evolution",
    description: "A progressive endurance program that systematically builds your cardiovascular capacity through phased training cycles. From base building to peak performance.",
    image: "https://images.unsplash.com/photo-1549060279-7e168fcee0c2?w=600&q=80",
    tag: "Featured"
  },
  {
    title: "Speed Surge",
    description: "Explosive speed and agility training combining plyometrics, sprint drills, and reactive movement patterns. Designed for athletes who demand more.",
    image: "https://images.unsplash.com/photo-1552674605-db6ffd4facb5?w=600&q=80",
    tag: "New"
  }
];
---

<section id="about" class="section-padding" style="background-color: #0E0E0E;">
  <div style="max-width: 1280px; margin: 0 auto;">

    <!-- Section Header -->
    <div class="fade-up" style="text-align: center; margin-bottom: 4rem;">
      <span style="color: #B5FF00; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em;" class="font-heading">About Us</span>
      <h2 class="font-heading" style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #FFFFFF; margin-top: 0.75rem; line-height: 1.15;">
        Experience Fitness <span style="color: #B5FF00;">Like Never Before</span>
      </h2>
      <p style="font-size: 1.0625rem; color: #9CA3AF; max-width: 640px; margin: 1.25rem auto 0; line-height: 1.7;">
        We combine cutting-edge science with passionate coaching to create training experiences that deliver real, lasting results.
      </p>
    </div>

    <!-- Featured Program Cards -->
    <div class="stagger-children about-grid" style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
      {featuredPrograms.map((program) => (
        <div class="card-hover" style="background-color: #141414; border-radius: 20px; overflow: hidden; display: flex; flex-direction: column;">
          <div style="position: relative; overflow: hidden;">
            <img src={program.image} alt={program.title} style="width: 100%; height: 280px; object-fit: cover;" loading="lazy" />
            <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(20, 20, 20, 1) 0%, transparent 60%);"></div>
            <!-- Tag -->
            <div style="position: absolute; top: 1.25rem; left: 1.25rem;">
              <span style="background-color: #B5FF00; color: #0A0A0A; font-size: 0.75rem; font-weight: 700; padding: 0.375rem 0.875rem; border-radius: 9999px; text-transform: uppercase; letter-spacing: 0.05em;" class="font-heading">{program.tag}</span>
            </div>
          </div>
          <div style="padding: 0 2rem 2rem;">
            <h3 class="font-heading" style="font-size: 1.5rem; font-weight: 700; color: #FFFFFF; margin-bottom: 0.75rem;">{program.title}</h3>
            <p style="font-size: 0.9375rem; color: #9CA3AF; line-height: 1.7; margin-bottom: 1.5rem;">{program.description}</p>
            <a href="#programs" style="display: inline-flex; align-items: center; gap: 0.5rem; color: #B5FF00; font-weight: 600; font-size: 0.9375rem; text-decoration: none; transition: gap 0.3s;" class="font-heading" onmouseover="this.style.gap='0.75rem'" onmouseout="this.style.gap='0.5rem'">
              Learn More
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Stats Row -->
    <div class="fade-up" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 4rem;">
      <div style="text-align: center; padding: 2rem; background-color: #141414; border-radius: 16px; border: 1px solid #222222;">
        <div class="font-heading counter" data-target="12000" data-suffix="+" style="font-size: 2.5rem; font-weight: 700; color: #B5FF00;">0</div>
        <div style="font-size: 0.875rem; color: #9CA3AF; margin-top: 0.375rem;">Happy Clients</div>
      </div>
      <div style="text-align: center; padding: 2rem; background-color: #141414; border-radius: 16px; border: 1px solid #222222;">
        <div class="font-heading counter" data-target="50" data-suffix="+" style="font-size: 2.5rem; font-weight: 700; color: #B5FF00;">0</div>
        <div style="font-size: 0.875rem; color: #9CA3AF; margin-top: 0.375rem;">Expert Trainers</div>
      </div>
      <div style="text-align: center; padding: 2rem; background-color: #141414; border-radius: 16px; border: 1px solid #222222;">
        <div class="font-heading counter" data-target="98" data-suffix="%" style="font-size: 2.5rem; font-weight: 700; color: #B5FF00;">0</div>
        <div style="font-size: 0.875rem; color: #9CA3AF; margin-top: 0.375rem;">Success Rate</div>
      </div>
      <div style="text-align: center; padding: 2rem; background-color: #141414; border-radius: 16px; border: 1px solid #222222;">
        <div class="font-heading counter" data-target="15" data-suffix="+" style="font-size: 2.5rem; font-weight: 700; color: #B5FF00;">0</div>
        <div style="font-size: 0.875rem; color: #9CA3AF; margin-top: 0.375rem;">Years Experience</div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .about-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (min-width: 768px) {
    .fade-up[style*="grid-template-columns: repeat(2"] {
      grid-template-columns: repeat(4, 1fr) !important;
    }
  }
</style>
