---
---

<footer style="background-color: #060606; border-top: 1px solid #1A1A1A;">
  <div style="max-width: 1280px; margin: 0 auto; padding: 4rem 1.5rem 2rem;">

    <!-- Top section -->
    <div class="footer-grid" style="display: grid; grid-template-columns: 1fr; gap: 3rem; margin-bottom: 3rem;">

      <!-- Brand -->
      <div>
        <a href="#home" style="text-decoration: none; display: inline-block; margin-bottom: 1.25rem;">
          <span class="font-heading" style="font-size: 1.625rem; font-weight: 700; color: #FFFFFF;">Fi<span style="color: #B5FF00;">Tusion</span></span>
        </a>
        <p style="font-size: 0.9375rem; color: #9CA3AF; line-height: 1.7; max-width: 320px;">
          Premium fitness center delivering world-class training, expert coaching, and a community that pushes you to your peak performance.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-heading" style="font-size: 1rem; font-weight: 600; color: #FFFFFF; margin-bottom: 1.25rem;">Quick Links</h4>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          <a href="#home" style="color: #9CA3AF; text-decoration: none; font-size: 0.9375rem; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#9CA3AF'">Home</a>
          <a href="#programs" style="color: #9CA3AF; text-decoration: none; font-size: 0.9375rem; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#9CA3AF'">Programs</a>
          <a href="#trainers" style="color: #9CA3AF; text-decoration: none; font-size: 0.9375rem; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#9CA3AF'">Trainers</a>
          <a href="#pricing" style="color: #9CA3AF; text-decoration: none; font-size: 0.9375rem; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#9CA3AF'">Pricing</a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-heading" style="font-size: 1rem; font-weight: 600; color: #FFFFFF; margin-bottom: 1.25rem;">Contact Us</h4>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          <a href="tel:+18005553488" style="color: #9CA3AF; text-decoration: none; font-size: 0.9375rem; display: flex; align-items: center; gap: 0.5rem; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#9CA3AF'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            +1 (800) 555-FITU
          </a>
          <a href="mailto:hello@fitusion.com" style="color: #9CA3AF; text-decoration: none; font-size: 0.9375rem; display: flex; align-items: center; gap: 0.5rem; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#9CA3AF'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            hello@fitusion.com
          </a>
          <span style="color: #9CA3AF; font-size: 0.9375rem; display: flex; align-items: center; gap: 0.5rem;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            456 Iron Avenue, Los Angeles, CA
          </span>
        </div>
      </div>

      <!-- Follow Us -->
      <div>
        <h4 class="font-heading" style="font-size: 1rem; font-weight: 600; color: #FFFFFF; margin-bottom: 1.25rem;">Follow Us On</h4>
        <div style="display: flex; gap: 0.75rem;">
          <a href="#" style="width: 40px; height: 40px; background-color: #141414; border: 1px solid #222; border-radius: 10px; display: flex; align-items: center; justify-content: center; transition: all 0.3s; text-decoration: none;" onmouseover="this.style.borderColor='#B5FF00';this.style.backgroundColor='rgba(181,255,0,0.1)'" onmouseout="this.style.borderColor='#222';this.style.backgroundColor='#141414'" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="#" style="width: 40px; height: 40px; background-color: #141414; border: 1px solid #222; border-radius: 10px; display: flex; align-items: center; justify-content: center; transition: all 0.3s; text-decoration: none;" onmouseover="this.style.borderColor='#B5FF00';this.style.backgroundColor='rgba(181,255,0,0.1)'" onmouseout="this.style.borderColor='#222';this.style.backgroundColor='#141414'" aria-label="Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" style="width: 40px; height: 40px; background-color: #141414; border: 1px solid #222; border-radius: 10px; display: flex; align-items: center; justify-content: center; transition: all 0.3s; text-decoration: none;" onmouseover="this.style.borderColor='#B5FF00';this.style.backgroundColor='rgba(181,255,0,0.1)'" onmouseout="this.style.borderColor='#222';this.style.backgroundColor='#141414'" aria-label="Twitter / X">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" style="width: 40px; height: 40px; background-color: #141414; border: 1px solid #222; border-radius: 10px; display: flex; align-items: center; justify-content: center; transition: all 0.3s; text-decoration: none;" onmouseover="this.style.borderColor='#B5FF00';this.style.backgroundColor='rgba(181,255,0,0.1)'" onmouseout="this.style.borderColor='#222';this.style.backgroundColor='#141414'" aria-label="YouTube">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top: 1px solid #1A1A1A; padding-top: 2rem; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1rem;">
      <p style="font-size: 0.8125rem; color: #555;">
        &copy; 2024 FiTusion. All rights reserved.
      </p>
      <div style="display: flex; gap: 1.5rem;">
        <a href="#" style="font-size: 0.8125rem; color: #555; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#555'">Privacy Policy</a>
        <a href="#" style="font-size: 0.8125rem; color: #555; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#555'">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr !important;
    }
  }
</style>
