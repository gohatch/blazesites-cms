---
---

<section id="cta" class="section-padding" style="background-color: #0A0A0A; position: relative; overflow: hidden;">
  <div style="max-width: 1280px; margin: 0 auto; position: relative;">

    <div class="fade-up" style="background: linear-gradient(135deg, #141414 0%, #1A1A1A 100%); border-radius: 24px; padding: 4rem 2rem; text-align: center; border: 1px solid #222222; position: relative; overflow: hidden;">
      <!-- Glow accent -->
      <div style="position: absolute; top: -2px; left: 50%; transform: translateX(-50%); width: 200px; height: 4px; background: linear-gradient(90deg, transparent, #B5FF00, transparent); border-radius: 2px;"></div>
      <div style="position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 400px; height: 100px; background: radial-gradient(ellipse, rgba(181, 255, 0, 0.08) 0%, transparent 70%);"></div>

      <div style="position: relative; z-index: 1;">
        <span style="color: #B5FF00; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em;" class="font-heading">Join The Movement</span>

        <h2 class="font-heading" style="font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 700; color: #FFFFFF; margin-top: 1rem; line-height: 1.15;">
          Connect. Engage. <span style="color: #B5FF00;">Transform.</span>
        </h2>

        <p style="font-size: 1.0625rem; color: #9CA3AF; max-width: 520px; margin: 1.25rem auto 2.5rem; line-height: 1.7;">
          Join our community and get exclusive access to workout tips, nutrition guides, and special member offers.
        </p>

        <!-- Email Input -->
        <div style="display: flex; flex-direction: column; gap: 1rem; max-width: 480px; margin: 0 auto;">
          <div class="cta-form" style="display: flex; gap: 0.75rem; flex-direction: column;">
            <input
              type="email"
              placeholder="Enter your email address"
              style="flex: 1; padding: 1rem 1.25rem; background-color: #0A0A0A; border: 1px solid #333; border-radius: 10px; color: #FFFFFF; font-size: 0.9375rem; outline: none; transition: border-color 0.3s; font-family: 'Inter', sans-serif;"
              onfocus="this.style.borderColor='#B5FF00'"
              onblur="this.style.borderColor='#333'"
            />
            <button class="btn-primary" style="white-space: nowrap; padding: 1rem 2rem; border-radius: 10px;">
              Join Now
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>
          <p style="font-size: 0.75rem; color: #666;">No spam. Unsubscribe anytime. We respect your privacy.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 640px) {
    .cta-form {
      flex-direction: row !important;
    }
  }
</style>
