---
const categories = [
  {
    title: "Cardio Training",
    description: "High-intensity cardiovascular workouts designed to boost endurance and torch calories.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#B5FF00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>`
  },
  {
    title: "Strength Build",
    description: "Progressive overload programs to build raw power, muscle mass, and functional strength.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#B5FF00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6.5 6.5h11"/><path d="M6.5 17.5h11"/><rect x="2" y="4.5" width="4" height="4" rx="1"/><rect x="18" y="4.5" width="4" height="4" rx="1"/><rect x="2" y="15.5" width="4" height="4" rx="1"/><rect x="18" y="15.5" width="4" height="4" rx="1"/><path d="M12 4.5v15"/></svg>`
  },
  {
    title: "Fat Loss",
    description: "Targeted fat-burning routines combining LISS and HIIT for maximum metabolic impact.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#B5FF00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`
  },
  {
    title: "HIIT Workouts",
    description: "Explosive interval training sessions that maximize results in minimal time.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#B5FF00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>`
  }
];
---

<section id="categories" class="section-padding" style="background-color: #0E0E0E;">
  <div style="max-width: 1280px; margin: 0 auto;">

    <!-- Section Header -->
    <div class="fade-up" style="text-align: center; margin-bottom: 4rem;">
      <span style="color: #B5FF00; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em;" class="font-heading">Our Specialties</span>
      <h2 class="font-heading" style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #FFFFFF; margin-top: 0.75rem; line-height: 1.15;">
        Discover What <span style="color: #B5FF00;">Sets Us Apart</span>
      </h2>
    </div>

    <!-- Categories Grid -->
    <div class="stagger-children" style="display: grid; grid-template-columns: repeat(1, 1fr); gap: 1.5rem;">
      {categories.map((cat) => (
        <div class="card-hover" style="background-color: #141414; border-radius: 16px; padding: 2.25rem; text-align: center; cursor: pointer; position: relative; overflow: hidden;">
          <!-- Subtle top accent line -->
          <div style="position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 0; height: 3px; background-color: #B5FF00; transition: width 0.4s ease; border-radius: 0 0 4px 4px;" class="accent-top"></div>

          <div style="width: 64px; height: 64px; background-color: rgba(181, 255, 0, 0.08); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem;">
            <Fragment set:html={cat.icon} />
          </div>
          <h3 class="font-heading" style="font-size: 1.25rem; font-weight: 600; color: #FFFFFF; margin-bottom: 0.75rem;">{cat.title}</h3>
          <p style="font-size: 0.9375rem; color: #9CA3AF; line-height: 1.6;">{cat.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @media (min-width: 640px) {
    .stagger-children {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (min-width: 1024px) {
    .stagger-children {
      grid-template-columns: repeat(4, 1fr) !important;
    }
  }
  .card-hover:hover .accent-top {
    width: 60% !important;
  }
</style>
