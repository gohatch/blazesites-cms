---
---

<header id="main-header" style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; transition: all 0.3s ease; background-color: transparent;">
  <div style="max-width: 1280px; margin: 0 auto; padding: 1.25rem 1.5rem; display: flex; align-items: center; justify-content: space-between;">

    <!-- Logo -->
    <a href="#home" style="text-decoration: none; display: flex; align-items: center; gap: 0.25rem;">
      <span class="font-heading" style="font-size: 1.625rem; font-weight: 700; color: #FFFFFF;">Fi<span style="color: #B5FF00;">Tusion</span></span>
    </a>

    <!-- Desktop Nav -->
    <nav style="display: none; align-items: center; gap: 2rem;" class="desktop-nav">
      <a href="#home" style="color: #FFFFFF; text-decoration: none; font-size: 0.9375rem; font-weight: 400; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#FFFFFF'">Home</a>
      <a href="#programs" style="color: #0A0A0A; text-decoration: none; font-size: 0.875rem; font-weight: 600; background-color: #B5FF00; padding: 0.375rem 1.125rem; border-radius: 9999px; transition: all 0.3s;" onmouseover="this.style.boxShadow='0 0 20px rgba(181,255,0,0.3)'" onmouseout="this.style.boxShadow='none'">Programs</a>
      <a href="#trainers" style="color: #FFFFFF; text-decoration: none; font-size: 0.9375rem; font-weight: 400; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#FFFFFF'">Trainers</a>
      <a href="#pricing" style="color: #FFFFFF; text-decoration: none; font-size: 0.9375rem; font-weight: 400; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#FFFFFF'">Pricing</a>
    </nav>

    <!-- Desktop CTA -->
    <div style="display: none;" class="desktop-nav">
      <a href="#cta" class="btn-outline" style="padding: 0.625rem 1.5rem; font-size: 0.875rem;">Get Started</a>
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" style="display: flex; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 0.5rem;" class="mobile-menu-btn" aria-label="Toggle menu">
      <span style="width: 24px; height: 2px; background-color: #FFFFFF; border-radius: 2px; transition: all 0.3s;"></span>
      <span style="width: 24px; height: 2px; background-color: #FFFFFF; border-radius: 2px; transition: all 0.3s;"></span>
      <span style="width: 18px; height: 2px; background-color: #B5FF00; border-radius: 2px; transition: all 0.3s;"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden" style="background-color: rgba(10, 10, 10, 0.98); backdrop-filter: blur(20px); border-top: 1px solid #222222;">
    <div style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
      <a href="#home" style="color: #FFFFFF; text-decoration: none; font-size: 1.0625rem; font-weight: 500; padding: 0.75rem 0; border-bottom: 1px solid #222222;">Home</a>
      <a href="#programs" style="color: #B5FF00; text-decoration: none; font-size: 1.0625rem; font-weight: 600; padding: 0.75rem 0; border-bottom: 1px solid #222222;">Programs</a>
      <a href="#trainers" style="color: #FFFFFF; text-decoration: none; font-size: 1.0625rem; font-weight: 500; padding: 0.75rem 0; border-bottom: 1px solid #222222;">Trainers</a>
      <a href="#pricing" style="color: #FFFFFF; text-decoration: none; font-size: 1.0625rem; font-weight: 500; padding: 0.75rem 0; border-bottom: 1px solid #222222;">Pricing</a>
      <a href="#cta" class="btn-primary" style="text-align: center; margin-top: 0.5rem;">Get Started</a>
    </div>
  </div>
</header>

<style>
  @media (min-width: 768px) {
    .desktop-nav {
      display: flex !important;
    }
    .mobile-menu-btn {
      display: none !important;
    }
  }
</style>
