---
const trainers = [
  {
    name: "Marcus Stone",
    specialty: "Strength & Conditioning",
    image: "https://images.unsplash.com/photo-1567013127542-490d757e51fc?w=400&q=80",
    bio: "15+ years transforming athletes with proven strength programming."
  },
  {
    name: "Alexa Rivera",
    specialty: "HIIT & Cardio Specialist",
    image: "https://images.unsplash.com/photo-1548690312-e3b507d8c110?w=400&q=80",
    bio: "Former competitive runner turned elite cardio and interval coach."
  },
  {
    name: "James Chen",
    specialty: "Nutrition & Wellness Coach",
    image: "https://images.unsplash.com/photo-1583468982228-19f19164aee2?w=400&q=80",
    bio: "Certified nutritionist helping clients fuel performance and recovery."
  }
];
---

<section id="trainers" class="section-padding" style="background-color: #0A0A0A;">
  <div style="max-width: 1280px; margin: 0 auto;">

    <!-- Section Header -->
    <div class="fade-up" style="text-align: center; margin-bottom: 4rem;">
      <span style="color: #B5FF00; font-size: 0.8125rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em;" class="font-heading">Meet The Team</span>
      <h2 class="font-heading" style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; color: #FFFFFF; margin-top: 0.75rem; line-height: 1.15;">
        Your Fitness Goals, <span style="color: #B5FF00;">Their Expertise</span>
      </h2>
    </div>

    <!-- Trainers Grid -->
    <div class="stagger-children team-grid" style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
      {trainers.map((trainer) => (
        <div class="card-hover" style="background-color: #141414; border-radius: 20px; overflow: hidden; text-align: center;">
          <div style="position: relative; overflow: hidden;">
            <img src={trainer.image} alt={trainer.name} style="width: 100%; height: 340px; object-fit: cover; object-position: top; transition: transform 0.6s ease;" loading="lazy" />
            <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(20, 20, 20, 1) 0%, transparent 50%);"></div>
          </div>
          <div style="padding: 0 1.75rem 2rem; margin-top: -2rem; position: relative;">
            <h3 class="font-heading" style="font-size: 1.375rem; font-weight: 700; color: #B5FF00; margin-bottom: 0.25rem;">{trainer.name}</h3>
            <p style="font-size: 0.875rem; color: #FFFFFF; font-weight: 500; margin-bottom: 0.75rem;">{trainer.specialty}</p>
            <p style="font-size: 0.8125rem; color: #9CA3AF; line-height: 1.6;">{trainer.bio}</p>

            <!-- Social icons -->
            <div style="display: flex; justify-content: center; gap: 0.75rem; margin-top: 1.25rem;">
              <a href="#" style="width: 36px; height: 36px; background-color: #1A1A1A; border: 1px solid #333; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.3s; text-decoration: none;" onmouseover="this.style.borderColor='#B5FF00';this.style.backgroundColor='rgba(181,255,0,0.1)'" onmouseout="this.style.borderColor='#333';this.style.backgroundColor='#1A1A1A'" aria-label="Instagram">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
              <a href="#" style="width: 36px; height: 36px; background-color: #1A1A1A; border: 1px solid #333; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.3s; text-decoration: none;" onmouseover="this.style.borderColor='#B5FF00';this.style.backgroundColor='rgba(181,255,0,0.1)'" onmouseout="this.style.borderColor='#333';this.style.backgroundColor='#1A1A1A'" aria-label="Twitter">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#9CA3AF"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(3, 1fr) !important;
    }
  }
</style>
