---
---

<section id="home" style="position: relative; min-height: 100vh; display: flex; align-items: center; background-color: #0A0A0A; overflow: hidden;">
  <!-- Background Image -->
  <div style="position: absolute; inset: 0;">
    <img
      src="https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?w=1920&q=80"
      alt="Athletic fitness training"
      style="width: 100%; height: 100%; object-fit: cover; opacity: 0.35;"
    />
    <div style="position: absolute; inset: 0; background: linear-gradient(135deg, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.6) 50%, rgba(10,10,10,0.8) 100%);"></div>
  </div>

  <!-- Content -->
  <div style="position: relative; z-index: 10; max-width: 1280px; margin: 0 auto; padding: 8rem 1.5rem 4rem; width: 100%;">
    <div style="max-width: 720px;">

      <!-- Badge -->
      <div class="fade-up" style="display: inline-flex; align-items: center; gap: 0.5rem; background-color: rgba(181, 255, 0, 0.1); border: 1px solid rgba(181, 255, 0, 0.3); border-radius: 9999px; padding: 0.5rem 1.125rem; margin-bottom: 2rem;">
        <span style="width: 8px; height: 8px; background-color: #B5FF00; border-radius: 50; display: inline-block;"></span>
        <span style="color: #B5FF00; font-size: 0.875rem; font-weight: 600;" class="font-heading">12K+ Happy Clients</span>
      </div>

      <!-- Heading -->
      <h1 class="font-heading fade-up" style="font-size: clamp(2.75rem, 6vw, 4.5rem); font-weight: 700; line-height: 1.05; color: #FFFFFF; margin-bottom: 1.5rem;">
        Sculpt Your <span style="color: #B5FF00; text-shadow: 0 0 40px rgba(181, 255, 0, 0.3);">Body</span>, Elevate Your <span style="color: #B5FF00; text-shadow: 0 0 40px rgba(181, 255, 0, 0.3);">Spirit</span>
      </h1>

      <!-- Subtext -->
      <p class="fade-up" style="font-size: 1.0625rem; color: #9CA3AF; line-height: 1.8; margin-bottom: 2.5rem; max-width: 540px;">
        Transform your physique with cutting-edge training programs, expert coaches, and a community that pushes your limits.
      </p>

      <!-- CTA Buttons -->
      <div class="fade-up" style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;">
        <a href="#programs" class="btn-primary" style="font-size: 1rem; padding: 1rem 2.5rem;">
          Let's Start
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href="#about" class="btn-outline" style="font-size: 1rem; padding: 1rem 2.5rem;">Learn More</a>
      </div>
    </div>

    <!-- PREV / NEXT nav arrows -->
    <div class="fade-up" style="display: flex; gap: 0.75rem; margin-top: 3rem;">
      <button style="width: 48px; height: 48px; border: 1px solid #333; border-radius: 50%; background: transparent; color: #FFFFFF; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s;" onmouseover="this.style.borderColor='#B5FF00';this.style.color='#B5FF00'" onmouseout="this.style.borderColor='#333';this.style.color='#FFFFFF'" aria-label="Previous">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button style="width: 48px; height: 48px; border: 1px solid #333; border-radius: 50%; background: transparent; color: #FFFFFF; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s;" onmouseover="this.style.borderColor='#B5FF00';this.style.color='#B5FF00'" onmouseout="this.style.borderColor='#333';this.style.color='#FFFFFF'" aria-label="Next">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </div>

  <!-- Brand Logos Strip -->
  <div style="position: absolute; bottom: 0; left: 0; right: 0; border-top: 1px solid #222222; background-color: rgba(10, 10, 10, 0.8); backdrop-filter: blur(10px);">
    <div style="max-width: 1280px; margin: 0 auto; padding: 1.25rem 1.5rem; display: flex; align-items: center; justify-content: center; gap: 3rem; flex-wrap: wrap;">
      <span style="color: #555; font-size: 0.8125rem; font-weight: 500; text-transform: uppercase; letter-spacing: 0.1em;">Trusted by</span>
      <div style="display: flex; align-items: center; gap: 2.5rem; flex-wrap: wrap; justify-content: center;">
        <span class="font-heading" style="color: #555; font-size: 1.125rem; font-weight: 700; letter-spacing: 0.05em; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#555'">NIKE</span>
        <span class="font-heading" style="color: #555; font-size: 1.125rem; font-weight: 700; letter-spacing: 0.05em; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#555'">UNDER ARMOUR</span>
        <span class="font-heading" style="color: #555; font-size: 1.125rem; font-weight: 700; letter-spacing: 0.05em; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#555'">PUMA</span>
        <span class="font-heading" style="color: #555; font-size: 1.125rem; font-weight: 700; letter-spacing: 0.05em; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#555'">REEBOK</span>
        <span class="font-heading" style="color: #555; font-size: 1.125rem; font-weight: 700; letter-spacing: 0.05em; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#555'">ADIDAS</span>
        <span class="font-heading" style="color: #555; font-size: 1.125rem; font-weight: 700; letter-spacing: 0.05em; transition: color 0.3s;" onmouseover="this.style.color='#B5FF00'" onmouseout="this.style.color='#555'">NEW BALANCE</span>
      </div>
    </div>
  </div>
</section>
