---
import brand from '../../brand.json';
---
<section id="home" class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src={brand.heroImage}
      alt="Luxury modern home"
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0" style={`background: linear-gradient(135deg, ${brand.colors.primary}ee 0%, ${brand.colors.primary}99 50%, ${brand.colors.primary}66 100%);`}></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-7xl px-6 py-32 text-center md:py-40">
    <div class="hero-animate hero-animate-1 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm text-white/90 backdrop-blur-sm mb-8">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" /></svg>
      Trusted by 250+ Happy Clients
    </div>

    <h1 class="hero-animate hero-animate-2 mx-auto max-w-4xl text-4xl font-extrabold leading-tight text-white md:text-6xl lg:text-7xl">
      {brand.tagline}
    </h1>

    <p class="hero-animate hero-animate-2 mx-auto mt-6 max-w-2xl text-lg text-white/75 md:text-xl">
      Discover exceptional properties and expert guidance to help you find the perfect place to call home.
    </p>

    <div class="hero-animate hero-animate-3 mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <a href="#properties" class="btn-primary text-base px-8 py-4" style={`background-color: ${brand.colors.accent}`}>
        Explore Properties
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
      <a href="#about" class="btn-outline text-base px-8 py-4">
        Learn More
      </a>
    </div>

    <!-- Stats overlay cards -->
    <div class="hero-animate hero-animate-3 mt-16 grid grid-cols-2 gap-4 sm:grid-cols-4 md:gap-6">
      {brand.stats.map(stat => (
        <div class="rounded-2xl border border-white/10 bg-white/10 p-4 backdrop-blur-sm md:p-6">
          <div class="text-2xl font-extrabold text-white md:text-3xl">{stat.value}</div>
          <div class="mt-1 text-xs text-white/60 md:text-sm">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
