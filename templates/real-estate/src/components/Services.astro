---
import brand from '../../brand.json';

const serviceCards = [
  {
    title: "Rent a Home",
    description: "Find the perfect rental property that fits your lifestyle and budget with our extensive listing database.",
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" /></svg>`
  },
  {
    title: "Buy a Home",
    description: "Expert guidance through every step of the home buying process, from search to closing day.",
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>`
  },
  {
    title: "Sell a Property",
    description: "Maximize your property's value with our marketing expertise and extensive network of qualified buyers.",
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" /></svg>`
  }
];
---
<section id="services" class="section-padding" style={`background-color: ${brand.colors.light}`}>
  <div class="mx-auto max-w-7xl">
    <!-- Heading -->
    <div class="animate-on-scroll text-center mb-14">
      <span class="inline-block rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-wider" style={`background-color: ${brand.colors.accent}15; color: ${brand.colors.accent}`}>
        What We Do
      </span>
      <h2 class="mt-4 text-3xl font-extrabold md:text-4xl lg:text-5xl" style={`color: ${brand.colors.primary}`}>
        Buy, Rent & Sell
      </h2>
      <p class="mt-4 mx-auto max-w-2xl text-base md:text-lg" style={`color: ${brand.colors.textLight}`}>
        Whether you're looking to buy your dream home, find the perfect rental, or sell your property at the best price, we've got you covered.
      </p>
    </div>

    <!-- Service cards -->
    <div class="stagger-children grid gap-8 md:grid-cols-3">
      {serviceCards.map(service => (
        <div class="card-hover group rounded-2xl bg-white p-8 shadow-sm border border-gray-100 text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl transition-colors" style={`background-color: ${brand.colors.accent}15; color: ${brand.colors.accent}`}>
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="mt-6 text-xl font-bold" style={`color: ${brand.colors.primary}`}>{service.title}</h3>
          <p class="mt-3 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>{service.description}</p>
          <a href="#contact" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold transition-colors" style={`color: ${brand.colors.accent}`}>
            Learn More
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
