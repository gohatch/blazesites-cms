---
import brand from '../../brand.json';
---
<section id="testimonials" class="section-padding">
  <div class="mx-auto max-w-7xl">
    <!-- Heading -->
    <div class="animate-on-scroll text-center mb-14">
      <span class="inline-block rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-wider" style={`background-color: ${brand.colors.accent}15; color: ${brand.colors.accent}`}>
        Testimonials
      </span>
      <h2 class="mt-4 text-3xl font-extrabold md:text-4xl lg:text-5xl" style={`color: ${brand.colors.primary}`}>
        Hear From Our Clients
      </h2>
      <p class="mt-4 mx-auto max-w-2xl text-base md:text-lg" style={`color: ${brand.colors.textLight}`}>
        Discover what our satisfied clients have to say about their experience working with us.
      </p>
    </div>

    <!-- Testimonial cards -->
    <div class="stagger-children grid gap-8 md:grid-cols-3">
      {brand.testimonials.map(testimonial => (
        <div class="card-hover rounded-2xl bg-white p-8 shadow-sm border border-gray-100">
          <!-- Stars -->
          <div class="flex gap-1 mb-4" style={`color: ${brand.colors.accent}`}>
            {[1,2,3,4,5].map(() => (
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-base leading-relaxed" style={`color: ${brand.colors.text}`}>
            "{testimonial.quote}"
          </p>

          <!-- Author -->
          <div class="mt-6 flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold text-white" style={`background-color: ${brand.colors.accent}`}>
              {testimonial.name.charAt(0)}
            </div>
            <div>
              <div class="text-sm font-semibold" style={`color: ${brand.colors.primary}`}>{testimonial.name}</div>
              <div class="text-xs" style={`color: ${brand.colors.textLight}`}>{testimonial.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
