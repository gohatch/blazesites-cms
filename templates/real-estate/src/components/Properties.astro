---
import brand from '../../brand.json';
---
<section id="properties" class="section-padding">
  <div class="mx-auto max-w-7xl">
    <!-- Heading -->
    <div class="animate-on-scroll text-center mb-14">
      <span class="inline-block rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-wider" style={`background-color: ${brand.colors.accent}15; color: ${brand.colors.accent}`}>
        Our Listings
      </span>
      <h2 class="mt-4 text-3xl font-extrabold md:text-4xl lg:text-5xl" style={`color: ${brand.colors.primary}`}>
        Explore All Properties
      </h2>
      <p class="mt-4 mx-auto max-w-2xl text-base md:text-lg" style={`color: ${brand.colors.textLight}`}>
        Browse our curated selection of premium properties in the most sought-after locations.
      </p>
    </div>

    <!-- Property grid -->
    <div class="stagger-children grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {brand.properties.map((property, i) => (
        <div class="property-card card-hover group overflow-hidden rounded-2xl bg-white shadow-sm border border-gray-100">
          <div class="relative h-64 overflow-hidden">
            <img
              src={brand.propertyImages[i]}
              alt={property.title}
              class="h-full w-full object-cover"
            />
            <!-- Price badge -->
            <div class="absolute top-4 left-4 rounded-full px-4 py-1.5 text-sm font-bold text-white" style={`background-color: ${brand.colors.accent}`}>
              {property.price}
            </div>
            <!-- Overlay on hover -->
            <div class="absolute inset-0 flex items-center justify-center bg-black/0 transition-all duration-300 group-hover:bg-black/20">
              <span class="translate-y-4 rounded-full bg-white px-6 py-2 text-sm font-semibold opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100" style={`color: ${brand.colors.primary}`}>
                View Details
              </span>
            </div>
          </div>
          <div class="p-5">
            <h3 class="text-lg font-bold" style={`color: ${brand.colors.primary}`}>{property.title}</h3>
            <p class="mt-1 flex items-center gap-1 text-sm" style={`color: ${brand.colors.textLight}`}>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              {property.location}
            </p>
            <div class="mt-4 flex items-center gap-4 border-t border-gray-100 pt-4 text-sm" style={`color: ${brand.colors.textLight}`}>
              <span class="flex items-center gap-1">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7h18M3 12h18m-9 5h9" /></svg>
                {property.beds} Beds
              </span>
              <span class="flex items-center gap-1">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4" /></svg>
                {property.baths} Baths
              </span>
              <span class="flex items-center gap-1">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" /></svg>
                {property.sqft} sqft
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- View all button -->
    <div class="animate-on-scroll mt-12 text-center">
      <a href="#" class="btn-primary px-8 py-4" style={`background-color: ${brand.colors.accent}`}>
        View All Properties
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </div>
</section>
