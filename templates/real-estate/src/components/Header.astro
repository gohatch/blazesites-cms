---
import brand from '../../brand.json';
---
<header class="fixed top-0 left-0 right-0 z-50 border-b border-black/5 backdrop-blur-md" style="background-color: rgba(255,255,255,0.95);">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="#home" class="text-xl font-extrabold tracking-tight" style={`color: ${brand.colors.primary}`}>
      {brand.businessName}<span style={`color: ${brand.colors.accent}`}>.</span>
    </a>
    <nav class="hidden items-center gap-8 md:flex">
      {brand.nav.map(link => (
        <a href={link.href} class="text-sm font-medium transition-colors hover:opacity-70" style={`color: ${brand.colors.text}`}>
          {link.label}
        </a>
      ))}
    </nav>
    <div class="hidden md:flex items-center gap-4">
      <a href="#contact" class="btn-primary text-sm" style={`background-color: ${brand.colors.accent}`}>Get Started</a>
    </div>
    <button class="md:hidden" id="mobile-menu-btn" aria-label="Menu">
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <div class="hidden border-t border-black/5 md:hidden" id="mobile-menu" style="background-color: #ffffff;">
    <div class="flex flex-col gap-1 px-6 py-4">
      {brand.nav.map(link => (
        <a href={link.href} class="rounded-lg px-4 py-3 text-sm font-medium hover:bg-gray-50">{link.label}</a>
      ))}
      <a href="#contact" class="btn-primary text-sm text-center mt-2" style={`background-color: ${brand.colors.accent}`}>Get Started</a>
    </div>
  </div>
</header>
<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  btn.addEventListener('click', () => menu.classList.toggle('hidden'));
</script>
