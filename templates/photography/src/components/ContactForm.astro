---
import brand from '../../brand.json';
---
<section id="contact" class="section-padding" style={`background:${brand.colors.white}`}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 animate-on-scroll">
      <div class="section-label">Say Hello</div>
      <h2 class="font-display text-4xl sm:text-5xl font-medium" style={`color:${brand.colors.text}`}>Get in Touch</h2>
      <p class="text-sm font-light mt-3 max-w-md mx-auto" style={`color:${brand.colors.textMuted}`}>{brand.contact.subheading}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 animate-on-scroll">
      <!-- Form -->
      <form class="space-y-5">
        <div class="grid grid-cols-2 gap-4">
          <input type="text" placeholder="First Name" class="w-full px-4 py-3 text-sm font-light outline-none transition-colors" style={`background:${brand.colors.bgLight}; border:1px solid ${brand.colors.border}; color:${brand.colors.text}`} />
          <input type="text" placeholder="Last Name" class="w-full px-4 py-3 text-sm font-light outline-none transition-colors" style={`background:${brand.colors.bgLight}; border:1px solid ${brand.colors.border}; color:${brand.colors.text}`} />
        </div>
        <input type="email" placeholder="Email" class="w-full px-4 py-3 text-sm font-light outline-none" style={`background:${brand.colors.bgLight}; border:1px solid ${brand.colors.border}; color:${brand.colors.text}`} />
        <input type="text" placeholder="Wedding Date" class="w-full px-4 py-3 text-sm font-light outline-none" style={`background:${brand.colors.bgLight}; border:1px solid ${brand.colors.border}; color:${brand.colors.text}`} />
        <textarea rows={4} placeholder="Tell us about your day..." class="w-full px-4 py-3 text-sm font-light outline-none resize-none" style={`background:${brand.colors.bgLight}; border:1px solid ${brand.colors.border}; color:${brand.colors.text}`}></textarea>
        <button type="submit" class="btn-primary w-full">Send Inquiry</button>
      </form>

      <!-- Info -->
      <div class="space-y-8">
        <div>
          <p class="text-[10px] tracking-[0.2em] uppercase mb-2" style={`color:${brand.colors.textMuted}`}>Studio</p>
          <p class="text-sm font-light" style={`color:${brand.colors.text}`}>{brand.address}</p>
        </div>
        <div>
          <p class="text-[10px] tracking-[0.2em] uppercase mb-2" style={`color:${brand.colors.textMuted}`}>Email</p>
          <p class="text-sm font-light" style={`color:${brand.colors.text}`}>{brand.email}</p>
        </div>
        <div>
          <p class="text-[10px] tracking-[0.2em] uppercase mb-2" style={`color:${brand.colors.textMuted}`}>Phone</p>
          <p class="text-sm font-light" style={`color:${brand.colors.text}`}>{brand.phone}</p>
        </div>
        <div>
          <p class="text-[10px] tracking-[0.2em] uppercase mb-2" style={`color:${brand.colors.textMuted}`}>Instagram</p>
          <p class="font-serif italic text-lg" style={`color:${brand.colors.accent}`}>{brand.instagram}</p>
        </div>
        <div>
          <p class="text-[10px] tracking-[0.2em] uppercase mb-3" style={`color:${brand.colors.textMuted}`}>Hours</p>
          {brand.contact.hours.map((h: any) => (
            <div class="flex justify-between text-sm font-light py-1" style={`color:${brand.colors.textMuted}; border-bottom:1px solid ${brand.colors.border}`}>
              <span>{h.days}</span>
              <span style={`color:${brand.colors.text}`}>{h.time}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
