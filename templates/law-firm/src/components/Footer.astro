---
import brand from '../../brand.json';

const socialIcons: Record<string, string> = {
  LinkedIn: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>`,
  Twitter: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  Facebook: `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
};
---
<footer style={`background-color: ${brand.colors.primary}`}>
  <div class="mx-auto max-w-7xl px-6">
    <!-- Main footer content -->
    <div class="grid gap-12 py-16 md:grid-cols-4">
      <!-- Brand column -->
      <div class="md:col-span-2">
        <!-- Logo -->
        <div class="flex items-center gap-2">
          <div class="flex h-10 w-10 items-center justify-center rounded" style={`background-color: ${brand.colors.accent}`}>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke={brand.colors.primary} stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 6l9-4 9 4v2H3V6z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 8v8m4-8v8m6-8v8m4-8v8" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16h18v2H3v-2z" />
            </svg>
          </div>
          <span class="font-serif text-xl font-bold text-white" style="font-family: 'Playfair Display', Georgia, serif">
            Sterling <span style={`color: ${brand.colors.accent}`}>&</span> Associates
          </span>
        </div>
        <!-- Motto -->
        <p class="mt-4 font-serif text-lg italic text-white/40" style="font-family: 'Playfair Display', Georgia, serif">
          {brand.footer.motto}
        </p>
        <p class="mt-3 max-w-md text-sm leading-relaxed text-white/30">
          {brand.description}
        </p>

        <!-- Social links -->
        <div class="mt-6 flex gap-4">
          {brand.footer.socials.map((social: { platform: string; url: string }) => (
            <a
              href={social.url}
              class="flex h-10 w-10 items-center justify-center rounded-full text-white/40 transition-all hover:text-white"
              style={`border: 1px solid rgba(255,255,255,0.1)`}
              aria-label={social.platform}
            >
              <Fragment set:html={socialIcons[social.platform] || ''} />
            </a>
          ))}
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3
          class="mb-6 text-xs font-semibold uppercase tracking-[0.15em]"
          style={`color: ${brand.colors.accent}`}
        >
          Quick Links
        </h3>
        <ul class="space-y-3">
          {brand.nav.map((link: { label: string; href: string }) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-white/40 transition-colors hover:text-white"
              >
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="#about" class="text-sm text-white/40 transition-colors hover:text-white">
              About Us
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <h3
          class="mb-6 text-xs font-semibold uppercase tracking-[0.15em]"
          style={`color: ${brand.colors.accent}`}
        >
          Contact
        </h3>
        <ul class="space-y-3">
          <li class="text-sm text-white/40">
            {brand.contact.address}
          </li>
          <li>
            <a
              href={`tel:${brand.contact.phone.replace(/[^0-9+]/g, '')}`}
              class="text-sm text-white/40 transition-colors hover:text-white"
            >
              {brand.contact.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${brand.contact.email}`}
              class="text-sm text-white/40 transition-colors hover:text-white"
            >
              {brand.contact.email}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t py-6" style="border-color: rgba(255,255,255,0.08)">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-xs text-white/30">
          &copy; {new Date().getFullYear()} {brand.businessName}. All rights reserved.
        </p>
        <div class="flex gap-6">
          <a href="#" class="text-xs text-white/30 transition-colors hover:text-white/60">
            Privacy Policy
          </a>
          <a href="#" class="text-xs text-white/30 transition-colors hover:text-white/60">
            Terms of Service
          </a>
          <a href="#" class="text-xs text-white/30 transition-colors hover:text-white/60">
            Disclaimer
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
