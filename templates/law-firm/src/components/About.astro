---
import brand from '../../brand.json';

const valueIcons: Record<string, string> = {
  Excellence: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>`,
  Integrity: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" /></svg>`,
  Dedication: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z" /></svg>`,
  Results: `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-5.54 0" /></svg>`,
};
---
<section id="about" class="section-padding" style={`background-color: ${brand.colors.white}`}>
  <div class="mx-auto max-w-7xl">
    <!-- Two-column layout -->
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">
      <!-- Image column -->
      <div class="animate-on-scroll from-left relative">
        <div class="overflow-hidden rounded-2xl">
          <img
            src={brand.about.image}
            alt="Sterling & Associates office"
            class="h-full w-full object-cover"
            style="aspect-ratio: 4/3"
            loading="lazy"
          />
        </div>
        <!-- Decorative gold accent -->
        <div
          class="absolute -bottom-4 -right-4 -z-10 hidden h-full w-full rounded-2xl lg:block"
          style={`border: 2px solid ${brand.colors.accent}; opacity: 0.3`}
        ></div>
        <!-- Experience badge -->
        <div
          class="absolute -bottom-6 -right-6 hidden rounded-xl px-6 py-4 shadow-xl lg:block"
          style={`background-color: ${brand.colors.accent}`}
        >
          <span class="block font-serif text-3xl font-bold" style={`color: ${brand.colors.primary}; font-family: 'Playfair Display', Georgia, serif`}>25+</span>
          <span class="text-xs font-semibold uppercase tracking-wider" style={`color: ${brand.colors.primary}`}>Years</span>
        </div>
      </div>

      <!-- Text column -->
      <div class="animate-on-scroll from-right">
        <div class="mb-4 flex items-center gap-3">
          <div class="h-px w-8" style={`background-color: ${brand.colors.accent}`}></div>
          <span
            class="text-xs font-semibold uppercase tracking-[0.2em]"
            style={`color: ${brand.colors.accent}`}
          >
            About Our Firm
          </span>
        </div>
        <h2
          class="font-serif text-3xl font-bold sm:text-4xl"
          style={`color: ${brand.colors.primary}; font-family: 'Playfair Display', Georgia, serif`}
        >
          {brand.about.heading}
        </h2>
        <p class="mt-6 text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
          {brand.about.text}
        </p>

        <!-- Gold divider -->
        <div class="my-8 h-px w-16" style={`background-color: ${brand.colors.accent}`}></div>

        <!-- Values grid -->
        <div class="grid grid-cols-2 gap-6">
          {brand.about.values.map((value: { title: string; description: string }) => (
            <div class="flex flex-col gap-2">
              <div class="flex items-center gap-3">
                <div style={`color: ${brand.colors.accent}`}>
                  <Fragment set:html={valueIcons[value.title] || valueIcons['Excellence']} />
                </div>
                <h3 class="font-serif text-base font-bold" style={`color: ${brand.colors.primary}; font-family: 'Playfair Display', Georgia, serif`}>
                  {value.title}
                </h3>
              </div>
              <p class="text-xs leading-relaxed" style={`color: ${brand.colors.textLight}`}>
                {value.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
