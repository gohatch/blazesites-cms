---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.white}`}>
  <div class="mx-auto max-w-7xl">
    <!-- Section header -->
    <div class="animate-on-scroll mb-16 text-center">
      <div class="mb-4 flex items-center justify-center gap-3">
        <div class="h-px w-8" style={`background-color: ${brand.colors.accent}`}></div>
        <span
          class="text-xs font-semibold uppercase tracking-[0.2em]"
          style={`color: ${brand.colors.accent}`}
        >
          Testimonials
        </span>
        <div class="h-px w-8" style={`background-color: ${brand.colors.accent}`}></div>
      </div>
      <h2
        class="font-serif text-3xl font-bold sm:text-4xl lg:text-5xl"
        style={`color: ${brand.colors.primary}; font-family: 'Playfair Display', Georgia, serif`}
      >
        What Our Clients Say
      </h2>
    </div>

    <!-- Testimonials grid -->
    <div class="stagger-children grid gap-8 md:grid-cols-3">
      {brand.testimonials.map((testimonial: { quote: string; author: string; role: string; rating: number }) => (
        <div
          class="card-hover relative rounded-xl p-8"
          style={`background-color: ${brand.colors.bg}; border: 1px solid ${brand.colors.border}`}
        >
          <!-- Quote mark -->
          <div class="quote-mark mb-2" style={`color: ${brand.colors.accent}; opacity: 0.25`}>
            &#8220;
          </div>

          <!-- Stars -->
          <div class="mb-4 flex gap-1">
            {Array.from({ length: testimonial.rating }).map(() => (
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill={brand.colors.accent}>
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote text -->
          <p class="text-sm leading-relaxed" style={`color: ${brand.colors.text}; opacity: 0.85`}>
            {testimonial.quote}
          </p>

          <!-- Author -->
          <div class="mt-6 flex items-center gap-3">
            <!-- Initials avatar -->
            <div
              class="flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold"
              style={`background-color: ${brand.colors.primary}; color: ${brand.colors.accent}`}
            >
              {testimonial.author.split(' ').map((n: string) => n[0]).join('')}
            </div>
            <div>
              <p class="text-sm font-semibold" style={`color: ${brand.colors.primary}`}>
                {testimonial.author}
              </p>
              <p class="text-xs" style={`color: ${brand.colors.textLight}`}>
                {testimonial.role}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
