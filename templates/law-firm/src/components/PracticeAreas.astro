---
import brand from '../../brand.json';

const iconMap: Record<string, string> = {
  building: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21" /></svg>`,
  family: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>`,
  shield: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>`,
  home: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819" /></svg>`,
  briefcase: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" /></svg>`,
  heart: `<svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>`,
};
---
<section id="practice-areas" class="section-padding" style={`background-color: ${brand.colors.bg}`}>
  <div class="mx-auto max-w-7xl">
    <!-- Section header -->
    <div class="animate-on-scroll mb-16 text-center">
      <div class="mb-4 flex items-center justify-center gap-3">
        <div class="h-px w-8" style={`background-color: ${brand.colors.accent}`}></div>
        <span
          class="text-xs font-semibold uppercase tracking-[0.2em]"
          style={`color: ${brand.colors.accent}`}
        >
          What We Do
        </span>
        <div class="h-px w-8" style={`background-color: ${brand.colors.accent}`}></div>
      </div>
      <h2
        class="font-serif text-3xl font-bold sm:text-4xl lg:text-5xl"
        style={`color: ${brand.colors.primary}; font-family: 'Playfair Display', Georgia, serif`}
      >
        Our Practice Areas
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
        We provide comprehensive legal services across multiple disciplines, ensuring our clients receive expert representation in every matter.
      </p>
    </div>

    <!-- Services grid -->
    <div class="stagger-children grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {brand.services.map((service: { title: string; description: string; icon: string }) => (
        <div
          class="accent-bar-left card-hover group cursor-pointer rounded-xl p-8 pl-8"
          style={`background-color: ${brand.colors.white}; border: 1px solid ${brand.colors.border}`}
        >
          <!-- Icon -->
          <div
            class="mb-5 flex h-14 w-14 items-center justify-center rounded-lg transition-colors duration-300"
            style={`background-color: ${brand.colors.bg}; color: ${brand.colors.accent}`}
          >
            <Fragment set:html={iconMap[service.icon] || iconMap['building']} />
          </div>

          <!-- Content -->
          <h3
            class="font-serif text-xl font-bold"
            style={`color: ${brand.colors.primary}; font-family: 'Playfair Display', Georgia, serif`}
          >
            {service.title}
          </h3>
          <p class="mt-3 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>
            {service.description}
          </p>

          <!-- Learn more link -->
          <div class="mt-5 flex items-center gap-2 text-sm font-semibold transition-colors" style={`color: ${brand.colors.accent}`}>
            <span>Learn More</span>
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
