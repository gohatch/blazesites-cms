---
import brand from '../../brand.json';
---
<section class="relative overflow-hidden py-20 sm:py-24" style={`background-color: ${brand.colors.primary}`}>
  <!-- Decorative elements -->
  <div class="absolute inset-0">
    <div class="absolute left-0 top-0 h-full w-1/3 opacity-5" style={`background: linear-gradient(to right, ${brand.colors.accent}, transparent)`}></div>
    <div class="absolute right-0 bottom-0 h-full w-1/3 opacity-5" style={`background: linear-gradient(to left, ${brand.colors.accent}, transparent)`}></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6">
    <!-- Section header -->
    <div class="animate-on-scroll mb-12 text-center">
      <div class="mb-4 flex items-center justify-center gap-3">
        <div class="h-px w-8" style={`background-color: ${brand.colors.accent}; opacity: 0.5`}></div>
        <span
          class="text-xs font-semibold uppercase tracking-[0.2em]"
          style={`color: ${brand.colors.accent}`}
        >
          Our Track Record
        </span>
        <div class="h-px w-8" style={`background-color: ${brand.colors.accent}; opacity: 0.5`}></div>
      </div>
      <h2
        class="font-serif text-3xl font-bold text-white sm:text-4xl"
        style="font-family: 'Playfair Display', Georgia, serif"
      >
        Numbers That Speak for Themselves
      </h2>
    </div>

    <!-- Stats grid -->
    <div class="stagger-children grid grid-cols-2 gap-8 md:grid-cols-4">
      {brand.stats.map((stat: { value: string; label: string }, i: number) => (
        <div class={`text-center ${i < brand.stats.length - 1 ? 'md:border-r' : ''}`} style={i < brand.stats.length - 1 ? 'border-color: rgba(255,255,255,0.1)' : ''}>
          <p
            class="font-serif text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl"
            style={`color: ${brand.colors.accent}; font-family: 'Playfair Display', Georgia, serif`}
            data-counter
            data-target={stat.value}
          >
            0
          </p>
          <p class="mt-3 text-xs font-semibold uppercase tracking-[0.15em] text-white/50 sm:text-sm">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
