---
import brand from '../../brand.json';
---
<section
  class="relative flex min-h-screen items-center overflow-hidden pattern-overlay"
  style={`background-color: ${brand.colors.primary}`}
>
  <!-- Decorative elements -->
  <div class="absolute inset-0 z-0">
    <!-- Subtle gradient overlay -->
    <div class="absolute inset-0" style={`background: linear-gradient(135deg, ${brand.colors.primary} 0%, ${brand.colors.primaryLight} 50%, ${brand.colors.primary} 100%)`}></div>
    <!-- Gold corner accent -->
    <div class="absolute right-0 top-0 h-96 w-96 opacity-5" style={`background: radial-gradient(circle at top right, ${brand.colors.accent}, transparent 70%)`}></div>
    <div class="absolute bottom-0 left-0 h-64 w-64 opacity-5" style={`background: radial-gradient(circle at bottom left, ${brand.colors.accent}, transparent 70%)`}></div>
  </div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 pb-20 pt-32 sm:pt-40">
    <div class="max-w-3xl">
      <!-- Section label -->
      <div class="hero-animate hero-animate-1 mb-6 flex items-center gap-3">
        <div class="h-px w-8" style={`background-color: ${brand.colors.accent}`}></div>
        <span
          class="text-xs font-semibold uppercase tracking-[0.2em]"
          style={`color: ${brand.colors.accent}`}
        >
          Attorneys at Law
        </span>
      </div>

      <!-- Heading -->
      <h1 class="hero-animate hero-animate-2 font-serif text-4xl font-bold leading-tight text-white sm:text-5xl md:text-6xl lg:text-7xl" style="font-family: 'Playfair Display', Georgia, serif">
        <span style={`color: ${brand.colors.accent}`}>{brand.hero.accentWord}</span>{' '}
        {brand.hero.heading.replace(brand.hero.accentWord, '').trim()}
      </h1>

      <!-- Subheading -->
      <p class="hero-animate hero-animate-3 mt-6 max-w-2xl text-lg leading-relaxed text-white/60 sm:text-xl">
        {brand.hero.subheading}
      </p>

      <!-- CTAs -->
      <div class="hero-animate hero-animate-4 mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
        <a href="#contact" class="btn-primary text-center">
          {brand.hero.primaryCta}
        </a>
        <a href="#practice-areas" class="btn-outline text-center">
          {brand.hero.secondaryCta}
        </a>
      </div>
    </div>

    <!-- Trust badges row -->
    <div class="hero-animate hero-animate-4 mt-20 grid grid-cols-2 gap-6 sm:grid-cols-4 sm:gap-8">
      {brand.stats.map((stat: { value: string; label: string }, i: number) => (
        <div class={`flex flex-col ${i < brand.stats.length - 1 ? 'sm:border-r' : ''}`} style={i < brand.stats.length - 1 ? 'border-color: rgba(255,255,255,0.1)' : ''}>
          <span
            class="font-serif text-2xl font-bold sm:text-3xl"
            style={`color: ${brand.colors.accent}; font-family: 'Playfair Display', Georgia, serif`}
          >
            {stat.value}
          </span>
          <span class="mt-1 text-xs font-medium uppercase tracking-widest text-white/40">
            {stat.label}
          </span>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
    <div class="flex flex-col items-center gap-2 opacity-40">
      <span class="text-xs uppercase tracking-widest text-white">Scroll</span>
      <div class="h-8 w-px animate-pulse" style={`background-color: ${brand.colors.accent}`}></div>
    </div>
  </div>
</section>
