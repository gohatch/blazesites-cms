---
import brand from '../../brand.json';
---

<header id="header" style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; background-color: rgba(253, 252, 248, 0.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(42, 42, 30, 0.06); transition: all 0.3s ease;">
  <div style="max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 80px;">
    <!-- Logo -->
    <a href="#" style="text-decoration: none; display: flex; align-items: center; gap: 0.25rem;">
      <span style="font-family: 'Playfair Display', serif; font-size: 1.75rem; font-weight: 700; color: #2A2A1E; letter-spacing: -0.02em;">Nestora</span>
    </a>

    <!-- Desktop Nav -->
    <nav style="display: none; align-items: center; gap: 2.5rem;" class="desktop-nav">
      {brand.nav.map((item) => (
        <a href={item.href} style="text-decoration: none; font-size: 0.9rem; font-weight: 400; color: #6B6B5A; transition: color 0.3s ease; letter-spacing: 0.01em;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='#6B6B5A'">
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Right side -->
    <div style="display: none; align-items: center; gap: 1.5rem;" class="desktop-right">
      <a href="tel:+18005556378" style="text-decoration: none; font-size: 0.875rem; font-weight: 400; color: #2A2A1E; display: flex; align-items: center; gap: 0.5rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#A68B3C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {brand.contact.phone}
      </a>
      <a href="#contact" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.625rem 1.75rem; background-color: #A68B3C; color: #ffffff; font-size: 0.875rem; font-weight: 500; border-radius: 50px; text-decoration: none; transition: all 0.3s ease; letter-spacing: 0.02em;" onmouseover="this.style.backgroundColor='#8F7732'; this.style.boxShadow='0 4px 20px rgba(166,139,60,0.3)'" onmouseout="this.style.backgroundColor='#A68B3C'; this.style.boxShadow='none'">
        Register
      </a>
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" style="display: flex; align-items: center; justify-content: center; background: none; border: none; cursor: pointer; padding: 0.5rem;" class="mobile-menu-btn" aria-label="Toggle menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2A2A1E" stroke-width="1.5" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden" style="background-color: #FDFCF8; border-top: 1px solid rgba(42, 42, 30, 0.06); padding: 1.5rem;">
    <nav style="display: flex; flex-direction: column; gap: 1.25rem;">
      {brand.nav.map((item) => (
        <a href={item.href} style="text-decoration: none; font-size: 1rem; font-weight: 400; color: #2A2A1E; padding: 0.5rem 0; border-bottom: 1px solid rgba(42, 42, 30, 0.06);">
          {item.label}
        </a>
      ))}
      <a href="tel:+18005556378" style="text-decoration: none; font-size: 0.9rem; font-weight: 400; color: #6B6B5A; display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 0;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#A68B3C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {brand.contact.phone}
      </a>
      <a href="#contact" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.75rem 1.5rem; background-color: #A68B3C; color: #ffffff; font-size: 0.875rem; font-weight: 500; border-radius: 50px; text-decoration: none; text-align: center;">
        Register
      </a>
    </nav>
  </div>
</header>

<style>
  @media (min-width: 768px) {
    .desktop-nav {
      display: flex !important;
    }
    .desktop-right {
      display: flex !important;
    }
    .mobile-menu-btn {
      display: none !important;
    }
  }
  .hidden {
    display: none;
  }
</style>
