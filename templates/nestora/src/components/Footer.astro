---
import brand from '../../brand.json';
---

<footer style="background-color: #1A1A12; color: rgba(255, 255, 255, 0.7); padding: 4rem 1.5rem 0;">
  <div style="max-width: 1200px; margin: 0 auto;">
    <!-- Main Footer Grid -->
    <div style="display: grid; grid-template-columns: 1fr; gap: 3rem; padding-bottom: 3rem; border-bottom: 1px solid rgba(255, 255, 255, 0.08);" id="footer-grid">
      <!-- Brand Column -->
      <div>
        <a href="#" style="text-decoration: none; display: inline-block; margin-bottom: 1.25rem;">
          <span style="font-family: 'Playfair Display', serif; font-size: 1.75rem; font-weight: 700; color: #ffffff; letter-spacing: -0.02em;">Nestora</span>
        </a>
        <p style="font-size: 0.9375rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); line-height: 1.8; max-width: 300px; margin-bottom: 1.5rem;">
          Premium real estate brand creating thoughtful, sustainable, and inspiring spaces for discerning clients since 2014.
        </p>
        <!-- Social Icons -->
        <div style="display: flex; gap: 0.75rem;">
          <a href={brand.social.instagram} style="width: 36px; height: 36px; border-radius: 50%; background-color: rgba(255, 255, 255, 0.08); display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.3s ease;" onmouseover="this.style.backgroundColor='#A68B3C'" onmouseout="this.style.backgroundColor='rgba(255, 255, 255, 0.08)'" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href={brand.social.facebook} style="width: 36px; height: 36px; border-radius: 50%; background-color: rgba(255, 255, 255, 0.08); display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.3s ease;" onmouseover="this.style.backgroundColor='#A68B3C'" onmouseout="this.style.backgroundColor='rgba(255, 255, 255, 0.08)'" aria-label="Facebook">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href={brand.social.linkedin} style="width: 36px; height: 36px; border-radius: 50%; background-color: rgba(255, 255, 255, 0.08); display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.3s ease;" onmouseover="this.style.backgroundColor='#A68B3C'" onmouseout="this.style.backgroundColor='rgba(255, 255, 255, 0.08)'" aria-label="LinkedIn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <a href={brand.social.twitter} style="width: 36px; height: 36px; border-radius: 50%; background-color: rgba(255, 255, 255, 0.08); display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.3s ease;" onmouseover="this.style.backgroundColor='#A68B3C'" onmouseout="this.style.backgroundColor='rgba(255, 255, 255, 0.08)'" aria-label="Twitter">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.7)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Sell a Home -->
      <div>
        <h4 style="font-family: 'Playfair Display', serif; font-size: 1.0625rem; font-weight: 600; color: #ffffff; margin-bottom: 1.25rem;">
          Sell a Home
        </h4>
        <nav style="display: flex; flex-direction: column; gap: 0.75rem;">
          <a href="#" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Request an Offer</a>
          <a href="#" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Pricing</a>
          <a href="#" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Reviews</a>
          <a href="#" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Stories</a>
        </nav>
      </div>

      <!-- Buy, Rent & Sell -->
      <div>
        <h4 style="font-family: 'Playfair Display', serif; font-size: 1.0625rem; font-weight: 600; color: #ffffff; margin-bottom: 1.25rem;">
          Buy, Rent & Sell
        </h4>
        <nav style="display: flex; flex-direction: column; gap: 0.75rem;">
          <a href="#" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Buy a Home</a>
          <a href="#" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Rent a Home</a>
          <a href="#" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Sell a Home</a>
          <a href="#" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Home Loans</a>
        </nav>
      </div>

      <!-- About & Contact -->
      <div>
        <h4 style="font-family: 'Playfair Display', serif; font-size: 1.0625rem; font-weight: 600; color: #ffffff; margin-bottom: 1.25rem;">
          About
        </h4>
        <nav style="display: flex; flex-direction: column; gap: 0.75rem;">
          <a href="#about" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Company</a>
          <a href="#team" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Our Team</a>
          <a href="#" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Contact Us</a>
          <a href="#" style="text-decoration: none; font-size: 0.875rem; font-weight: 300; color: rgba(255, 255, 255, 0.55); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.55)'">Careers</a>
        </nav>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div style="display: flex; flex-direction: column; align-items: center; justify-content: space-between; gap: 1rem; padding: 1.5rem 0;" id="footer-bottom">
      <p style="font-size: 0.8125rem; font-weight: 300; color: rgba(255, 255, 255, 0.4);">
        &copy; 2024 Nestora. All rights reserved.
      </p>
      <div style="display: flex; gap: 1.5rem;">
        <a href="#" style="text-decoration: none; font-size: 0.8125rem; font-weight: 300; color: rgba(255, 255, 255, 0.4); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.4)'">Privacy Policy</a>
        <a href="#" style="text-decoration: none; font-size: 0.8125rem; font-weight: 300; color: rgba(255, 255, 255, 0.4); transition: color 0.3s ease;" onmouseover="this.style.color='#A68B3C'" onmouseout="this.style.color='rgba(255, 255, 255, 0.4)'">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  @media (min-width: 768px) {
    #footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr !important;
    }
    #footer-bottom {
      flex-direction: row !important;
    }
  }
</style>
