---
import brand from '../../brand.json';
---

<section id="hero" style="position: relative; min-height: 100vh; display: flex; flex-direction: column; justify-content: center; overflow: hidden;">
  <!-- Background Image -->
  <div style="position: absolute; inset: 0; z-index: 0;">
    <img
      src={brand.hero.image}
      alt="Luxury modern home"
      style="width: 100%; height: 100%; object-fit: cover;"
      loading="eager"
    />
    <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(42, 42, 30, 0.55) 0%, rgba(42, 42, 30, 0.75) 100%);"></div>
  </div>

  <!-- Content -->
  <div style="position: relative; z-index: 10; max-width: 1280px; margin: 0 auto; padding: 8rem 1.5rem 10rem; width: 100%; text-align: center;">
    <div class="fade-up">
      <div style="display: flex; align-items: center; justify-content: center; gap: 0.75rem; margin-bottom: 2rem;">
        <span style="width: 2rem; height: 1px; background-color: #A68B3C;"></span>
        <span style="font-size: 0.8125rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: #A68B3C;">Premium Real Estate</span>
        <span style="width: 2rem; height: 1px; background-color: #A68B3C;"></span>
      </div>
    </div>

    <h1 class="fade-up" style="font-family: 'Playfair Display', serif; font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 500; color: #ffffff; line-height: 1.15; max-width: 800px; margin: 0 auto 1.5rem; letter-spacing: -0.01em;">
      {brand.hero.heading}
    </h1>

    <p class="fade-up" style="font-size: clamp(0.9375rem, 1.5vw, 1.125rem); font-weight: 300; color: rgba(255, 255, 255, 0.8); max-width: 560px; margin: 0 auto 2.5rem; line-height: 1.8;">
      {brand.hero.subheading}
    </p>

    <div class="fade-up">
      <a href="#properties" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 1rem 2.5rem; background-color: #A68B3C; color: #ffffff; font-size: 0.9375rem; font-weight: 500; border-radius: 4px; text-decoration: none; transition: all 0.3s ease; letter-spacing: 0.03em;" onmouseover="this.style.backgroundColor='#8F7732'; this.style.boxShadow='0 4px 20px rgba(166,139,60,0.4)'; this.style.transform='translateY(-2px)'" onmouseout="this.style.backgroundColor='#A68B3C'; this.style.boxShadow='none'; this.style.transform='translateY(0)'">
        {brand.hero.cta}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Search Bar -->
  <div style="position: absolute; bottom: 0; left: 0; right: 0; z-index: 20;">
    <div style="max-width: 1100px; margin: 0 auto; padding: 0 1.5rem;">
      <div class="fade-up" style="background-color: #ffffff; border-radius: 12px 12px 0 0; padding: 1.5rem 2rem; box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.08); display: grid; grid-template-columns: 1fr; gap: 1rem; align-items: end;" id="search-bar">
        <div style="display: grid; grid-template-columns: 1fr; gap: 1rem;" class="search-fields">
          <div>
            <label style="display: block; font-size: 0.75rem; font-weight: 500; color: #6B6B5A; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.375rem;">Building Type</label>
            <select style="width: 100%; padding: 0.625rem 0.75rem; border: 1px solid rgba(42, 42, 30, 0.12); border-radius: 6px; font-family: 'Poppins', sans-serif; font-size: 0.875rem; color: #2A2A1E; background-color: #F9F7F2; cursor: pointer; appearance: auto;">
              <option>All Types</option>
              <option>Villa</option>
              <option>Penthouse</option>
              <option>Estate</option>
              <option>Apartment</option>
            </select>
          </div>
          <div>
            <label style="display: block; font-size: 0.75rem; font-weight: 500; color: #6B6B5A; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.375rem;">Category</label>
            <select style="width: 100%; padding: 0.625rem 0.75rem; border: 1px solid rgba(42, 42, 30, 0.12); border-radius: 6px; font-family: 'Poppins', sans-serif; font-size: 0.875rem; color: #2A2A1E; background-color: #F9F7F2; cursor: pointer; appearance: auto;">
              <option>Buy</option>
              <option>Rent</option>
              <option>Sell</option>
            </select>
          </div>
          <div>
            <label style="display: block; font-size: 0.75rem; font-weight: 500; color: #6B6B5A; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.375rem;">Price Range</label>
            <select style="width: 100%; padding: 0.625rem 0.75rem; border: 1px solid rgba(42, 42, 30, 0.12); border-radius: 6px; font-family: 'Poppins', sans-serif; font-size: 0.875rem; color: #2A2A1E; background-color: #F9F7F2; cursor: pointer; appearance: auto;">
              <option>Any Price</option>
              <option>$500K - $1M</option>
              <option>$1M - $3M</option>
              <option>$3M - $5M</option>
              <option>$5M+</option>
            </select>
          </div>
          <div>
            <label style="display: block; font-size: 0.75rem; font-weight: 500; color: #6B6B5A; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.375rem;">Location</label>
            <select style="width: 100%; padding: 0.625rem 0.75rem; border: 1px solid rgba(42, 42, 30, 0.12); border-radius: 6px; font-family: 'Poppins', sans-serif; font-size: 0.875rem; color: #2A2A1E; background-color: #F9F7F2; cursor: pointer; appearance: auto;">
              <option>All Locations</option>
              <option>Beverly Hills, CA</option>
              <option>Miami Beach, FL</option>
              <option>Manhattan, NY</option>
              <option>Aspen, CO</option>
            </select>
          </div>
        </div>
        <button style="width: 100%; padding: 0.75rem 2rem; background-color: #A68B3C; color: #ffffff; font-family: 'Poppins', sans-serif; font-size: 0.875rem; font-weight: 500; border: none; border-radius: 6px; cursor: pointer; transition: all 0.3s ease; display: flex; align-items: center; justify-content: center; gap: 0.5rem; letter-spacing: 0.02em;" class="search-btn" onmouseover="this.style.backgroundColor='#8F7732'" onmouseout="this.style.backgroundColor='#A68B3C'">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
          Search
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .search-fields {
      grid-template-columns: repeat(4, 1fr) !important;
    }
    #search-bar {
      grid-template-columns: 1fr auto !important;
      padding: 2rem 2.5rem !important;
    }
    .search-btn {
      width: auto !important;
      padding: 0.75rem 2rem !important;
      height: 44px;
    }
  }
</style>
