---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.lavender}`}>
  <div class="mx-auto max-w-7xl space-y-24 lg:space-y-32">
    {brand.detailSections.map((section, i) => (
      <div class={`grid items-center gap-12 lg:grid-cols-2 lg:gap-20 ${i % 2 === 1 ? 'direction-rtl' : ''}`}>
        <!-- Text Side -->
        <div class={`animate-on-scroll ${i % 2 === 0 ? 'from-left' : 'from-right'} ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
          <span class="badge-purple">{section.badge}</span>
          <h2 class="mt-4 heading-serif text-3xl tracking-tight sm:text-4xl">
            {section.badge}
          </h2>

          <div class="mt-8 space-y-6">
            {section.features.map((feat, j) => (
              <div class="flex gap-4">
                <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full" style={`background-color: ${brand.colors.accentLight}`}>
                  <svg class="h-4 w-4" style={`color: ${brand.colors.accent}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold">{feat}</h3>
                  <p class="mt-1 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>
                    {section.descriptions[j]}
                  </p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href="#cta" class="btn-primary !text-sm">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              Download for iOS
            </a>
            <a href="#cta" class="btn-outline !text-sm">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-1.4l2.651 1.535a1 1 0 010 1.716l-2.651 1.535-2.537-2.537 2.537-2.25zM5.864 1.458L16.8 7.79l-2.302 2.302-8.634-8.634z"/></svg>
              Download for Playstore
            </a>
          </div>
        </div>

        <!-- Image Side -->
        <div class={`animate-on-scroll ${i % 2 === 0 ? 'from-right' : 'from-left'} ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
          <div class="overflow-hidden rounded-2xl shadow-xl">
            <img
              src={section.image}
              alt={section.badge}
              class="w-full object-cover"
              style="aspect-ratio: 4/3"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
