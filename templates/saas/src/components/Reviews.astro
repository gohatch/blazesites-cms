---
import brand from '../../brand.json';
---
<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <span class="badge-purple">Testimonials</span>
      <h2 class="mt-4 heading-serif text-3xl tracking-tight sm:text-4xl">Customer reviews</h2>
      <p class="mt-4 text-base" style={`color: ${brand.colors.textLight}`}>
        See what teams around the world are saying about {brand.businessName}.
      </p>
    </div>

    <div class="stagger-children mt-14 grid gap-8 lg:grid-cols-2">
      {brand.testimonials.map((t, i) => (
        <div class={`card-feature ${i === 0 ? 'lg:row-span-1' : ''}`}>
          <!-- Stars -->
          <div class="flex gap-0.5 text-amber-400">
            {[1,2,3,4,5].map(() => (
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="mt-4 text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
            "{t.quote}"
          </p>

          <!-- Author -->
          <div class="mt-6 flex items-center gap-4 border-t border-gray-100 pt-5">
            <img
              src={t.image}
              alt={t.author}
              class="h-12 w-12 rounded-full object-cover"
              loading="lazy"
            />
            <div>
              <p class="font-bold">{t.author}</p>
              <p class="text-sm" style={`color: ${brand.colors.textLight}`}>{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
