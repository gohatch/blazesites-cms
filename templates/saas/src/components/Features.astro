---
import brand from '../../brand.json';

const iconPaths: Record<string, string> = {
  sync: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15',
  layout: 'M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm0 8a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zm10 0a1 1 0 011-1h4a1 1 0 011 1v6a1 1 0 01-1 1h-4a1 1 0 01-1-1v-6z',
  connect: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1',
  chart: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
};
---
<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <span class="badge-purple">Features</span>
      <h2 class="mt-4 heading-serif text-3xl tracking-tight sm:text-4xl">Our Features</h2>
      <p class="mt-4 text-base" style={`color: ${brand.colors.textLight}`}>
        Everything you need to manage projects, collaborate with your team, and boost productivity.
      </p>
    </div>

    <div class="stagger-children mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-2 max-w-4xl mx-auto">
      {brand.features.map((feature) => (
        <div class="card-feature">
          <div class="icon-box">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[feature.icon] || iconPaths.sync} />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>{feature.description}</p>
          <a href="#" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors hover:opacity-70" style={`color: ${brand.colors.accent}`}>
            Learn more
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
