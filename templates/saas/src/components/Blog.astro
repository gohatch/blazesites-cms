---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.lavender}`}>
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <span class="badge-purple">Blog</span>
      <h2 class="mt-4 heading-serif text-3xl tracking-tight sm:text-4xl">Recent articles</h2>
      <p class="mt-4 text-base" style={`color: ${brand.colors.textLight}`}>
        Insights, tips, and updates from the {brand.businessName} team.
      </p>
    </div>

    <div class="stagger-children mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {brand.blog.map((post) => (
        <article class="card-feature overflow-hidden !p-0">
          <div class="relative overflow-hidden">
            <img
              src={post.image}
              alt={post.title}
              class="w-full object-cover transition-transform duration-300 hover:scale-105"
              style="aspect-ratio: 16/10"
              loading="lazy"
            />
            <span class="absolute top-4 left-4 badge-purple !text-xs">{post.tag}</span>
          </div>
          <div class="p-6">
            <p class="text-xs font-medium" style={`color: ${brand.colors.textLight}`}>{post.date}</p>
            <h3 class="mt-2 text-lg font-bold leading-snug">{post.title}</h3>
            <p class="mt-2 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>{post.description}</p>
            <a href="#" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors hover:opacity-70" style={`color: ${brand.colors.accent}`}>
              Read more
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
