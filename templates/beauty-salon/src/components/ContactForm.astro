---
import brand from '../../brand.json';
---
<section id="contact" class="section-padding" style={`background-color: ${brand.colors.cream}`}>
  <div class="mx-auto max-w-3xl">
    <div class="animate-on-scroll mx-auto max-w-xl text-center">
      <div class="ornament mb-4">
        <span class="text-xs font-medium uppercase tracking-[0.25em]" style={`color: ${brand.colors.primary}`}>Contact</span>
      </div>
      <h2 class="font-serif text-3xl font-bold sm:text-4xl" style={`color: ${brand.colors.textDark}`}>
        Book Your <em>Appointment</em>
      </h2>
      <p class="mt-4 text-base font-light" style={`color: ${brand.colors.textLight}`}>
        Ready to treat yourself? Fill out the form and we'll confirm your booking within 24 hours.
      </p>
    </div>

    <div class="animate-on-scroll mt-12">
      <form class="bg-white p-8 shadow-sm sm:p-10" onsubmit="event.preventDefault()">
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label class="mb-2 block text-xs font-medium uppercase tracking-wider" style={`color: ${brand.colors.textDark}`}>Full Name</label>
            <input
              type="text"
              placeholder="Your name"
              class="w-full border-b-2 bg-transparent p-3 text-sm transition-colors focus:outline-none"
              style={`border-color: ${brand.colors.border}`}
              onfocus={`this.style.borderColor='${brand.colors.primary}'`}
              onblur={`this.style.borderColor='${brand.colors.border}'`}
            />
          </div>
          <div>
            <label class="mb-2 block text-xs font-medium uppercase tracking-wider" style={`color: ${brand.colors.textDark}`}>Email</label>
            <input
              type="email"
              placeholder="your@email.com"
              class="w-full border-b-2 bg-transparent p-3 text-sm transition-colors focus:outline-none"
              style={`border-color: ${brand.colors.border}`}
              onfocus={`this.style.borderColor='${brand.colors.primary}'`}
              onblur={`this.style.borderColor='${brand.colors.border}'`}
            />
          </div>
          <div>
            <label class="mb-2 block text-xs font-medium uppercase tracking-wider" style={`color: ${brand.colors.textDark}`}>Phone</label>
            <input
              type="tel"
              placeholder="(555) 123-4567"
              class="w-full border-b-2 bg-transparent p-3 text-sm transition-colors focus:outline-none"
              style={`border-color: ${brand.colors.border}`}
              onfocus={`this.style.borderColor='${brand.colors.primary}'`}
              onblur={`this.style.borderColor='${brand.colors.border}'`}
            />
          </div>
          <div>
            <label class="mb-2 block text-xs font-medium uppercase tracking-wider" style={`color: ${brand.colors.textDark}`}>Service</label>
            <select
              class="w-full border-b-2 bg-transparent p-3 text-sm transition-colors focus:outline-none"
              style={`border-color: ${brand.colors.border}`}
              onfocus={`this.style.borderColor='${brand.colors.primary}'`}
              onblur={`this.style.borderColor='${brand.colors.border}'`}
            >
              <option value="">Select a service</option>
              {brand.services.map(s => (
                <option value={s.title}>{s.title}</option>
              ))}
            </select>
          </div>
        </div>
        <div class="mt-6">
          <label class="mb-2 block text-xs font-medium uppercase tracking-wider" style={`color: ${brand.colors.textDark}`}>Message</label>
          <textarea
            rows="3"
            placeholder="Tell us about your needs..."
            class="w-full border-b-2 bg-transparent p-3 text-sm transition-colors focus:outline-none"
            style={`border-color: ${brand.colors.border}`}
            onfocus={`this.style.borderColor='${brand.colors.primary}'`}
            onblur={`this.style.borderColor='${brand.colors.border}'`}
          ></textarea>
        </div>
        <div class="mt-8 text-center">
          <button type="submit" class="btn-primary">
            Book Appointment
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>
