---
import brand from '../../brand.json';
---
<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md border-b" style={`border-color: ${brand.colors.border}`}>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="/" class="font-serif text-xl font-bold tracking-tight" style={`color: ${brand.colors.text}`}>
      {brand.businessName}
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {brand.nav.map(link => (
        <a href={link.href} class="text-sm font-normal tracking-wide transition-colors hover:opacity-70" style={`color: ${brand.colors.textLight}`}>
          {link.label}
        </a>
      ))}
      <a href="#contact" class="btn-primary !py-2.5 !px-6 !text-sm">
        Book Now
      </a>
    </nav>

    <button class="md:hidden" id="mobile-menu-btn" aria-label="Menu" style={`color: ${brand.colors.text}`}>
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div class="hidden border-t bg-white md:hidden" id="mobile-menu" style={`border-color: ${brand.colors.border}`}>
    <div class="flex flex-col gap-1 px-6 py-4">
      {brand.nav.map(link => (
        <a href={link.href} class="rounded-lg px-4 py-3 text-sm transition-colors hover:bg-gray-50" style={`color: ${brand.colors.textLight}`}>
          {link.label}
        </a>
      ))}
      <a href="#contact" class="btn-primary mt-2 justify-center !text-sm">Book Now</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  btn.addEventListener('click', () => menu.classList.toggle('hidden'));
</script>
