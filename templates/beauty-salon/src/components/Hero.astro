---
import brand from '../../brand.json';
---
<section class="relative min-h-[85vh] overflow-hidden pt-16">
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src={brand.heroImage}
      alt={brand.tagline}
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/40 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 mx-auto flex min-h-[85vh] max-w-7xl items-center px-6">
    <div class="max-w-xl">
      <div class="hero-animate hero-animate-1">
        <div class="ornament mb-6 justify-start">
          <span class="text-xs font-medium uppercase tracking-[0.25em] text-white/70">Welcome to {brand.businessName}</span>
        </div>
      </div>

      <h1 class="hero-animate hero-animate-1 font-serif text-5xl font-bold leading-[1.1] text-white sm:text-6xl lg:text-7xl">
        {brand.tagline}
      </h1>

      <p class="hero-animate hero-animate-2 mt-6 max-w-md text-base leading-relaxed text-white/75 font-light">
        {brand.description}
      </p>

      <div class="hero-animate hero-animate-3 mt-10 flex flex-wrap gap-4">
        <a href="#services" class="btn-primary">
          Explore Services
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#contact" class="btn-outline !border-white/30 !text-white hover:!bg-white hover:!text-gray-900">
          Book Appointment
        </a>
      </div>
    </div>
  </div>
</section>
