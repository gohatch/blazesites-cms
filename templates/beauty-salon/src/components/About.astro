---
import brand from '../../brand.json';
---
<section id="about" class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <!-- Left: Image -->
      <div class="animate-on-scroll from-left">
        <div class="relative">
          <img
            src={brand.aboutImage}
            alt="About us"
            class="h-[500px] w-full rounded-sm object-cover shadow-lg lg:h-[600px]"
            loading="lazy"
          />
          <!-- Decorative frame -->
          <div class="absolute -bottom-4 -right-4 h-full w-full rounded-sm border" style={`border-color: ${brand.colors.primary}40`}></div>
        </div>
      </div>

      <!-- Right: Content -->
      <div class="animate-on-scroll from-right">
        <div class="ornament mb-4 justify-start">
          <span class="text-xs font-medium uppercase tracking-[0.25em]" style={`color: ${brand.colors.primary}`}>About Us</span>
        </div>

        <h2 class="font-serif text-3xl font-bold leading-tight sm:text-4xl lg:text-5xl" style={`color: ${brand.colors.textDark}`}>
          {brand.about.heading}
        </h2>

        <p class="mt-6 text-base leading-relaxed font-light" style={`color: ${brand.colors.textLight}`}>
          {brand.about.text}
        </p>

        <!-- Stats grid -->
        <div class="stagger-children mt-10 grid grid-cols-2 gap-6">
          {brand.about.stats.map((stat) => (
            <div class="border-l-2 pl-5" style={`border-color: ${brand.colors.primary}`}>
              <p
                class="font-serif text-3xl font-bold"
                style={`color: ${brand.colors.primary}`}
                data-counter
                data-target={stat.value}
              >
                0
              </p>
              <p class="mt-1 text-xs font-medium uppercase tracking-wider" style={`color: ${brand.colors.textLight}`}>
                {stat.label}
              </p>
            </div>
          ))}
        </div>

        <a href="#services" class="btn-primary mt-10">
          Our Services
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
