---
import brand from '../../brand.json';
---
<section class="relative overflow-hidden py-24 text-center sm:py-32" style={`background-color: ${brand.colors.primary}`}>
  <!-- Decorative elements -->
  <div class="absolute left-0 top-0 h-full w-1/3 opacity-10">
    <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=600&h=800&fit=crop" alt="" class="h-full w-full object-cover" />
  </div>
  <div class="absolute right-0 top-0 h-full w-1/3 opacity-10">
    <img src="https://images.unsplash.com/photo-1560066984-138dadb4c035?w=600&h=800&fit=crop" alt="" class="h-full w-full object-cover" />
  </div>

  <div class="relative z-10 mx-auto max-w-2xl px-6">
    <div class="animate-on-scroll">
      <div class="ornament mb-6">
        <span class="text-xs font-medium uppercase tracking-[0.25em] text-white/60">Book Today</span>
      </div>
      <h2 class="font-serif text-3xl font-bold text-white sm:text-4xl lg:text-5xl">
        {brand.cta.heading}
      </h2>
    </div>
    <div class="animate-on-scroll" style="transition-delay: 0.1s">
      <p class="mt-5 text-base text-white/70 font-light">{brand.cta.subheading}</p>
    </div>
    <div class="animate-on-scroll mt-10" style="transition-delay: 0.2s">
      <a href={brand.cta.buttonLink} class="inline-flex items-center gap-2 bg-white px-8 py-4 font-serif text-sm font-semibold tracking-wide transition-all hover:-translate-y-0.5 hover:shadow-lg" style={`color: ${brand.colors.primary}`}>
        {brand.cta.buttonText}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
