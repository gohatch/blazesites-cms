---
import brand from '../../brand.json';
---
<section id="testimonials" class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <div class="ornament mb-4">
        <span class="text-xs font-medium uppercase tracking-[0.25em]" style={`color: ${brand.colors.primary}`}>Testimonials</span>
      </div>
      <h2 class="font-serif text-3xl font-bold sm:text-4xl" style={`color: ${brand.colors.textDark}`}>
        What Our <em>Clients Say</em>
      </h2>
    </div>

    <div class="stagger-children mt-14 grid gap-8 md:grid-cols-3">
      {brand.testimonials.map((t) => (
        <div class="card-hover rounded-sm bg-white p-8 shadow-sm border" style={`border-color: ${brand.colors.border}`}>
          <!-- Stars -->
          <div class="flex gap-0.5">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="h-4 w-4" style={`color: ${brand.colors.primary}`} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <p class="mt-5 text-sm leading-relaxed font-light italic" style={`color: ${brand.colors.textLight}`}>
            "{t.quote}"
          </p>

          <div class="mt-6 flex items-center gap-3 border-t pt-5" style={`border-color: ${brand.colors.border}`}>
            {t.image && (
              <img src={t.image} alt={t.author} class="h-11 w-11 rounded-full object-cover" loading="lazy" />
            )}
            <div>
              <p class="font-serif text-sm font-semibold" style={`color: ${brand.colors.textDark}`}>{t.author}</p>
              <p class="text-xs font-light" style={`color: ${brand.colors.textLight}`}>{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
