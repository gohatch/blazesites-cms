---
import brand from '../../brand.json';
---
<section id="services" class="section-padding" style={`background-color: ${brand.colors.cream}`}>
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <div class="ornament mb-4">
        <span class="text-xs font-medium uppercase tracking-[0.25em]" style={`color: ${brand.colors.primary}`}>What We Offer</span>
      </div>
      <h2 class="font-serif text-3xl font-bold sm:text-4xl lg:text-5xl" style={`color: ${brand.colors.textDark}`}>
        Our <em>Services</em>
      </h2>
      <p class="mt-4 text-base font-light" style={`color: ${brand.colors.textLight}`}>
        Curated beauty experiences designed to pamper, transform, and inspire.
      </p>
    </div>

    <div class="stagger-children mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {brand.services.map((service) => (
        <div class="card-hover group overflow-hidden bg-white">
          <!-- Service image -->
          <div class="relative h-56 overflow-hidden">
            <img
              src={service.image}
              alt={service.title}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
          </div>
          <!-- Content -->
          <div class="p-7">
            <h3 class="font-serif text-xl font-semibold" style={`color: ${brand.colors.textDark}`}>
              {service.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed font-light" style={`color: ${brand.colors.textLight}`}>
              {service.description}
            </p>
            <a href="#contact" class="mt-5 inline-flex items-center gap-2 text-sm font-medium transition-colors" style={`color: ${brand.colors.primary}`}>
              Book Now
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
