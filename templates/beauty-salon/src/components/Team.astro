---
import brand from '../../brand.json';
---
<section id="team" class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <div class="ornament mb-4">
        <span class="text-xs font-medium uppercase tracking-[0.25em]" style={`color: ${brand.colors.primary}`}>Our Experts</span>
      </div>
      <h2 class="font-serif text-3xl font-bold sm:text-4xl" style={`color: ${brand.colors.textDark}`}>
        Meet the <em>Team</em>
      </h2>
    </div>

    <div class="stagger-children mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {brand.team.map((member) => (
        <div class="group text-center">
          <div class="relative mx-auto h-72 w-full max-w-[260px] overflow-hidden rounded-sm">
            <img
              src={member.image}
              alt={member.name}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
          </div>
          <h3 class="mt-5 font-serif text-lg font-semibold" style={`color: ${brand.colors.textDark}`}>
            {member.name}
          </h3>
          <p class="mt-1 text-sm font-light" style={`color: ${brand.colors.primary}`}>
            {member.role}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
