---
import brand from '../../brand.json';

const avatars = [
  'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=80&h=80&fit=crop',
  'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=80&h=80&fit=crop',
  'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=80&h=80&fit=crop',
];
---

<section class="relative min-h-screen flex items-center pt-24 pb-0 overflow-hidden">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img
      src={brand.heroImage}
      alt="Gym interior"
      class="w-full h-full object-cover opacity-20"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg)] via-[var(--color-bg)]/80 to-[var(--color-bg)]"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="fade-up section-label mb-6">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
        </svg>
        Start Your Journey
      </div>

      <!-- Heading -->
      <h1 class="fade-up fade-up-delay-1 text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.08] mb-6" style="font-family: var(--font-clash);">
        Transform Your <br/>
        <span class="text-[var(--color-accent)]">Body</span> Unleash <br/>
        Your <span class="text-[var(--color-accent)]">Potential</span>
      </h1>

      <!-- Description -->
      <p class="fade-up fade-up-delay-2 text-lg text-[var(--color-text-light)] max-w-lg mb-8 leading-relaxed">
        Join our state-of-the-art facility with expert trainers, diverse classes, and a supportive community ready to help you achieve your fitness goals.
      </p>

      <!-- Buttons -->
      <div class="fade-up fade-up-delay-3 flex flex-wrap items-center gap-4 mb-10">
        <a href="#contact" class="btn-primary">
          Contact Us
        </a>
        <a href="#classes" class="btn-outline">
          View our Classes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Trust badge -->
      <div class="fade-up fade-up-delay-4 flex items-center gap-4">
        <div class="flex -space-x-2">
          {avatars.map((src) => (
            <img
              src={src}
              alt="Member"
              class="w-9 h-9 rounded-full border-2 border-[var(--color-bg)] object-cover"
            />
          ))}
        </div>
        <div class="flex items-center gap-2">
          <div class="flex gap-0.5">
            {[...Array(5)].map(() => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#C8FF00" stroke="none">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>
          <span class="text-sm font-medium text-white">5.0</span>
          <span class="text-sm text-[var(--color-text-light)]">Trusted by 15+ Members</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom highlights strip -->
  <div class="absolute bottom-0 left-0 right-0 z-10 border-t border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur-sm">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-[var(--color-border)]">
        {brand.highlights.map((item) => (
          <div class="flex items-center gap-3 py-5 md:px-6 first:md:pl-0">
            <div class="w-10 h-10 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center flex-shrink-0">
              {item.icon === 'clock' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C8FF00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
              )}
              {item.icon === 'grid' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C8FF00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                </svg>
              )}
              {item.icon === 'users' && (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C8FF00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
              )}
            </div>
            <span class="text-sm font-medium text-white">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
