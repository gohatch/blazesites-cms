---
import brand from '../../brand.json';
---

<section id="contact" class="section-padding">
  <div class="container mx-auto">
    <div class="card p-10 md:p-14 text-center relative overflow-hidden fade-up">
      <!-- Subtle accent glow -->
      <div class="absolute -top-20 -right-20 w-60 h-60 bg-[var(--color-accent)]/5 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-20 -left-20 w-60 h-60 bg-[var(--color-accent)]/5 rounded-full blur-3xl pointer-events-none"></div>

      <!-- Dumbbell icon -->
      <div class="w-14 h-14 rounded-2xl bg-[var(--color-accent)]/10 flex items-center justify-center mx-auto mb-6">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C8FF00" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6.5 6.5h11M6.5 17.5h11M3 10h2v4H3zM19 10h2v4h-2zM5 8h2v8H5zM17 8h2v8h-2zM7 11h10v2H7z"/>
        </svg>
      </div>

      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4" style="font-family: var(--font-clash);">
        {brand.cta.heading}
      </h2>

      <p class="text-[var(--color-text-light)] max-w-lg mx-auto mb-8 leading-relaxed">
        {brand.cta.description}
      </p>

      <a href={brand.cta.buttonLink} class="btn-primary">
        {brand.cta.buttonText}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>
