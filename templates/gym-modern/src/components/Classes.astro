---
import brand from '../../brand.json';
---

<section id="classes" class="section-padding">
  <div class="container mx-auto">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
      <div class="fade-up">
        <div class="section-label">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
          </svg>
          Our Classes
        </div>
        <h2 class="section-title">What we Offer</h2>
        <p class="section-desc">
          From high-intensity training to mindful yoga, we have a class for every fitness level and goal.
        </p>
      </div>

      <!-- Navigation arrows -->
      <div class="flex gap-3 fade-up">
        <button id="classes-prev" class="w-11 h-11 rounded-full border border-[var(--color-border)] flex items-center justify-center hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-all" aria-label="Previous">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
        </button>
        <button id="classes-next" class="w-11 h-11 rounded-full border border-[var(--color-border)] flex items-center justify-center hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-all" aria-label="Next">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Classes scroll container -->
    <div id="classes-scroll" class="scroll-container fade-up">
      {brand.classes.map((cls) => (
        <div class="relative w-64 md:w-72 h-80 rounded-2xl overflow-hidden group cursor-pointer flex-shrink-0 accent-glow">
          <img
            src={cls.image}
            alt={cls.title}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 right-0 p-5">
            <h3 class="text-lg font-semibold text-white" style="font-family: var(--font-clash);">{cls.title}</h3>
          </div>
          <!-- Hover accent line -->
          <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-[var(--color-accent)] transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const scroll = document.getElementById('classes-scroll');
  const prev = document.getElementById('classes-prev');
  const next = document.getElementById('classes-next');

  const scrollAmount = 300;

  prev?.addEventListener('click', () => {
    scroll?.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
  });

  next?.addEventListener('click', () => {
    scroll?.scrollBy({ left: scrollAmount, behavior: 'smooth' });
  });
</script>
