---
import brand from '../../brand.json';
---

<section id="pricing" class="section-padding">
  <div class="container mx-auto">
    <!-- Header -->
    <div class="text-center mb-12 fade-up">
      <div class="section-label mx-auto w-fit">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
        Pricing
      </div>
      <h2 class="section-title">Flexible Plans for<br/> Every Goal</h2>
      <p class="section-desc mx-auto">
        Choose the plan that fits your lifestyle. No hidden fees, cancel anytime.
      </p>
    </div>

    <!-- Toggle -->
    <div class="flex justify-center mb-10 fade-up">
      <div class="toggle-wrapper">
        <button class="toggle-option active">Monthly</button>
        <button class="toggle-option">Yearly</button>
      </div>
    </div>

    <!-- Pricing cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
      {brand.pricing.map((plan, i) => (
        <div class={`card p-7 flex flex-col fade-up fade-up-delay-${i + 1} ${plan.popular ? 'border-[var(--color-accent)]/30' : ''}`}>
          {plan.popular && (
            <div class="inline-flex items-center gap-1.5 text-xs font-semibold text-[var(--color-bg)] bg-[var(--color-accent)] px-3 py-1 rounded-full w-fit mb-4">
              Most Popular
            </div>
          )}

          <h3 class="text-xl font-semibold text-white mb-2" style="font-family: var(--font-clash);">{plan.name}</h3>

          <div class="flex items-baseline gap-1 mb-6">
            <span class="text-4xl font-bold text-white" style="font-family: var(--font-clash);">{plan.price}</span>
            <span class="text-[var(--color-text-light)] text-sm">{plan.period}</span>
          </div>

          <ul class="space-y-3.5 mb-8 flex-grow">
            {plan.features.map((feature) => (
              <li class="flex items-center gap-3 text-sm text-[var(--color-text-light)]">
                <div class="w-5 h-5 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center flex-shrink-0">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#C8FF00" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </div>
                {feature}
              </li>
            ))}
          </ul>

          <a
            href="#contact"
            class={plan.popular ? 'btn-primary w-full justify-center' : 'btn-outline w-full justify-center'}
          >
            Join Now
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
