---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import brand from '../../brand.json';
---
<Layout title="Services" description={`Construction services by ${brand.businessName}`}>
  <Header />
  <Hero
    heading="Our Services"
    subheading="From foundations to finishing touches — comprehensive construction solutions tailored to your project."
    ctaText="Get a Quote"
    ctaLink="/contact"
  />
  <Features heading="What We Build" subheading="Every project receives our full attention, expertise, and commitment to excellence" />
  <Testimonials />
  <CTA />
  <Footer />
</Layout>
