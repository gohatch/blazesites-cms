---
import brand from '../../brand.json';

interface Props {
  heading?: string;
  subheading?: string;
}

const {
  heading = 'Our Services',
  subheading = 'Comprehensive construction solutions from concept to completion',
} = Astro.props;

const iconPaths: Record<string, string> = {
  home: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  building: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  hammer: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z',
  clipboard: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
};
---
<section class="section-padding" style={`background-color: ${brand.colors.light}`}>
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <p class="text-sm font-bold uppercase tracking-widest" style={`color: ${brand.colors.accent}`}>What We Do</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">{heading}</h2>
      <p class="mt-4 text-lg" style={`color: ${brand.colors.textLight}`}>{subheading}</p>
    </div>

    <div class="stagger-children mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {brand.services.map((service, i) => (
        <div class="card-hover rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
          <div class="icon-box">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[service.icon] || iconPaths.building} />
            </svg>
          </div>
          <h3 class="mt-6 text-lg font-bold">{service.title}</h3>
          <p class="mt-2 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>{service.description}</p>
          <a href="/services" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors" style={`color: ${brand.colors.accent}`}>
            Learn more
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
