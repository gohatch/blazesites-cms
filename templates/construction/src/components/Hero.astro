---
import brand from '../../brand.json';

interface Props {
  heading?: string;
  subheading?: string;
  ctaText?: string;
  ctaLink?: string;
  image?: string;
  overlay?: boolean;
}

const {
  heading = brand.tagline,
  subheading = brand.description,
  ctaText = 'Get a Free Quote',
  ctaLink = '/contact',
  image = brand.heroImage,
  overlay = true,
} = Astro.props;
---
<section
  class="parallax-bg gradient-overlay relative flex min-h-[90vh] items-center"
  style={image ? `background-image: url(${image})` : `background-color: ${brand.colors.primary}`}
>
  <div class="relative z-10 mx-auto w-full max-w-7xl px-6 pt-24">
    <div class="max-w-3xl">
      <div class="hero-animate hero-animate-1">
        <div
          class="mb-6 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-white/90 backdrop-blur-sm"
        >
          <span class="inline-block h-2 w-2 rounded-full" style={`background-color: ${brand.colors.accent}`}></span>
          Trusted by 500+ clients
        </div>
      </div>

      <h1 class="hero-animate hero-animate-2 text-4xl font-extrabold leading-[1.08] tracking-tight text-white sm:text-5xl md:text-6xl lg:text-7xl" style="text-shadow: 0 2px 20px rgba(0,0,0,0.3)">
        {heading}
      </h1>

      <p class="hero-animate hero-animate-3 mt-6 max-w-xl text-lg leading-relaxed text-white/80 sm:text-xl">
        {subheading}
      </p>

      <div class="hero-animate hero-animate-4 mt-10 flex flex-col gap-4 sm:flex-row sm:items-center">
        <a href={ctaLink} class="btn-accent text-center">
          {ctaText}
          <svg class="ml-2 -mr-1 inline h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        {brand.contact.phone && (
          <a href={`tel:${brand.contact.phone}`} class="flex items-center gap-2 text-sm font-medium text-white/70 transition-colors hover:text-white">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call {brand.contact.phone}
          </a>
        )}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 z-10 -translate-x-1/2 animate-bounce">
    <svg class="h-6 w-6 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
