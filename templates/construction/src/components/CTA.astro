---
import brand from '../../brand.json';

interface Props {
  heading?: string;
  subheading?: string;
  ctaText?: string;
  ctaLink?: string;
}

const {
  heading = brand.cta.heading,
  subheading = brand.cta.subheading,
  ctaText = brand.cta.buttonText,
  ctaLink = brand.cta.buttonLink,
} = Astro.props;
---
<section
  class="relative overflow-hidden py-24 text-center sm:py-32"
  style={`background-color: ${brand.colors.primary}`}
>
  <!-- Decorative accent circles -->
  <div class="absolute -left-20 -top-20 h-72 w-72 rounded-full opacity-10" style={`background-color: ${brand.colors.accent}`}></div>
  <div class="absolute -bottom-16 -right-16 h-56 w-56 rounded-full opacity-10" style={`background-color: ${brand.colors.accent}`}></div>

  <div class="relative z-10 mx-auto max-w-3xl px-6">
    <div class="animate-on-scroll">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl md:text-5xl text-balance">
        {heading}
      </h2>
    </div>
    <div class="animate-on-scroll" style="transition-delay: 0.1s">
      <p class="mt-5 text-lg text-white/70">{subheading}</p>
    </div>
    <div class="animate-on-scroll mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center" style="transition-delay: 0.2s">
      <a href={ctaLink} class="btn-accent text-center">
        {ctaText}
        <svg class="ml-2 -mr-1 inline h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      {brand.contact.phone && (
        <a href={`tel:${brand.contact.phone}`} class="btn-outline border-white/20 !text-white/80 hover:!bg-white/10 hover:!text-white">
          Call Us Today
        </a>
      )}
    </div>
  </div>
</section>
