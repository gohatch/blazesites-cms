---
import brand from '../../brand.json';

interface Props {
  heading?: string;
  text?: string;
  image?: string;
}

const {
  heading = brand.about.heading,
  text = brand.about.text,
  image = brand.aboutImage,
} = Astro.props;
---
<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">
      <!-- Text -->
      <div class="animate-on-scroll from-left">
        <p class="text-sm font-bold uppercase tracking-widest" style={`color: ${brand.colors.accent}`}>About Us</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">{heading}</h2>
        <p class="mt-6 text-lg leading-relaxed" style={`color: ${brand.colors.textLight}`}>{text}</p>

        {brand.about.values && (
          <div class="mt-8 grid grid-cols-2 gap-3">
            {brand.about.values.map(value => (
              <div class="flex items-center gap-3">
                <div class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full" style={`background-color: ${brand.colors.accentLight}`}>
                  <svg class="h-3.5 w-3.5" style={`color: ${brand.colors.accent}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-sm font-medium">{value}</span>
              </div>
            ))}
          </div>
        )}

        <a href="/about" class="btn-accent mt-8 inline-block">
          More About Us
          <svg class="ml-2 -mr-1 inline h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Image -->
      <div class="animate-on-scroll from-right">
        {image ? (
          <div class="relative">
            <img
              src={image}
              alt={heading}
              class="rounded-2xl object-cover shadow-2xl"
              style="aspect-ratio: 4/3"
              loading="lazy"
            />
            <!-- Decorative accent border -->
            <div
              class="absolute -bottom-4 -right-4 -z-10 h-full w-full rounded-2xl"
              style={`border: 3px solid ${brand.colors.accent}; opacity: 0.3`}
            ></div>
          </div>
        ) : (
          <div class="flex h-80 items-center justify-center rounded-2xl bg-gray-100">
            <p class="text-gray-400">Image placeholder</p>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
