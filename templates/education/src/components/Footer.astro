---
import brand from '../../brand.json';
---
<footer style={`background:${brand.colors.bgDark}`}>
  <div class="max-w-6xl mx-auto px-6 lg:px-8 py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mb-8">
      <a href="#" class="font-display text-xl text-white">{brand.name}</a>
      <div class="flex gap-5">
        {brand.footer.socials.map((s: any) => (
          <a href={s.href} class="text-xs font-medium text-white/40 hover:text-white transition-colors">{s.name}</a>
        ))}
      </div>
    </div>
    <div class="pt-6 flex flex-col sm:flex-row items-center justify-between gap-3" style="border-top:1px solid rgba(255,255,255,0.1)">
      <p class="text-xs text-white/30">&copy; {new Date().getFullYear()} {brand.name}. All rights reserved.</p>
      <p class="text-xs font-medium text-white/40">{brand.footer.tagline}</p>
    </div>
  </div>
</footer>
