---
import brand from '../../brand.json';
---
<section id="contact" class="section-padding" style={`background:${brand.colors.bg}`}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12">
      <div class="animate-on-scroll">
        <p class="text-xs font-semibold tracking-widest uppercase mb-2" style={`color:${brand.colors.primary}`}>Get in Touch</p>
        <h2 class="font-display text-3xl leading-tight mb-4" style={`color:${brand.colors.text}`}>{brand.contact.heading}</h2>
        <p class="text-sm font-light leading-relaxed mb-8" style={`color:${brand.colors.textMuted}`}>{brand.contact.subheading}</p>
        <div class="space-y-4">
          <div class="flex items-center gap-3"><span class="text-lg">📧</span><span class="text-sm" style={`color:${brand.colors.text}`}>{brand.email}</span></div>
          <div class="flex items-center gap-3"><span class="text-lg">📞</span><span class="text-sm" style={`color:${brand.colors.text}`}>{brand.phone}</span></div>
          <div class="flex items-center gap-3"><span class="text-lg">📍</span><span class="text-sm" style={`color:${brand.colors.text}`}>{brand.address}</span></div>
        </div>
      </div>
      <div class="animate-on-scroll">
        <form class="space-y-4 p-6 rounded-2xl" style={`background:${brand.colors.white}; border:1px solid ${brand.colors.border}`}>
          <div class="grid grid-cols-2 gap-3">
            <input type="text" placeholder="First Name" class="w-full px-4 py-3 rounded-xl text-sm outline-none" style={`background:${brand.colors.bg}; border:1px solid ${brand.colors.border}`} />
            <input type="text" placeholder="Last Name" class="w-full px-4 py-3 rounded-xl text-sm outline-none" style={`background:${brand.colors.bg}; border:1px solid ${brand.colors.border}`} />
          </div>
          <input type="email" placeholder="Email" class="w-full px-4 py-3 rounded-xl text-sm outline-none" style={`background:${brand.colors.bg}; border:1px solid ${brand.colors.border}`} />
          <select class="w-full px-4 py-3 rounded-xl text-sm outline-none appearance-none" style={`background:${brand.colors.bg}; border:1px solid ${brand.colors.border}; color:${brand.colors.textMuted}`}>
            <option value="">I'm interested in...</option>
            {brand.services.map((s: any) => <option value={s.name}>{s.name}</option>)}
          </select>
          <textarea rows={3} placeholder="Your message..." class="w-full px-4 py-3 rounded-xl text-sm outline-none resize-none" style={`background:${brand.colors.bg}; border:1px solid ${brand.colors.border}`}></textarea>
          <button type="submit" class="btn-primary w-full">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>
