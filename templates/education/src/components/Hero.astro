---
import brand from '../../brand.json';
---
<section class="relative pt-28 pb-16 overflow-hidden" style={`background:${brand.colors.bg}`}>
  <div class="absolute top-0 right-0 w-1/2 h-full opacity-5 pointer-events-none" style={`background:radial-gradient(circle at 80% 30%, ${brand.colors.primary}, transparent 60%)`}></div>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="hero-animate hero-animate-1 inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold mb-6" style={`background:${brand.colors.accent}20; color:${brand.colors.accent}`}>
          <span>🎓</span> {brand.hero.eyebrow}
        </div>
        <h1 class="hero-animate hero-animate-2 font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.1] mb-6" style={`color:${brand.colors.text}`}>
          Unlock your potential with <span style={`color:${brand.colors.primary}`}>expert-led</span> courses
        </h1>
        <p class="hero-animate hero-animate-3 text-base font-light leading-relaxed mb-8 max-w-lg" style={`color:${brand.colors.textMuted}`}>{brand.hero.subheading}</p>
        <div class="hero-animate hero-animate-4 flex flex-col sm:flex-row gap-3 mb-10">
          <a href="#courses" class="btn-primary">{brand.hero.cta}</a>
          <a href="#pricing" class="btn-outline">{brand.hero.ctaSecondary}</a>
        </div>
        <div class="hero-animate hero-animate-4 flex items-center gap-6">
          {brand.hero.stats.map((s: any) => (
            <div>
              <p class="font-display text-xl" style={`color:${brand.colors.text}`}>{s.value}</p>
              <p class="text-xs" style={`color:${brand.colors.textMuted}`}>{s.label}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="hero-animate hero-animate-3 relative">
        <div class="rounded-2xl overflow-hidden shadow-2xl" style={`box-shadow:0 24px 48px rgba(30,64,175,0.15)`}>
          <img src={brand.hero.image} alt="Students learning" class="w-full h-[400px] object-cover" />
        </div>
        <div class="absolute -bottom-4 -left-4 px-4 py-3 rounded-xl shadow-lg" style={`background:${brand.colors.white}; border:1px solid ${brand.colors.border}`}>
          <div class="flex items-center gap-2">
            <span class="text-xl">⭐</span>
            <div>
              <p class="text-sm font-bold" style={`color:${brand.colors.text}`}>4.9/5 Rating</p>
              <p class="text-xs" style={`color:${brand.colors.textMuted}`}>from 12K+ reviews</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
