---
import brand from '../../brand.json';
---
<section class="py-20" style={`background:${brand.colors.bgDark}`}>
  <div class="max-w-3xl mx-auto px-6 text-center animate-on-scroll">
    <span class="text-3xl mb-4 block">🚀</span>
    <h2 class="font-display text-3xl sm:text-4xl text-white leading-tight mb-4">{brand.cta.heading}</h2>
    <p class="text-sm font-light text-white/60 mb-8">{brand.cta.subheading}</p>
    <a href="#contact" class="btn-accent">{brand.cta.primary}</a>
  </div>
</section>
