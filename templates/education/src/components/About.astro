---
import brand from '../../brand.json';
---
<section id="about" class="section-padding" style={`background:${brand.colors.bg}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-14 items-center">
      <div class="animate-on-scroll">
        <div class="rounded-2xl overflow-hidden"><img src={brand.about.image} alt="Learning" class="w-full h-[400px] object-cover" /></div>
      </div>
      <div class="animate-on-scroll">
        <p class="text-xs font-semibold tracking-widest uppercase mb-2" style={`color:${brand.colors.primary}`}>Why LearnSpace</p>
        <h2 class="font-display text-3xl sm:text-4xl leading-tight mb-5" style={`color:${brand.colors.text}`}>{brand.about.heading}</h2>
        <p class="text-sm font-light leading-[1.8] mb-8" style={`color:${brand.colors.textMuted}`}>{brand.about.body}</p>
        <div class="grid grid-cols-2 gap-4 stagger-children">
          {brand.about.values.map((v: any) => (
            <div class="p-4 rounded-xl" style={`background:${brand.colors.white}; border:1px solid ${brand.colors.border}`}>
              <span class="text-2xl mb-2 block">{v.icon}</span>
              <h4 class="font-display text-sm mb-1" style={`color:${brand.colors.text}`}>{v.title}</h4>
              <p class="text-xs font-light" style={`color:${brand.colors.textMuted}`}>{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
