---
import brand from '../../brand.json';
---
<section id="about" class="section-padding" style={`background-color: ${brand.colors.cream}`}>
  <div class="mx-auto max-w-7xl">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">
      <!-- Left: Image -->
      <div class="animate-on-scroll from-left">
        <div class="relative overflow-hidden rounded-2xl">
          <img
            src={brand.aboutImage}
            alt="About our dental practice"
            class="h-[450px] w-full object-cover lg:h-[550px]"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Right: Content -->
      <div class="animate-on-scroll from-right">
        <div class="flex items-start gap-4">
          <h2 class="font-heading text-4xl leading-[0.95] tracking-tight sm:text-5xl" style={`color: ${brand.colors.primary}`}>
            {brand.about.heading}
          </h2>
          <!-- Decorative dental mirror icon -->
          <svg class="mt-2 h-12 w-12 flex-shrink-0 opacity-20" style={`color: ${brand.colors.primary}`} fill="currentColor" viewBox="0 0 24 24">
            <circle cx="12" cy="8" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12 14v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>

        <p class="mt-6 text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
          {brand.about.text}
        </p>

        <a href="#team" class="btn-outline mt-8">
          {brand.about.cta}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
