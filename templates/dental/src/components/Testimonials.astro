---
import brand from '../../brand.json';
---
<section id="testimonials" class="section-padding" style={`background-color: ${brand.colors.cream}`}>
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <p class="text-sm font-bold uppercase tracking-widest" style={`color: ${brand.colors.primary}`}>Testimonials</p>
      <h2 class="font-heading mt-3 text-3xl tracking-tight sm:text-4xl" style={`color: ${brand.colors.primary}`}>
        What Our Patients Say
      </h2>
    </div>

    <div class="stagger-children mt-14 grid gap-8 md:grid-cols-3">
      {brand.testimonials.map((t) => (
        <div class="card-hover relative rounded-2xl bg-white p-8 shadow-sm">
          <svg class="mb-4 h-8 w-8 opacity-20" style={`color: ${brand.colors.primary}`} fill="currentColor" viewBox="0 0 32 32">
            <path d="M10 8c-3.3 0-6 2.7-6 6v10h10V14H8c0-1.1.9-2 2-2V8zm14 0c-3.3 0-6 2.7-6 6v10h10V14h-6c0-1.1.9-2 2-2V8z" />
          </svg>

          <p class="text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
            "{t.quote}"
          </p>

          <div class="mt-6 flex items-center gap-3 border-t pt-4" style={`border-color: ${brand.colors.accentLight}`}>
            {t.image && (
              <img src={t.image} alt={t.author} class="h-10 w-10 rounded-full object-cover" loading="lazy" />
            )}
            <div>
              <p class="font-bold text-sm" style={`color: ${brand.colors.primary}`}>{t.author}</p>
              <p class="text-xs" style={`color: ${brand.colors.textLight}`}>{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
