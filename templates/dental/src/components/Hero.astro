---
import brand from '../../brand.json';
---
<section class="relative overflow-hidden pt-24 pb-0 lg:pt-28" style={`background: linear-gradient(180deg, #dce6f9 0%, ${brand.colors.bg} 100%)`}>
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid items-end gap-0 lg:grid-cols-2">
      <!-- Left: Text Content -->
      <div class="hero-animate hero-animate-1 pb-16 lg:pb-24">
        <h1 class="font-heading text-5xl leading-[0.95] tracking-tight sm:text-6xl lg:text-7xl" style={`color: ${brand.colors.primary}`}>
          {brand.tagline.split(',').map((part: string, i: number) => (
            <span class:list={[i > 0 && 'block']}>{part.trim()}{i === 0 ? ',' : ''}</span>
          ))}
        </h1>

        <div class="hero-animate hero-animate-2 mt-8">
          <a href="#contact" class="btn-outline">
            Book an Appointment
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <p class="hero-animate hero-animate-3 mt-12 max-w-md text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
          {brand.description}
        </p>
      </div>

      <!-- Right: Hero Image -->
      <div class="hero-animate hero-animate-2 relative flex justify-end">
        <div class="relative w-full max-w-lg overflow-hidden rounded-t-[2rem] lg:rounded-t-[3rem]">
          <img
            src={brand.heroImage}
            alt={brand.tagline}
            class="h-[400px] w-full object-cover object-top lg:h-[520px]"
          />
        </div>
      </div>
    </div>
  </div>
</section>
