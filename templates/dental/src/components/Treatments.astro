---
import brand from '../../brand.json';
---
<section id="treatments" class="section-padding" style={`background-color: ${brand.colors.bg}`}>
  <div class="mx-auto max-w-7xl">
    <!-- Header -->
    <div class="animate-on-scroll flex items-end justify-between">
      <div class="flex items-center gap-4">
        <!-- Decorative toothbrush -->
        <svg class="hidden sm:block h-16 w-16 -rotate-45 opacity-15" style={`color: ${brand.colors.primary}`} fill="currentColor" viewBox="0 0 24 24">
          <rect x="10" y="1" width="4" height="14" rx="2"/>
          <rect x="9" y="15" width="6" height="8" rx="1" fill="none" stroke="currentColor" stroke-width="1"/>
          <line x1="10" y1="17" x2="14" y2="17" stroke="currentColor" stroke-width="0.5"/>
          <line x1="10" y1="19" x2="14" y2="19" stroke="currentColor" stroke-width="0.5"/>
          <line x1="10" y1="21" x2="14" y2="21" stroke="currentColor" stroke-width="0.5"/>
        </svg>
        <h2 class="font-heading text-4xl tracking-tight sm:text-5xl" style={`color: ${brand.colors.primary}`}>
          Tailored Treatments
        </h2>
      </div>

      <!-- Navigation arrows -->
      <div class="hidden sm:flex items-center gap-2">
        <button id="treatments-prev" class="flex h-10 w-10 items-center justify-center rounded-full border-2 transition-colors hover:bg-white" style={`border-color: ${brand.colors.primary}; color: ${brand.colors.primary}`}>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button id="treatments-next" class="flex h-10 w-10 items-center justify-center rounded-full border-2 transition-colors hover:bg-white" style={`border-color: ${brand.colors.primary}; color: ${brand.colors.primary}`}>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Treatment cards - horizontal scroll -->
    <div id="treatments-scroll" class="stagger-children mt-10 flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide" style="-ms-overflow-style: none; scrollbar-width: none;">
      {brand.services.map((service) => (
        <div class="min-w-[300px] max-w-[340px] flex-shrink-0 snap-start rounded-2xl bg-white p-8 shadow-sm transition-all hover:shadow-md">
          <span class="inline-block rounded-full px-4 py-1.5 text-[11px] font-semibold" style={`background-color: ${brand.colors.accentLight}; color: ${brand.colors.primary}`}>
            Book Appointment
          </span>
          <h3 class="font-heading mt-5 text-xl tracking-tight" style={`color: ${brand.colors.primary}`}>
            {service.title}
          </h3>
          <p class="mt-3 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>
            {service.description}
          </p>
          {service.image && (
            <div class="mt-5 flex justify-end">
              <img src={service.image} alt={service.title} class="h-16 w-16 rounded-xl object-cover opacity-70" loading="lazy" />
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #treatments-scroll::-webkit-scrollbar { display: none; }
</style>

<script>
  const scroll = document.getElementById('treatments-scroll')!;
  const prev = document.getElementById('treatments-prev');
  const next = document.getElementById('treatments-next');
  const cardWidth = 340 + 24; // card + gap

  prev?.addEventListener('click', () => {
    scroll.scrollBy({ left: -cardWidth, behavior: 'smooth' });
  });
  next?.addEventListener('click', () => {
    scroll.scrollBy({ left: cardWidth, behavior: 'smooth' });
  });
</script>
