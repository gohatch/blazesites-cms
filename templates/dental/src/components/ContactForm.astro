---
import brand from '../../brand.json';
---
<section id="contact" class="section-padding bg-white">
  <div class="mx-auto max-w-3xl">
    <div class="animate-on-scroll mx-auto max-w-xl text-center">
      <p class="text-sm font-bold uppercase tracking-widest" style={`color: ${brand.colors.primary}`}>Contact</p>
      <h2 class="font-heading mt-3 text-3xl tracking-tight sm:text-4xl" style={`color: ${brand.colors.primary}`}>
        Book Your Visit
      </h2>
      <p class="mt-4 text-base" style={`color: ${brand.colors.textLight}`}>
        Tell us about your dental needs and we'll get back to you within 24 hours.
      </p>
    </div>

    <div class="animate-on-scroll mt-12">
      <form class="rounded-2xl border bg-white p-8 shadow-lg sm:p-10" style={`border-color: ${brand.colors.accentLight}`} onsubmit="event.preventDefault()">
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-semibold" style={`color: ${brand.colors.primary}`}>Full Name</label>
            <input
              type="text"
              placeholder="John Smith"
              class="w-full rounded-xl border-2 p-3.5 text-sm transition-colors focus:outline-none"
              style={`border-color: ${brand.colors.accentLight}`}
              onfocus={`this.style.borderColor='${brand.colors.primary}'`}
              onblur={`this.style.borderColor='${brand.colors.accentLight}'`}
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold" style={`color: ${brand.colors.primary}`}>Email</label>
            <input
              type="email"
              placeholder="john@example.com"
              class="w-full rounded-xl border-2 p-3.5 text-sm transition-colors focus:outline-none"
              style={`border-color: ${brand.colors.accentLight}`}
              onfocus={`this.style.borderColor='${brand.colors.primary}'`}
              onblur={`this.style.borderColor='${brand.colors.accentLight}'`}
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold" style={`color: ${brand.colors.primary}`}>Phone</label>
            <input
              type="tel"
              placeholder="(555) 123-4567"
              class="w-full rounded-xl border-2 p-3.5 text-sm transition-colors focus:outline-none"
              style={`border-color: ${brand.colors.accentLight}`}
              onfocus={`this.style.borderColor='${brand.colors.primary}'`}
              onblur={`this.style.borderColor='${brand.colors.accentLight}'`}
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold" style={`color: ${brand.colors.primary}`}>Treatment</label>
            <select
              class="w-full rounded-xl border-2 p-3.5 text-sm transition-colors focus:outline-none"
              style={`border-color: ${brand.colors.accentLight}`}
              onfocus={`this.style.borderColor='${brand.colors.primary}'`}
              onblur={`this.style.borderColor='${brand.colors.accentLight}'`}
            >
              <option value="">Select a treatment</option>
              {brand.services.map(s => (
                <option value={s.title}>{s.title}</option>
              ))}
            </select>
          </div>
        </div>
        <div class="mt-6">
          <label class="mb-2 block text-sm font-semibold" style={`color: ${brand.colors.primary}`}>Additional Details</label>
          <textarea
            rows="4"
            placeholder="Tell us about your dental needs..."
            class="w-full rounded-xl border-2 p-3.5 text-sm transition-colors focus:outline-none"
            style={`border-color: ${brand.colors.accentLight}`}
            onfocus={`this.style.borderColor='${brand.colors.primary}'`}
            onblur={`this.style.borderColor='${brand.colors.accentLight}'`}
          ></textarea>
        </div>
        <button type="submit" class="btn-primary mt-6 w-full justify-center py-4">
          Book Appointment
        </button>
        <p class="mt-3 text-center text-xs" style={`color: ${brand.colors.textLight}`}>
          We'll respond within 24 hours. No spam, ever.
        </p>
      </form>
    </div>
  </div>
</section>
