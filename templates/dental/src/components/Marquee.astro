---
import brand from '../../brand.json';
const items = brand.marqueeServices;
---
<section class="overflow-hidden py-5" style={`background-color: ${brand.colors.primary}`}>
  <div class="relative flex whitespace-nowrap">
    <div class="marquee-track flex items-center gap-0">
      {[...items, ...items].map((service) => (
        <span class="flex items-center gap-6 px-6 text-sm font-bold uppercase tracking-widest text-white">
          {service}
          <svg class="tooth-icon opacity-50" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C9.5 2 7.5 3.5 7 6c-.3 1.5-.5 3-1.5 4.5C4 12.5 3 15 4 17.5s3 3.5 4.5 2c1-.8 1.5-2.5 2-4 .3-1 .8-1.5 1.5-1.5s1.2.5 1.5 1.5c.5 1.5 1 3.2 2 4 1.5 1.5 3.5.5 4.5-2s0-5-1.5-7C17.5 9 17.3 7.5 17 6c-.5-2.5-2.5-4-5-4z"/>
          </svg>
        </span>
      ))}
    </div>
  </div>
</section>
