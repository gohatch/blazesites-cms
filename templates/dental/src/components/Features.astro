---
import brand from '../../brand.json';
---
<section id="features" class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <p class="text-sm font-bold uppercase tracking-widest" style={`color: ${brand.colors.primary}`}>Our Services</p>
      <h2 class="font-heading mt-3 text-3xl tracking-tight sm:text-4xl" style={`color: ${brand.colors.primary}`}>
        Complete Dental Care
      </h2>
      <p class="mt-4 text-base" style={`color: ${brand.colors.textLight}`}>
        From routine cleanings to advanced procedures, we deliver exceptional dental services for the whole family.
      </p>
    </div>

    <div class="stagger-children mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {brand.services.map((service) => (
        <div class="card-hover rounded-2xl border bg-white p-7 shadow-sm" style={`border-color: ${brand.colors.accentLight}`}>
          <div class="flex h-12 w-12 items-center justify-center rounded-xl" style={`background-color: ${brand.colors.accentLight}`}>
            <svg class="h-6 w-6" style={`color: ${brand.colors.primary}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold" style={`color: ${brand.colors.primary}`}>{service.title}</h3>
          <p class="mt-2 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
