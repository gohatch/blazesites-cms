---
import brand from '../../brand.json';

const iconSvgs: Record<string, string> = {
  heart: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
  hands: 'M7 11.5V14m0 0v2.5M7 14h2.5M7 14H4.5m4.5-4V7.5M9 10h2.5M9 10H6.5M17 11.5V14m0 0v2.5m0-2.5h2.5M17 14h-2.5m4.5-4V7.5M19 10h-2.5M19 10h2.5M12 21a9 9 0 110-18 9 9 0 010 18z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
};
---
<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="grid items-start gap-16 lg:grid-cols-2">
      <!-- Left: Heading -->
      <div class="animate-on-scroll from-left">
        <span class="badge-green">
          Why Choose Us
        </span>
        <h2 class="mt-5 text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl lg:text-5xl" style={`color: ${brand.colors.text}`}>
          Why Choose
          <span style="font-family: 'Playfair Display', serif; font-style: italic; color: var(--color-primary)"> {brand.businessName} </span>
          For Your Recovery
        </h2>
        <p class="mt-6 text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
          {brand.about.text}
        </p>

        <!-- Image -->
        <div class="mt-8 overflow-hidden rounded-2xl">
          <img
            src={brand.aboutImage}
            alt="Why choose us"
            class="h-[300px] w-full object-cover"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Right: Features -->
      <div class="stagger-children space-y-8 lg:pt-12">
        {brand.whyUs.map((item) => (
          <div class="flex gap-5">
            <!-- Icon Circle -->
            <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full" style={`background-color: ${brand.colors.light}; border: 2px solid rgba(27, 94, 32, 0.12)`}>
              <svg class="h-6 w-6" style={`color: ${brand.colors.primary}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconSvgs[item.icon] || iconSvgs.heart} />
              </svg>
            </div>
            <!-- Text -->
            <div>
              <h3 class="text-lg font-bold" style={`color: ${brand.colors.text}`}>{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
