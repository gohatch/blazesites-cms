---
import brand from '../../brand.json';
---
<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md shadow-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2">
      <svg class="h-7 w-7" style={`color: ${brand.colors.primary}`} fill="currentColor" viewBox="0 0 24 24">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
      <span class="text-xl font-extrabold tracking-tight" style={`color: ${brand.colors.text}`}>
        {brand.businessName}
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden items-center gap-8 lg:flex">
      {brand.nav.map(link => (
        <a href={link.href} class="text-sm font-medium transition-colors hover:opacity-70" style={`color: ${brand.colors.text}`}>
          {link.label}
        </a>
      ))}
      <a href="/contact" class="btn-accent !py-2.5 !px-6 !text-sm !rounded-full">
        Get Started
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button class="lg:hidden" id="mobile-menu-btn" aria-label="Menu" style={`color: ${brand.colors.text}`}>
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="hidden border-t border-gray-100 bg-white lg:hidden" id="mobile-menu">
    <div class="flex flex-col gap-1 px-6 py-4">
      {brand.nav.map(link => (
        <a href={link.href} class="rounded-lg px-4 py-3 text-sm font-medium transition-colors hover:bg-gray-50" style={`color: ${brand.colors.text}`}>
          {link.label}
        </a>
      ))}
      <a href="/contact" class="btn-accent mt-2 text-center !text-sm">
        Get Started
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  btn.addEventListener('click', () => menu.classList.toggle('hidden'));
</script>
