---
import brand from '../../brand.json';
---
<section class="section-padding bg-white">
  <div class="mx-auto max-w-5xl px-6">
    <div class="animate-on-scroll relative overflow-hidden rounded-3xl px-8 py-16 text-center sm:px-16 sm:py-20" style={`background-color: ${brand.colors.primary}`}>
      <!-- Decorative circles -->
      <div class="absolute -left-12 -top-12 h-48 w-48 rounded-full opacity-10" style={`background-color: ${brand.colors.accent}`}></div>
      <div class="absolute -bottom-8 -right-8 h-36 w-36 rounded-full opacity-10" style={`background-color: ${brand.colors.accent}`}></div>

      <div class="relative z-10">
        <h2 class="mx-auto max-w-2xl text-2xl font-extrabold tracking-tight text-white sm:text-3xl lg:text-4xl text-balance">
          {brand.cta.heading}
        </h2>

        <!-- Email Input + Button -->
        <form class="mx-auto mt-10 flex max-w-md flex-col gap-3 sm:flex-row" onsubmit="event.preventDefault()">
          <input
            type="email"
            placeholder="Enter your email address"
            class="flex-1 rounded-full border-2 border-white/20 bg-white/10 px-5 py-3.5 text-sm text-white placeholder-white/50 backdrop-blur-sm focus:border-white/40 focus:outline-none"
          />
          <button type="submit" class="btn-accent !rounded-full whitespace-nowrap">
            {brand.cta.buttonText}
            <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
