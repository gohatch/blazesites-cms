---
import brand from '../../brand.json';
---
<section class="relative overflow-hidden pt-24 pb-0 lg:pt-28 lg:pb-0">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left: Text Content -->
      <div class="hero-animate hero-animate-1 py-12 lg:py-20">
        <!-- Badge -->
        <span class="badge-green">
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
          Feel Better, Move Freely, Live Fully
        </span>

        <!-- Heading -->
        <h1 class="mt-6 text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-[3.5rem]" style={`color: ${brand.colors.text}`}>
          {brand.tagline.split(',')[0]},
          <span style="font-family: 'Playfair Display', serif; font-style: italic; color: var(--color-primary)">
            {brand.tagline.split(',').slice(1).join(',')}
          </span>
        </h1>

        <!-- Description -->
        <p class="mt-6 max-w-lg text-lg leading-relaxed" style={`color: ${brand.colors.textLight}`}>
          {brand.description}
        </p>

        <!-- CTA Button -->
        <div class="mt-8">
          <a href="/contact" class="btn-accent text-center">
            Book an Appointment
            <svg class="ml-1 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Stats Row -->
        <div class="hero-animate hero-animate-3 mt-12 flex flex-wrap gap-8 border-t border-gray-100 pt-8">
          {brand.stats.map((stat) => (
            <div class="text-center sm:text-left">
              <p class="text-3xl font-extrabold" style={`color: ${brand.colors.primary}`}>{stat.value}</p>
              <p class="mt-1 text-xs font-medium" style={`color: ${brand.colors.textLight}`}>{stat.label}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Image Collage -->
      <div class="hero-animate hero-animate-2 relative hidden lg:block">
        <div class="relative h-[580px]">
          <!-- Main large image -->
          <div class="absolute top-0 right-0 w-[75%] overflow-hidden rounded-3xl shadow-2xl">
            <img
              src={brand.heroImage}
              alt={brand.tagline}
              class="h-[400px] w-full object-cover"
            />
          </div>
          <!-- Overlapping second image -->
          <div class="absolute bottom-0 left-0 w-[60%] overflow-hidden rounded-3xl shadow-2xl border-4 border-white">
            <img
              src={brand.heroImage2}
              alt="Physiotherapy treatment"
              class="h-[300px] w-full object-cover"
            />
          </div>
          <!-- Decorative accent dot -->
          <div class="absolute top-8 left-12 h-16 w-16 rounded-full opacity-20" style={`background-color: ${brand.colors.accent}`}></div>
          <div class="absolute bottom-20 right-4 h-10 w-10 rounded-full opacity-15" style={`background-color: ${brand.colors.primary}`}></div>
        </div>
      </div>

      <!-- Mobile single image fallback -->
      <div class="hero-animate hero-animate-2 lg:hidden -mt-4">
        <div class="overflow-hidden rounded-2xl shadow-xl">
          <img
            src={brand.heroImage}
            alt={brand.tagline}
            class="h-[350px] w-full object-cover"
          />
        </div>
      </div>
    </div>
  </div>
</section>
