---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.light}`}>
  <div class="mx-auto max-w-7xl">
    <!-- Section Header -->
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <span class="badge-green">
        Testimonials
      </span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight sm:text-4xl lg:text-5xl" style={`color: ${brand.colors.text}`}>
        What Our
        <span style="font-family: 'Playfair Display', serif; font-style: italic; color: var(--color-primary)"> Patients </span>
        Say
      </h2>
    </div>

    <!-- Testimonial Cards -->
    <div class="stagger-children mt-14 grid gap-8 md:grid-cols-2">
      {brand.testimonials.map((t) => (
        <div class="card-hover rounded-2xl bg-white p-8 shadow-sm">
          <!-- Star Rating -->
          <div class="flex gap-0.5">
            {[1,2,3,4,5].map(() => (
              <svg class="h-5 w-5" style={`color: ${brand.colors.accent}`} fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="mt-5 text-base leading-relaxed" style={`color: ${brand.colors.textLight}`}>
            "{t.quote}"
          </p>

          <!-- Author -->
          <div class="mt-6 flex items-center gap-3 border-t border-gray-100 pt-5">
            <div class="flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold text-white" style={`background-color: ${brand.colors.primary}`}>
              {t.author.charAt(0)}
            </div>
            <div>
              <p class="text-sm font-bold" style={`color: ${brand.colors.text}`}>{t.author}</p>
              <p class="text-xs" style={`color: ${brand.colors.textLight}`}>{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
