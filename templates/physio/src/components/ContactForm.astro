---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.primary}`}>
  <div class="mx-auto max-w-4xl">
    <div class="animate-on-scroll text-center">
      <!-- Badge -->
      <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-semibold text-white">
        <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
        </svg>
        Book an Appointment
      </span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Feel Better, Move Better.
        <span style="font-family: 'Playfair Display', serif; font-style: italic; display: block; margin-top: 0.25rem;">
          Reach Out To Us Today
        </span>
      </h2>
    </div>

    <!-- Form -->
    <div class="animate-on-scroll mt-12">
      <form class="rounded-2xl bg-white p-8 shadow-2xl sm:p-10" onsubmit="event.preventDefault()">
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-semibold" style={`color: ${brand.colors.text}`}>Full Name</label>
            <input
              type="text"
              placeholder="John Smith"
              class="w-full rounded-xl border-2 border-gray-200 p-3.5 text-sm transition-colors focus:outline-none"
              onfocus="this.style.borderColor='var(--color-primary)'"
              onblur="this.style.borderColor='#e5e7eb'"
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold" style={`color: ${brand.colors.text}`}>Phone</label>
            <input
              type="tel"
              placeholder="(555) 123-4567"
              class="w-full rounded-xl border-2 border-gray-200 p-3.5 text-sm transition-colors focus:outline-none"
              onfocus="this.style.borderColor='var(--color-primary)'"
              onblur="this.style.borderColor='#e5e7eb'"
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold" style={`color: ${brand.colors.text}`}>Last Name</label>
            <input
              type="text"
              placeholder="Smith"
              class="w-full rounded-xl border-2 border-gray-200 p-3.5 text-sm transition-colors focus:outline-none"
              onfocus="this.style.borderColor='var(--color-primary)'"
              onblur="this.style.borderColor='#e5e7eb'"
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold" style={`color: ${brand.colors.text}`}>Preferred Date</label>
            <input
              type="date"
              class="w-full rounded-xl border-2 border-gray-200 p-3.5 text-sm transition-colors focus:outline-none"
              onfocus="this.style.borderColor='var(--color-primary)'"
              onblur="this.style.borderColor='#e5e7eb'"
            />
          </div>
        </div>
        <div class="mt-6">
          <label class="mb-2 block text-sm font-semibold" style={`color: ${brand.colors.text}`}>Message</label>
          <textarea
            rows="4"
            placeholder="Tell us about your condition or needs..."
            class="w-full rounded-xl border-2 border-gray-200 p-3.5 text-sm transition-colors focus:outline-none"
            onfocus="this.style.borderColor='var(--color-primary)'"
            onblur="this.style.borderColor='#e5e7eb'"
          ></textarea>
        </div>
        <button type="submit" class="mt-6 w-full rounded-xl py-4 text-center text-sm font-bold text-white transition-all hover:opacity-90" style={`background-color: ${brand.colors.primary}`}>
          Send Message
          <svg class="ml-2 -mr-1 inline h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>
