---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.light}`}>
  <div class="mx-auto max-w-7xl">
    <!-- Section Header -->
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <span class="badge-green">
        <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        Our Services
      </span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight sm:text-4xl lg:text-5xl" style={`color: ${brand.colors.text}`}>
        Expert Physiotherapy <span style="font-family: 'Playfair Display', serif; font-style: italic; color: var(--color-primary)">Services</span>
      </h2>
    </div>

    <!-- Services Cards -->
    <div class="stagger-children mt-14 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {brand.services.map((service, i) => (
        <div class="card-hover group overflow-hidden rounded-2xl bg-white shadow-sm">
          <!-- Image -->
          <div class="relative overflow-hidden">
            <img
              src={service.image}
              alt={service.title}
              class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <!-- Number Badge -->
            <div class="absolute top-4 left-4 flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold text-white" style={`background-color: ${brand.colors.primary}`}>
              {String(i + 1).padStart(2, '0')}
            </div>
          </div>
          <!-- Content -->
          <div class="p-7">
            <h3 class="text-lg font-bold" style={`color: ${brand.colors.text}`}>{service.title}</h3>
            <p class="mt-2 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>{service.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="animate-on-scroll mt-14 flex flex-col items-center gap-4 text-center sm:flex-row sm:justify-center">
      <p class="text-lg font-semibold" style={`color: ${brand.colors.text}`}>
        Let's Make Everything Great Together
      </p>
      <a href="/services" class="inline-flex items-center gap-2 text-sm font-bold transition-colors hover:opacity-80" style={`color: ${brand.colors.primary}`}>
        View All Services
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
