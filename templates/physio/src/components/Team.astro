---
import brand from '../../brand.json';
---
<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <!-- Section Header -->
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <span class="badge-green">
        Our Team
      </span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight sm:text-4xl lg:text-5xl" style={`color: ${brand.colors.text}`}>
        A Team You Can Trust
        <span style="font-family: 'Playfair Display', serif; font-style: italic; color: var(--color-primary)"> With Your Health</span>
      </h2>
    </div>

    <!-- Team Members Row -->
    <div class="stagger-children mt-14 flex flex-wrap justify-center gap-8 lg:gap-12">
      {brand.team.map((member) => (
        <div class="flex flex-col items-center text-center">
          <!-- Circular Photo -->
          <div class="relative">
            <div class="h-36 w-36 overflow-hidden rounded-full border-4 shadow-lg" style={`border-color: ${brand.colors.light}`}>
              <img
                src={member.image}
                alt={member.name}
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </div>
            <!-- Online indicator dot -->
            <div class="absolute bottom-2 right-2 h-4 w-4 rounded-full border-2 border-white" style={`background-color: ${brand.colors.primary}`}></div>
          </div>
          <h3 class="mt-4 text-sm font-bold" style={`color: ${brand.colors.text}`}>{member.name}</h3>
          <p class="mt-1 text-xs font-semibold" style={`color: ${brand.colors.primary}`}>{member.role}</p>
        </div>
      ))}
    </div>
  </div>
</section>
