---
import brand from '../../brand.json';

const benefitIcons = [
  'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01',
  'M13 10V3L4 14h7v7l9-11h-7z',
  'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
  'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z',
  'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9',
];
---
<section class="section-padding" style={`background-color: ${brand.colors.light}`}>
  <div class="mx-auto max-w-7xl">
    <!-- Section Header -->
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <span class="badge-green">
        Our Benefits
      </span>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight sm:text-4xl lg:text-5xl" style={`color: ${brand.colors.text}`}>
        Discover The Life-Changing Power Of
        <span style="font-family: 'Playfair Display', serif; font-style: italic; color: var(--color-primary)"> Physiotherapy</span>
      </h2>
    </div>

    <!-- Benefits Grid: 2x3 -->
    <div class="stagger-children mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {brand.benefits.map((benefit, i) => (
        <div class="card-hover rounded-2xl bg-white p-8 shadow-sm">
          <!-- Icon Circle -->
          <div class="flex h-12 w-12 items-center justify-center rounded-full" style={`background-color: ${brand.colors.light}; border: 2px solid rgba(27, 94, 32, 0.1)`}>
            <svg class="h-5 w-5" style={`color: ${brand.colors.primary}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={benefitIcons[i] || benefitIcons[0]} />
            </svg>
          </div>
          <h3 class="mt-5 text-base font-bold" style={`color: ${brand.colors.text}`}>{benefit.title}</h3>
          <p class="mt-2 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
