---
import brand from '../../brand.json';
---
<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll grid gap-12 lg:grid-cols-2 lg:gap-24">
      <div>
        <p class="dot-marker text-sm font-medium">{brand.about.heading}</p>
      </div>
      <div>
        <p class="heading-serif text-2xl leading-relaxed sm:text-3xl">
          {brand.about.text}
        </p>
      </div>
    </div>
  </div>
</section>
