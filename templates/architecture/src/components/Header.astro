---
import brand from '../../brand.json';
---
<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
    <a href="/" class="text-base font-bold tracking-wider uppercase">
      {brand.businessName}
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {brand.nav.map(link => (
        <a href={link.href} class="text-sm transition-colors hover:opacity-60">
          {link.label}
        </a>
      ))}
      <a href="/contact" class="btn-pill">
        Get started
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </nav>

    <button class="md:hidden" id="mobile-menu-btn" aria-label="Menu">
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div class="hidden border-t border-gray-100 bg-white md:hidden" id="mobile-menu">
    <div class="flex flex-col gap-1 px-6 py-4">
      {brand.nav.map(link => (
        <a href={link.href} class="rounded-lg px-4 py-3 text-sm transition-colors hover:bg-gray-50">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  btn.addEventListener('click', () => menu.classList.toggle('hidden'));
</script>
