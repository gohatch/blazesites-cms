---
import brand from '../../brand.json';
---
<section class="relative overflow-hidden py-20" style={`background-color: ${brand.colors.primary}`}>
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <!-- Image -->
      <div class="animate-on-scroll from-left relative overflow-hidden rounded-2xl" style="aspect-ratio: 4/3">
        <img
          src={brand.aboutImage}
          alt="Project categories"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>

      <!-- Text -->
      <div class="animate-on-scroll from-right">
        <h2 class="text-4xl text-white sm:text-5xl" style="line-height: 1.05">
          <span class="heading-serif">Project</span><br />
          <span class="heading-italic">Categories</span>
        </h2>

        <ul class="mt-8 space-y-3">
          {brand.categories.map((cat) => (
            <li class="dot-marker text-sm text-white/70">{cat}</li>
          ))}
        </ul>

        <a href="/contact" class="mt-8 inline-flex items-center gap-2 rounded-full border border-white/30 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-white/10">
          Contact us
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
