---
import brand from '../../brand.json';

const iconPaths: Record<string, string> = {
  home: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  building: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
};
---
<section class="section-padding bg-white">
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll mx-auto max-w-2xl text-center">
      <p class="text-sm font-semibold" style={`color: ${brand.colors.accent}`}>Our Services</p>
      <h2 class="mt-2 text-3xl font-extrabold tracking-tight sm:text-4xl">Complete Roofing Solutions</h2>
      <p class="mt-4 text-base" style={`color: ${brand.colors.textLight}`}>
        From residential repairs to commercial installations, we deliver exceptional roofing services that protect what matters most to you.
      </p>
    </div>

    <div class="stagger-children mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {brand.services.map((service) => (
        <div class="card-hover rounded-2xl border border-gray-100 bg-white p-7 shadow-sm">
          <div class="icon-box">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[service.icon] || iconPaths.home} />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-bold">{service.title}</h3>
          <p class="mt-2 text-sm leading-relaxed" style={`color: ${brand.colors.textLight}`}>{service.description}</p>
        </div>
      ))}

      <!-- CTA Card (accent) -->
      <div class="card-hover flex flex-col justify-center rounded-2xl p-7 text-white" style={`background-color: ${brand.colors.accent}`}>
        <svg class="h-10 w-10 opacity-80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <h3 class="mt-5 text-xl font-bold leading-tight">Schedule your roofing consultation</h3>
        <a href="/contact" class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-white/90 transition-colors hover:text-white">
          Book now
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
