---
import brand from '../../brand.json';
---
<section id="contact" class="section-padding" style={`background:${brand.colors.bg}`}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 animate-on-scroll">
      <p class="text-xs tracking-[0.2em] uppercase mb-3" style={`color:${brand.colors.accent}`}>Say Hello</p>
      <h2 class="font-script text-4xl sm:text-5xl font-medium" style={`color:${brand.colors.text}`}>{brand.contact.heading}</h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 animate-on-scroll">
      <form class="space-y-4">
        <div class="grid grid-cols-2 gap-3">
          <input type="text" placeholder="First Name" class="w-full px-4 py-3 rounded-lg text-sm font-light outline-none" style={`background:${brand.colors.white}; border:1px solid ${brand.colors.border}; color:${brand.colors.text}`} />
          <input type="text" placeholder="Last Name" class="w-full px-4 py-3 rounded-lg text-sm font-light outline-none" style={`background:${brand.colors.white}; border:1px solid ${brand.colors.border}; color:${brand.colors.text}`} />
        </div>
        <input type="email" placeholder="Email" class="w-full px-4 py-3 rounded-lg text-sm font-light outline-none" style={`background:${brand.colors.white}; border:1px solid ${brand.colors.border}; color:${brand.colors.text}`} />
        <select class="w-full px-4 py-3 rounded-lg text-sm font-light outline-none appearance-none" style={`background:${brand.colors.white}; border:1px solid ${brand.colors.border}; color:${brand.colors.textMuted}`}>
          <option value="">Type of Session</option>
          {brand.services.map((s: any) => <option value={s.name}>{s.name}</option>)}
        </select>
        <textarea rows={4} placeholder="Tell us about your vision..." class="w-full px-4 py-3 rounded-lg text-sm font-light outline-none resize-none" style={`background:${brand.colors.white}; border:1px solid ${brand.colors.border}; color:${brand.colors.text}`}></textarea>
        <button type="submit" class="btn-dark w-full">Send Message</button>
      </form>

      <div class="space-y-6">
        <div><p class="text-xs tracking-[0.15em] uppercase mb-1" style={`color:${brand.colors.textMuted}`}>Studio</p><p class="text-sm" style={`color:${brand.colors.text}`}>{brand.address}</p></div>
        <div><p class="text-xs tracking-[0.15em] uppercase mb-1" style={`color:${brand.colors.textMuted}`}>Email</p><p class="text-sm" style={`color:${brand.colors.text}`}>{brand.email}</p></div>
        <div><p class="text-xs tracking-[0.15em] uppercase mb-1" style={`color:${brand.colors.textMuted}`}>Phone</p><p class="text-sm" style={`color:${brand.colors.text}`}>{brand.phone}</p></div>
        <div><p class="text-xs tracking-[0.15em] uppercase mb-1" style={`color:${brand.colors.textMuted}`}>Follow Us</p><p class="font-serif italic text-lg" style={`color:${brand.colors.accent}`}>{brand.instagram}</p></div>
        <div>
          <p class="text-xs tracking-[0.15em] uppercase mb-2" style={`color:${brand.colors.textMuted}`}>Hours</p>
          {brand.contact.hours.map((h: any) => (
            <div class="flex justify-between text-sm py-1" style={`color:${brand.colors.textMuted}; border-bottom:1px solid ${brand.colors.border}`}>
              <span>{h.days}</span><span style={`color:${brand.colors.text}`}>{h.time}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
