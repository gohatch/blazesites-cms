---
import brand from '../../brand.json';
---
<header class="fixed top-0 left-0 right-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <div class="flex items-center justify-between px-6 py-3 rounded-full backdrop-blur-md" style={`background:rgba(44,44,44,0.85)`}>
      <!-- Logo -->
      <a href="#" class="font-script text-lg text-white tracking-wide">{brand.name}</a>
      <!-- Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {brand.nav.map((item: any, i: number) => (
          <a href={item.href} class="text-xs font-medium tracking-wide transition-colors" style={i === 0 ? `color:${brand.colors.accent}` : 'color:rgba(255,255,255,0.7)'}>
            {item.label}
          </a>
        ))}
      </nav>
      <!-- CTA -->
      <a href="#contact" class="hidden md:block btn-accent text-xs py-2 px-5">{brand.hero.cta}</a>
      <!-- Mobile -->
      <button id="mob-btn" class="md:hidden p-2" aria-label="Menu">
        <div class="space-y-1"><span class="block w-5 h-px bg-white"></span><span class="block w-3.5 h-px bg-white"></span></div>
      </button>
    </div>
  </div>
  <div id="mob-menu" class="md:hidden fixed inset-0 top-16 transform translate-x-full transition-transform duration-300 z-40" style={`background:${brand.colors.bgDark}`}>
    <nav class="flex flex-col items-center justify-center h-full gap-6">
      {brand.nav.map((item: any) => (
        <a href={item.href} class="mob-link font-serif text-xl text-white">{item.label}</a>
      ))}
    </nav>
  </div>
</header>
<script>
  const b=document.getElementById('mob-btn'),m=document.getElementById('mob-menu');let o=false;
  b?.addEventListener('click',()=>{o=!o;m?.classList.toggle('translate-x-full',!o);m?.classList.toggle('translate-x-0',o);});
  document.querySelectorAll('.mob-link').forEach(l=>l.addEventListener('click',()=>{o=false;m?.classList.add('translate-x-full');m?.classList.remove('translate-x-0');}));
</script>
