---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.cream}`}>
  <div class="max-w-7xl mx-auto">
    <!-- Heading -->
    <div class="text-center mb-14 animate-on-scroll">
      <p
        class="text-sm font-bold uppercase tracking-[0.2em] mb-3"
        style={`color: ${brand.colors.accent}`}
      >Testimonials</p>
      <h2 class="font-serif text-4xl md:text-5xl" style={`color: ${brand.colors.text}`}>
        Hear From Our Clients
      </h2>
    </div>

    <!-- Testimonial Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
      {brand.testimonials.map((t: { quote: string; author: string; role: string; image: string; rating: string }) => (
        <div
          class="card-hover p-8 rounded-xl"
          style={`background-color: ${brand.colors.bg}`}
        >
          <!-- Stars -->
          <div class="flex gap-1 mb-5">
            {[...Array(5)].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill={brand.colors.accent} stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            ))}
          </div>
          <!-- Quote -->
          <p
            class="text-sm leading-relaxed mb-6 italic"
            style={`color: ${brand.colors.textLight}`}
          >"{t.quote}"</p>
          <!-- Author -->
          <div class="flex items-center gap-3 pt-4 border-t" style={`border-color: ${brand.colors.cream}`}>
            <img
              src={t.image}
              alt={t.author}
              class="w-12 h-12 rounded-full object-cover"
              loading="lazy"
            />
            <div>
              <p
                class="text-sm font-bold"
                style={`color: ${brand.colors.accent}`}
              >{t.author}</p>
              <p
                class="text-xs"
                style={`color: ${brand.colors.textLight}`}
              >{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
