---
import brand from '../../brand.json';

const iconMap: Record<string, string> = {
  star: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>`,
  lightbulb: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>`,
  shield: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"/></svg>`,
  leaf: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
};
---
<section class="section-padding" style={`background-color: ${brand.colors.primary}`}>
  <div class="max-w-7xl mx-auto">
    <!-- Heading -->
    <div class="text-center mb-16 animate-on-scroll">
      <p
        class="text-sm font-bold uppercase tracking-[0.2em] mb-3"
        style={`color: ${brand.colors.accent}`}
      >What We Stand For</p>
      <h2 class="font-serif text-4xl md:text-5xl text-white uppercase">
        Our Core Values
      </h2>
    </div>

    <!-- Values Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 stagger-children">
      {brand.values.map((value: { title: string; description: string; icon: string }) => (
        <div class="text-center p-8 rounded-xl border border-white/10 hover:border-white/25 transition-all duration-300">
          <div
            class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-5"
            style={`background-color: rgba(232, 93, 38, 0.15); color: ${brand.colors.accent}`}
          >
            <Fragment set:html={iconMap[value.icon] || iconMap.star} />
          </div>
          <h3
            class="text-lg font-bold uppercase tracking-wider mb-3"
            style={`color: ${brand.colors.accent}`}
          >{value.title}</h3>
          <p class="text-sm leading-relaxed text-white/75">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
