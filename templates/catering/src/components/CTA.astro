---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.bg}`}>
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 rounded-2xl overflow-hidden min-h-[400px]">
      <!-- Left: CTA Content -->
      <div
        class="flex flex-col justify-center p-10 md:p-16 animate-on-scroll from-left"
        style={`background-color: ${brand.colors.primary}`}
      >
        <p
          class="text-sm font-bold uppercase tracking-[0.2em] mb-4"
          style={`color: ${brand.colors.accent}`}
        >Get Started Today</p>
        <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl text-white uppercase leading-tight mb-6">
          Ready to Elevate Your Culinary Journey?
        </h2>
        <p class="text-white/70 text-base leading-relaxed mb-8 max-w-md">
          Let our expert team create an unforgettable dining experience for your next event. From intimate dinners to grand celebrations.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#" class="btn-primary">Book Now &#8594;</a>
          <a
            href="#"
            class="inline-flex items-center gap-2 px-6 py-3 border-2 border-white/30 text-white text-xs font-bold uppercase tracking-wider rounded no-underline transition-all hover:bg-white/10"
          >
            View Menu
          </a>
        </div>
      </div>
      <!-- Right: Image -->
      <div class="animate-on-scroll from-right relative">
        <img
          src="https://images.unsplash.com/photo-1600565193348-f74bd3c7ccdf?w=800&q=80"
          alt="Chef preparing a gourmet dish"
          class="w-full h-full object-cover min-h-[300px]"
          loading="lazy"
        />
        <!-- Overlay Accent -->
        <div
          class="absolute bottom-0 left-0 right-0 h-1"
          style={`background-color: ${brand.colors.accent}`}
        ></div>
      </div>
    </div>
  </div>
</section>
