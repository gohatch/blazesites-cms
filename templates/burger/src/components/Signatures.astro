---
import brand from '../../brand.json';
---
<section class="section-padding text-center" style={`background-color: ${brand.colors.cream}`}>
  <div class="mx-auto max-w-7xl">
    <div class="animate-on-scroll">
      <p class="heading-display text-sm tracking-[0.2em]" style={`color: ${brand.colors.accent}`}>
        Explore Our Menu
      </p>
      <h2 class="heading-display mt-3 text-5xl sm:text-6xl lg:text-7xl xl:text-8xl" style={`color: ${brand.colors.primary}`}>
        Our Signature<br />
        <span class="text-outline">Burgers</span>
      </h2>
      <p class="mx-auto mt-5 max-w-lg text-sm leading-relaxed sm:text-base" style={`color: ${brand.colors.textLight}`}>
        Discover our most-loved burgers, crafted with premium ingredients and bold flavors that keep customers coming back for more.
      </p>
    </div>

    <div class="stagger-children mt-16 grid gap-10 sm:grid-cols-3">
      {brand.signatures.map((burger, i) => (
        <div class="group relative">
          <!-- Card -->
          <div class="relative mx-auto w-full max-w-[320px] overflow-hidden rounded-3xl shadow-xl transition-all duration-500 group-hover:-translate-y-3 group-hover:shadow-2xl" style="aspect-ratio: 3/4">
            <img
              src={burger.image}
              alt={burger.name}
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <!-- Gradient overlay at bottom -->
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/40 to-transparent"></div>

            <!-- Gold "Best Menu" circular badge -->
            <div class="absolute left-4 top-4 flex h-16 w-16 items-center justify-center rounded-full shadow-lg" style={`background-color: ${brand.colors.accent}`}>
              <span class="heading-display text-[0.55rem] leading-tight text-center" style={`color: ${brand.colors.primary}`}>Best<br/>Menu</span>
            </div>

            <!-- Number badge -->
            <div class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-full bg-white/20 backdrop-blur-sm">
              <span class="heading-display text-sm text-white">0{i + 1}</span>
            </div>
          </div>

          <!-- Gold tag label -->
          <div class="mx-auto mt-5 max-w-[240px]">
            <span class="gold-tag !rounded-lg !px-5 !py-2 !text-sm">{burger.name}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="animate-on-scroll mt-14">
      <a href="/contact" class="btn-pill !px-10 !py-4 !text-base">
        Get Your Burger
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
