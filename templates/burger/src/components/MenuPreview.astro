---
import brand from '../../brand.json';
---
<section class="section-padding text-center" style={`background-color: ${brand.colors.cream}`}>
  <div class="mx-auto max-w-5xl">
    <div class="animate-on-scroll">
      <p class="heading-display text-sm tracking-[0.2em]" style={`color: ${brand.colors.accent}`}>
        What We Serve
      </p>
      <h2 class="heading-display mt-3 text-5xl sm:text-6xl lg:text-7xl xl:text-8xl" style={`color: ${brand.colors.primary}`}>
        Menu <span class="text-outline">Preview</span>
      </h2>
      <p class="mx-auto mt-5 max-w-lg text-sm leading-relaxed sm:text-base" style={`color: ${brand.colors.textLight}`}>
        From juicy burgers to crispy fries and refreshing drinks, explore a taste of what awaits you at {brand.businessName}.
      </p>
    </div>

    <div class="stagger-children mt-14 flex flex-wrap items-center justify-center gap-12 sm:gap-16">
      {brand.menuPreview.map((item) => (
        <div class="group flex flex-col items-center">
          <!-- Circular image with gold ring border -->
          <div class="relative">
            <!-- Outer gold ring -->
            <div class="absolute -inset-3 rounded-full" style={`border: 3px solid ${brand.colors.accent}`}></div>
            <!-- Second subtle ring -->
            <div class="absolute -inset-5 rounded-full" style={`border: 1px solid ${brand.colors.accent}44`}></div>

            <div class="relative h-36 w-36 overflow-hidden rounded-full shadow-xl transition-transform duration-500 group-hover:scale-105 sm:h-44 sm:w-44 lg:h-48 lg:w-48">
              <img
                src={item.image}
                alt={item.name}
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
            </div>
          </div>

          <!-- Gold tag -->
          <span class="gold-tag mt-6 !rounded-lg !px-5 !py-2 !text-sm">{item.name}</span>
        </div>
      ))}
    </div>

    <div class="animate-on-scroll mt-14">
      <a href="/menu" class="btn-pill !px-10 !py-4 !text-base">
        View Full Menu
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
