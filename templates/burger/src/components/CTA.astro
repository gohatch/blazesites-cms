---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.accent}`}>
  <div class="mx-auto max-w-4xl">
    <div class="animate-on-scroll text-center">
      <p class="heading-display text-sm tracking-[0.2em]" style={`color: ${brand.colors.primary}`}>
        Reservation
      </p>
      <h2 class="heading-display mt-3 text-5xl sm:text-6xl lg:text-7xl xl:text-8xl" style={`color: ${brand.colors.primary}`}>
        Come Enjoy<br />With <span style={`-webkit-text-stroke: 2px ${brand.colors.primary}; color: transparent`}>Us</span>
      </h2>
      <p class="mx-auto mt-5 max-w-lg text-sm leading-relaxed sm:text-base" style={`color: ${brand.colors.dark}`}>
        {brand.cta.subheading}
      </p>

      <!-- White card form -->
      <form class="mt-12 rounded-3xl bg-white p-8 text-left shadow-2xl sm:p-10" onsubmit="event.preventDefault()">
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label class="mb-2 block text-xs font-bold uppercase tracking-widest" style={`color: ${brand.colors.textLight}`}>Full Name</label>
            <input
              type="text"
              placeholder="Your name"
              class="w-full rounded-xl border-2 border-gray-200 px-5 py-3.5 text-sm outline-none transition-all duration-300 focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20"
            />
          </div>
          <div>
            <label class="mb-2 block text-xs font-bold uppercase tracking-widest" style={`color: ${brand.colors.textLight}`}>Email Address</label>
            <input
              type="email"
              placeholder="you@email.com"
              class="w-full rounded-xl border-2 border-gray-200 px-5 py-3.5 text-sm outline-none transition-all duration-300 focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20"
            />
          </div>
          <div>
            <label class="mb-2 block text-xs font-bold uppercase tracking-widest" style={`color: ${brand.colors.textLight}`}>Phone Number</label>
            <input
              type="tel"
              placeholder="(555) 000-0000"
              class="w-full rounded-xl border-2 border-gray-200 px-5 py-3.5 text-sm outline-none transition-all duration-300 focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20"
            />
          </div>
          <div>
            <label class="mb-2 block text-xs font-bold uppercase tracking-widest" style={`color: ${brand.colors.textLight}`}>Guest</label>
            <select class="w-full rounded-xl border-2 border-gray-200 px-5 py-3.5 text-sm outline-none transition-all duration-300 focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20">
              <option>1 Person</option>
              <option>2 People</option>
              <option>3-4 People</option>
              <option>5+ People</option>
            </select>
          </div>
          <div>
            <label class="mb-2 block text-xs font-bold uppercase tracking-widest" style={`color: ${brand.colors.textLight}`}>Date</label>
            <input
              type="date"
              class="w-full rounded-xl border-2 border-gray-200 px-5 py-3.5 text-sm outline-none transition-all duration-300 focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20"
            />
          </div>
          <div>
            <label class="mb-2 block text-xs font-bold uppercase tracking-widest" style={`color: ${brand.colors.textLight}`}>Time</label>
            <select class="w-full rounded-xl border-2 border-gray-200 px-5 py-3.5 text-sm outline-none transition-all duration-300 focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/20">
              <option>11:00 AM</option>
              <option>12:00 PM</option>
              <option>1:00 PM</option>
              <option>6:00 PM</option>
              <option>7:00 PM</option>
              <option>8:00 PM</option>
            </select>
          </div>
        </div>

        <button type="submit" class="btn-pill mt-8 w-full justify-center !py-4 !text-base">
          Get Your Burger
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>
