---
import brand from '../../brand.json';
---
<footer style={`background-color: ${brand.colors.primary}`} class="text-white">
  <div class="mx-auto max-w-7xl px-6 py-20">
    <!-- Centered logo + tagline -->
    <div class="text-center">
      <p class="heading-display text-4xl sm:text-5xl lg:text-6xl">{brand.businessName}</p>
      <p class="mx-auto mt-4 max-w-md text-sm leading-relaxed text-white/50 sm:text-base">
        Serving freshly grilled, handcrafted burgers made with premium ingredients and bold flavors. Your go-to spot for juicy burgers, crispy fries, and great vibes every day.
      </p>
    </div>

    <!-- Divider -->
    <div class="mx-auto mt-12 h-px max-w-3xl" style={`background: linear-gradient(to right, transparent, ${brand.colors.accent}66, transparent)`}></div>

    <!-- 4 Column grid -->
    <div class="mt-12 grid gap-10 text-sm sm:grid-cols-2 lg:grid-cols-4">
      <!-- Quick Link -->
      <div class="text-center lg:text-left">
        <p class="heading-display text-xs tracking-[0.15em]" style={`color: ${brand.colors.accent}`}>Quick Link</p>
        <ul class="mt-5 space-y-3">
          <li><a href="/" class="text-white/50 transition-colors duration-200 hover:text-white">Home</a></li>
          <li><a href="/about" class="text-white/50 transition-colors duration-200 hover:text-white">Find Your Spot</a></li>
          <li><a href="/about" class="text-white/50 transition-colors duration-200 hover:text-white">About Us</a></li>
          <li><a href="/menu" class="text-white/50 transition-colors duration-200 hover:text-white">Signature Burgers</a></li>
          <li><a href="/contact" class="text-white/50 transition-colors duration-200 hover:text-white">Reviews</a></li>
        </ul>
      </div>

      <!-- Follow Us -->
      <div class="text-center lg:text-left">
        <p class="heading-display text-xs tracking-[0.15em]" style={`color: ${brand.colors.accent}`}>Follow Us</p>
        <ul class="mt-5 space-y-3">
          <li><a href="#" class="text-white/50 transition-colors duration-200 hover:text-white">Instagram</a></li>
          <li><a href="#" class="text-white/50 transition-colors duration-200 hover:text-white">Facebook</a></li>
          <li><a href="#" class="text-white/50 transition-colors duration-200 hover:text-white">TikTok</a></li>
          <li><a href="#" class="text-white/50 transition-colors duration-200 hover:text-white">Twitter / X</a></li>
        </ul>
      </div>

      <!-- Contact Us -->
      <div class="text-center lg:text-left">
        <p class="heading-display text-xs tracking-[0.15em]" style={`color: ${brand.colors.accent}`}>Contact Us</p>
        <div class="mt-5 space-y-3 text-white/50">
          {brand.contact.address && <p>{brand.contact.address}</p>}
          {brand.contact.phone && <p>{brand.contact.phone}</p>}
          {brand.contact.email && (
            <p><a href={`mailto:${brand.contact.email}`} class="transition-colors duration-200 hover:text-white">{brand.contact.email}</a></p>
          )}
        </div>
      </div>

      <!-- Opening Hours -->
      <div class="text-center lg:text-left">
        <p class="heading-display text-xs tracking-[0.15em]" style={`color: ${brand.colors.accent}`}>Opening Hours</p>
        <div class="mt-5 space-y-4 text-white/50">
          <div>
            <p class="font-semibold text-white/70">Monday - Friday</p>
            <p>9:00 AM - 10:00 PM</p>
          </div>
          <div>
            <p class="font-semibold text-white/70">Saturday - Sunday</p>
            <p>10:00 AM - 11:00 PM</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-14 border-t border-white/10 pt-8 text-center">
      <p class="text-xs text-white/30">
        &copy; {new Date().getFullYear()} {brand.businessName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
