---
import brand from '../../brand.json';
---
<section class="section-padding" style={`background-color: ${brand.colors.light}`}>
  <div class="mx-auto max-w-3xl">
    <div class="animate-on-scroll mx-auto max-w-xl text-center">
      <p class="text-sm font-bold uppercase tracking-widest" style={`color: ${brand.colors.accent}`}>Contact</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight sm:text-4xl">Get Your Free Estimate</h2>
      <p class="mt-4 text-lg" style={`color: ${brand.colors.textLight}`}>
        Tell us about your project and we'll get back to you within 24 hours.
      </p>
    </div>

    <div class="animate-on-scroll mt-12">
      <form class="rounded-2xl border border-gray-100 bg-white p-8 shadow-lg sm:p-10" onsubmit="event.preventDefault()">
        <div class="grid gap-6 sm:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-semibold">Full Name</label>
            <input
              type="text"
              placeholder="John Smith"
              class="w-full rounded-lg border-2 border-gray-200 p-3.5 text-sm transition-colors focus:outline-none"
              style="--focus-color: var(--color-accent)"
              onfocus="this.style.borderColor=this.style.getPropertyValue('--focus-color')"
              onblur="this.style.borderColor='#e5e7eb'"
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold">Email</label>
            <input
              type="email"
              placeholder="john@example.com"
              class="w-full rounded-lg border-2 border-gray-200 p-3.5 text-sm transition-colors focus:outline-none"
              onfocus="this.style.borderColor='var(--color-accent)'"
              onblur="this.style.borderColor='#e5e7eb'"
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold">Phone</label>
            <input
              type="tel"
              placeholder="(555) 123-4567"
              class="w-full rounded-lg border-2 border-gray-200 p-3.5 text-sm transition-colors focus:outline-none"
              onfocus="this.style.borderColor='var(--color-accent)'"
              onblur="this.style.borderColor='#e5e7eb'"
            />
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold">Project Type</label>
            <select
              class="w-full rounded-lg border-2 border-gray-200 p-3.5 text-sm transition-colors focus:outline-none"
              onfocus="this.style.borderColor='var(--color-accent)'"
              onblur="this.style.borderColor='#e5e7eb'"
            >
              <option value="">Select a service</option>
              {brand.services.map(s => (
                <option value={s.title}>{s.title}</option>
              ))}
            </select>
          </div>
        </div>
        <div class="mt-6">
          <label class="mb-2 block text-sm font-semibold">Project Details</label>
          <textarea
            rows="4"
            placeholder="Tell us about your project..."
            class="w-full rounded-lg border-2 border-gray-200 p-3.5 text-sm transition-colors focus:outline-none"
            onfocus="this.style.borderColor='var(--color-accent)'"
            onblur="this.style.borderColor='#e5e7eb'"
          ></textarea>
        </div>
        <button type="submit" class="btn-accent mt-6 w-full py-4 text-center">
          Request Free Estimate
        </button>
        <p class="mt-3 text-center text-xs" style={`color: ${brand.colors.textLight}`}>
          We'll respond within 24 hours. No spam, ever.
        </p>
      </form>
    </div>
  </div>
</section>
